#
# Tests for AggregateJoinRemoveRule and related rules.
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testAggregateJoinRemove1 ----------------------------------------------------
# Should remove the left join since the aggregate has no call and
# only uses column in the left input of the bottom join as group key.

select distinct e.deptno
from emp e
left outer join dept d on e.deptno = d.deptno;
+--------+
| DEPTNO |
+--------+
|     10 |
|     20 |
|     30 |
+--------+
(3 rows)

!ok
LogicalAggregate(group=[{0}])
  LogicalProject(DEPTNO=[$7])
    LogicalJoin(condition=[=($7, $9)], joinType=[left])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalAggregate(group=[{7}])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_REMOVE"

# testAggregateJoinRemove10 ---------------------------------------------------
# Similar to testAggregateJoinRemove1; should not remove the bottom join since
# the aggregate uses column in the right input of bottom join.

SELECT e.deptno, COUNT(DISTINCT d1.dname, d2.dname)
FROM emp e
LEFT JOIN dept d1 ON e.deptno = d1.deptno
LEFT JOIN dept d2 ON e.deptno = d2.deptno
GROUP BY e.deptno;
# Not using !ok: this test focuses on plan transformation (see !sub-plan).
LogicalAggregate(group=[{0}], EXPR$1=[COUNT(DISTINCT $1, $2)])
  LogicalProject(DEPTNO=[$7], DNAME=[$10], DNAME0=[$12])
    LogicalJoin(condition=[=($7, $11)], joinType=[left])
      LogicalJoin(condition=[=($7, $9)], joinType=[left])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalAggregate(group=[{7}], EXPR$1=[COUNT(DISTINCT $10, $12)])
  LogicalJoin(condition=[=($7, $11)], joinType=[left])
    LogicalJoin(condition=[=($7, $9)], joinType=[left])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_JOIN_REMOVE"

# testAggregateJoinRemove11 ---------------------------------------------------
# Similar to testAggregateJoinRemove3 but with agg call referencing the last
# column of the left input.

select e.deptno, count(distinct e.slacker) as c
from (select empno, job, deptno, job <> 'MANAGER' as slacker
  from emp) e
left outer join dept d on e.deptno = d.deptno
group by e.deptno;
+--------+---+
| DEPTNO | C |
+--------+---+
|     10 | 2 |
|     20 | 2 |
|     30 | 2 |
+--------+---+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$2], SLACKER=[$3])
    LogicalJoin(condition=[=($2, $4)], joinType=[left])
      LogicalProject(EMPNO=[$0], JOB=[$2], DEPTNO=[$7], SLACKER=[<>($2, 'MANAGER')])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalAggregate(group=[{2}], C=[COUNT(DISTINCT $3)])
  LogicalProject(EMPNO=[$0], JOB=[$2], DEPTNO=[$7], SLACKER=[<>($2, 'MANAGER')])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_REMOVE"

# testAggregateJoinRemove2 ----------------------------------------------------
# Similar to testAggregateJoinRemove1 but has aggregate call with distinct.

select e.deptno, count(distinct e.job)
from emp e
left outer join dept d on e.deptno = d.deptno
group by e.deptno;
# Not using !ok: this test focuses on plan transformation (see !sub-plan).
LogicalAggregate(group=[{0}], EXPR$1=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], JOB=[$2])
    LogicalJoin(condition=[=($7, $9)], joinType=[left])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalAggregate(group=[{7}], EXPR$1=[COUNT(DISTINCT $2)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_REMOVE"

# testAggregateJoinRemove3 ----------------------------------------------------
# Similar to testAggregateJoinRemove1 but should not remove the left join
# since the aggregate uses column in the right input of the bottom join.

select e.deptno, count(distinct d.dname) as c
from emp e
left outer join dept d on e.deptno = d.deptno
group by e.deptno;
+--------+---+
| DEPTNO | C |
+--------+---+
|     10 | 1 |
|     20 | 1 |
|     30 | 1 |
+--------+---+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], DNAME=[$10])
    LogicalJoin(condition=[=($7, $9)], joinType=[left])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalAggregate(group=[{7}], C=[COUNT(DISTINCT $10)])
  LogicalJoin(condition=[=($7, $9)], joinType=[left])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_REMOVE"

# testAggregateJoinRemove4 ----------------------------------------------------
# Similar to testAggregateJoinRemove1 but right join.

select distinct d.deptno
from emp e
right outer join dept d on e.deptno = d.deptno;
# Not using !ok: this test focuses on plan transformation (see !sub-plan).
LogicalAggregate(group=[{0}])
  LogicalProject(DEPTNO=[$9])
    LogicalJoin(condition=[=($7, $9)], joinType=[right])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan ""
LogicalProject(DEPTNO=[$0])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_REMOVE"

# testAggregateJoinRemove5 ----------------------------------------------------
