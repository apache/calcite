#
# Tests planner rules for merging Sort/Limit operators
# (LIMIT_MERGE, SORT_PROJECT_TRANSPOSE).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testLimitMerge ---------------------------------------------------------------
# LIMIT_MERGE should merge two nested LIMIT operators into one, keeping the
# smaller fetch value.

select deptno
from (select deptno from emp where sal > 100 limit 10000)
limit 10;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
+--------+
(10 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(fetch=[10])
      LogicalSort(fetch=[10000])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(fetch=[10])
    LogicalFilter(condition=[>($5, 100)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_REMOVE"

# testLimitMerge1 --------------------------------------------------------------
# LIMIT_MERGE should merge two nested LIMIT operators, keeping the smaller
# fetch when the inner has ORDER BY.

select deptno
from (
  select deptno
  from emp
  where sal > 100
  order by sal desc limit 10000)
limit 10;
# Not using !ok: this test focuses on plan transformation (see !sub-plan).
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalSort(fetch=[10])
      LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10000])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10])
    LogicalFilter(condition=[>($5, 100)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_MERGE"

# testLimitMerge2 --------------------------------------------------------------
# LIMIT_MERGE should merge two nested LIMIT operators, keeping the smaller
# fetch when the inner has ORDER BY and inner fetch is smaller.

select deptno
from (
  select deptno
  from emp
  where sal > 100
  order by sal desc limit 10)
limit 10000;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
|     30 |
|     30 |
+--------+
(10 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalSort(fetch=[10000])
      LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10])
    LogicalFilter(condition=[>($5, 100)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_MERGE"

# testLimitMerge3 --------------------------------------------------------------
# LIMIT_MERGE should not merge when the outer has ORDER BY (different semantics);
# PROJECT_REMOVE collapses the identity project.

select deptno
from (
  select deptno
  from emp
  where sal > 100
  limit 100)
order by deptno desc;
+--------+
| DEPTNO |
+--------+
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
|     20 |
|     20 |
|     20 |
|     20 |
|     20 |
|     10 |
|     10 |
|     10 |
+--------+
(14 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(sort0=[$7], dir0=[DESC])
      LogicalSort(fetch=[100])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(sort0=[$7], dir0=[DESC])
    LogicalSort(fetch=[100])
      LogicalFilter(condition=[>($5, 100)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_REMOVE"

# testLimitMerge4 --------------------------------------------------------------
# LIMIT_MERGE should not merge when the inner and outer have different ORDER BY
# keys; the projects are merged instead.

select deptno
from (select deptno
  from emp
  where sal > 100
  order by sal desc limit 10)
order by deptno limit 10000;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
|     30 |
|     30 |
+--------+
(10 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalSort(sort0=[$7], dir0=[ASC], fetch=[10000])
      LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(sort0=[$7], dir0=[ASC], fetch=[10000])
    LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10])
      LogicalFilter(condition=[>($5, 100)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_MERGE"

# testLimitMerge5 --------------------------------------------------------------
# LIMIT_MERGE should merge when the inner fetch (10000) is greater than the
# outer fetch (10); the projects are merged.

select deptno
from (select deptno
  from emp
  where sal > 100
  order by sal desc limit 10000)
order by deptno limit 10;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
+--------+
(10 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalSort(sort0=[$7], dir0=[ASC], fetch=[10])
      LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10000])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$7])
  LogicalSort(sort0=[$7], dir0=[ASC], fetch=[10])
    LogicalSort(sort0=[$5], dir0=[DESC], fetch=[10000])
      LogicalFilter(condition=[>($5, 100)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_MERGE"

# testLimitMergeBigint ---------------------------------------------------------
# LIMIT_MERGE should handle BIGINT fetch values (> Integer.MAX_VALUE).
# Not using !ok: Fetch size is too large for EnumerableLimit to implement

select deptno
from (select deptno from emp where sal > 100 limit 3100000000)
limit 3000000000;
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(fetch=[3000000000:BIGINT])
      LogicalSort(fetch=[3100000000:BIGINT])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(fetch=[3000000000:BIGINT])
      LogicalFilter(condition=[>($5, 100)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE, PROJECT_MERGE"

# End limit-merge.iq
