# testUncorrelatedCallInConjunctionIsFlattenedOnlyIfSiblingOfCorrelation -------
# FilterFlattenCorrelatedConditionRule flattens an uncorrelated call in a
# conjunction only if it is a sibling of the correlation.

select *
from emp e1
where exists (
  select *
  from emp e2
  where (e2.empno+50) < 20 and e1.deptno >= (30+e2.deptno));
