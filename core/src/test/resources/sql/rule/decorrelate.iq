# (correlation is removed by the SQL-to-rel converter).

WITH
  t1(a, ts) AS (VALUES('a', 1)),
  t2(a, ts, x) AS (SELECT ename as a, empno as ts, mgr as x FROM emp)
SELECT *
FROM t1
LEFT JOIN LATERAL (
    SELECT x
    FROM t2
    WHERE t2.a = t1.a AND t2.ts <= t1.ts
    LIMIT 1) ON true
LEFT JOIN LATERAL (
    SELECT x
    FROM t2
    WHERE t2.a = t1.a) ON true;
