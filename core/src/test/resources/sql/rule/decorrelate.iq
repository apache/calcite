# testLateralTransposeWithDecorrelateFalse -------------------------------------
# ProjectCorrelateTransposeRule does not transpose when decorrelate=false.

WITH
  t1(a, ts) AS (VALUES('a', 1)),
  t2(a, ts, x) AS (SELECT ename as a, empno as ts, mgr as x FROM emp)
SELECT *
FROM t1
LEFT JOIN LATERAL (
    SELECT x
    FROM t2
    WHERE t2.a = t1.a AND t2.ts <= t1.ts
    LIMIT 1) ON true
LEFT JOIN LATERAL (
    SELECT x
    FROM t2
    WHERE t2.a = t1.a) ON true;
+---+----+---+----+
| A | TS | X | X0 |
+---+----+---+----+
| a |  1 |   |    |
+---+----+---+----+
(1 row)

!ok
LogicalProject(A=[$0], TS=[$1], X=[$2], X0=[$3])
  LogicalCorrelate(correlation=[$cor2], joinType=[left], requiredColumns=[{0}])
    LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0, 1}])
      LogicalValues(tuples=[[{ 'a', 1 }]])
      LogicalSort(fetch=[1])
        LogicalProject(X=[$2])
          LogicalFilter(condition=[AND(=($0, CAST($cor0.A):VARCHAR(20) NOT NULL), <=($1, $cor0.TS))])
            LogicalProject(A=[$1], TS=[$0], X=[$3])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(X=[$2])
      LogicalFilter(condition=[=($0, CAST($cor2.A):VARCHAR(20) NOT NULL)])
        LogicalProject(A=[$1], TS=[$0], X=[$3])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "decorrelate=false, NONE"
LogicalProject(A=[$0], TS=[$1], X=[$2], X0=[$3])
  LogicalCorrelate(correlation=[$cor2], joinType=[left], requiredColumns=[{0}])
    LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0, 1}])
      LogicalValues(tuples=[[{ 'a', 1 }]])
      LogicalSort(fetch=[1])
        LogicalProject(X=[$2])
          LogicalFilter(condition=[AND(=($0, CAST($cor0.A):VARCHAR(20) NOT NULL), <=($1, $cor0.TS))])
            LogicalProject(A=[$1], TS=[$0], X=[$3])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(X=[$2])
      LogicalFilter(condition=[=($0, CAST($cor2.A):VARCHAR(20) NOT NULL)])
        LogicalProject(A=[$1], TS=[$0], X=[$3])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "decorrelate=false, PROJECT_CORRELATE_TRANSPOSE"
