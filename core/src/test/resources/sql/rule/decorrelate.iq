# Tests for decorrelation.
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testCallOverCorrelationVariableIsNotFlattened --------------------------------
# FilterFlattenCorrelatedConditionRule does not flatten a call that is over a
# correlation variable (the correlated expression is on the left side of the
# equals).

select *
from emp e1
where exists (
  select *
  from emp e2
  where (e1.deptno+30) = e2.deptno);
+-------+-------+-----+-----+----------+-----+------+--------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO |
+-------+-------+-----+-----+----------+-----+------+--------+
+-------+-------+-----+-----+----------+-----+------+--------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[IS NOT NULL($9)])
    LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{7}])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalAggregate(group=[{}], agg#0=[MIN($0)])
        LogicalProject($f0=[true])
          LogicalFilter(condition=[=(+($cor0.DEPTNO, 30), $7)])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, decorrelate=false, NONE"
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[IS NOT NULL($9)])
    LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{7}])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalAggregate(group=[{}], agg#0=[MIN($0)])
        LogicalProject($f0=[true])
          LogicalFilter(condition=[=(+($cor0.DEPTNO, 30), $7)])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, decorrelate=false, FILTER_FLATTEN_CORRELATED_CONDITION"
# testCorrelatedVariableAtSecondLevel ------------------------------------------
# RelDecorrelator handles a correlated variable used at the second level.

SELECT d1.dname,
  d1.deptno
    + (SELECT e1.empno
        FROM emp e1
        WHERE e1.sal =
          (SELECT max(sal)
            FROM emp e2
            WHERE e1.sal = e2.sal and
              e1.deptno = e2.deptno and
              d1.deptno < e2.deptno))
FROM dept d1;
SINGLE_VALUE
!error
LogicalProject(DNAME=[$1], EXPR$1=[+($0, $2)])
  LogicalCorrelate(correlation=[$cor2], joinType=[left], requiredColumns=[{0}])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{}], agg#0=[SINGLE_VALUE($0)])
      LogicalProject(EMPNO=[$0])
        LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
          LogicalFilter(condition=[=($5, $9)])
            LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{5, 7}])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
              LogicalAggregate(group=[{}], EXPR$0=[MAX($0)])
                LogicalProject(SAL=[$5])
                  LogicalFilter(condition=[AND(=($cor0.SAL, $5), =($cor0.DEPTNO, $7), <($cor2.DEPTNO, $7))])
                    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "trim=true, subQueryRules"
LogicalProject(DNAME=[$1], EXPR$1=[+($0, $3)])
  LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $2)], joinType=[left])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}], agg#0=[SINGLE_VALUE($1)])
      LogicalProject(DEPTNO00=[$11], EMPNO=[$0])
        LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], SAL0=[CAST($9):INTEGER], DEPTNO0=[CAST($10):INTEGER], DEPTNO00=[CAST($11):INTEGER], EXPR$0=[CAST($12):INTEGER])
          LogicalJoin(condition=[AND(=($5, $9), =($7, $10))], joinType=[inner])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
            LogicalFilter(condition=[=($0, $3)])
              LogicalAggregate(group=[{0, 1, 2}], EXPR$0=[MAX($3)])
                LogicalProject(SAL0=[$9], DEPTNO0=[$10], DEPTNO00=[$11], SAL=[$5])
                  LogicalJoin(condition=[AND(=($9, $5), =($10, $7), <($11, $7))], joinType=[inner])
                    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
                    LogicalJoin(condition=[true], joinType=[inner])
                      LogicalAggregate(group=[{0, 1}])
                        LogicalProject(SAL=[$5], DEPTNO=[$7])
                          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
                      LogicalProject(DEPTNO=[$0])
                        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "trim=true, lateDecorrelate=true, subQueryRules"

# testCustomColumnResolvingInCorrelatedSubQuery --------------------------------
# SubQueryRemoveRule decorrelates a correlated subquery using struct.t column
# resolving.
# Not using !ok: uses mock catalog only.

select *
from struct.t t1
where c0 = (
  select max(f1.c0)
  from struct.t t2
  where t1.k0 = t2.k0);
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
    LogicalFilter(condition=[=($4, $9)])
      LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0}])
        LogicalTableScan(table=[[CATALOG, STRUCT, T]])
        LogicalAggregate(group=[{}], EXPR$0=[MAX($0)])
          LogicalProject("F1"."C0"=[$5])
            LogicalFilter(condition=[=($cor0."K0", $0)])
              LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, subQueryRules"
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8], "K0"0=[CAST($9):VARCHAR(20)], EXPR$0=[$10])
    LogicalJoin(condition=[AND(=($0, $9), =($4, $10))], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, STRUCT, T]])
      LogicalAggregate(group=[{0}], EXPR$0=[MAX($1)])
        LogicalProject("K0"=[$0], "F1"."C0"=[$5])
          LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, lateDecorrelate=true, subQueryRules"

# testCustomColumnResolvingInCorrelatedSubQuery2 -------------------------------
# SubQueryRemoveRule decorrelates a correlated IN subquery using struct.t column
# resolving.
# Not using !ok: uses mock catalog only.

select *
from struct.t t1
where c0 in (
  select f1.c0
  from struct.t t2
  where t1.c2 = t2.c2);
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
    LogicalFilter(condition=[=($4, $9)])
      LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{7}])
        LogicalTableScan(table=[[CATALOG, STRUCT, T]])
        LogicalAggregate(group=[{0}])
          LogicalProject(C0=[$5])
            LogicalFilter(condition=[=($cor0."F1"."C2", $7)])
              LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, subQueryRules"
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalJoin(condition=[AND(=($7, $10), =($4, $9))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, STRUCT, T]])
    LogicalAggregate(group=[{0, 1}])
      LogicalProject(C0=[$5], "F1"."C2"=[$7])
        LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, lateDecorrelate=true, subQueryRules"

# testCustomColumnResolvingInNonCorrelatedSubQuery -----------------------------
# SubQueryRemoveRule decorrelates a non-correlated IN subquery using struct.t
# column resolving.
# Not using !ok: uses mock catalog only.

select *
from struct.t t1
where c0 in (select f1.c0 from struct.t t2);
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
    LogicalJoin(condition=[=($4, $9)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, STRUCT, T]])
      LogicalAggregate(group=[{0}])
        LogicalProject(C0=[$5])
          LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, subQueryRules"
LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
  LogicalProject("K0"=[$0], "C1"=[$1], "F1"."A0"=[$2], "F2"."A0"=[$3], "F0"."C0"=[$4], "F1"."C0"=[$5], "F0"."C1"=[$6], "F1"."C2"=[$7], "F2"."C3"=[$8])
    LogicalJoin(condition=[=($4, $9)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, STRUCT, T]])
      LogicalAggregate(group=[{0}])
        LogicalProject(C0=[$5])
          LogicalTableScan(table=[[CATALOG, STRUCT, T]])
!sub-plan "trim=true, lateDecorrelate=true, subQueryRules"

# testDecorrelateAggWithConstantGroupKey ---------------------------------------
# RelDecorrelator handles aggregate with a constant group key when
# decorrelating.

SELECT *
FROM emp A
where sal in (SELECT max(sal)
  FROM emp B
  where A.mgr = B.empno
  group by deptno, 'abc');
+-------+-------+-----+-----+----------+-----+------+--------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO |
+-------+-------+-----+-----+----------+-----+------+--------+
+-------+-------+-----+-----+----------+-----+------+--------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalJoin(condition=[AND(=($3, $10), =($5, $9))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(EXPR$0=[$2], EMPNO=[$1])
      LogicalAggregate(group=[{0, 1}], EXPR$0=[MAX($2)])
        LogicalProject(DEPTNO=[$7], EMPNO=[$0], SAL=[$5])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, lateDecorrelate=true, trim=true, NONE"
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalJoin(condition=[AND(=($3, $10), =($5, $9))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(EXPR$0=[$2], EMPNO=[$1])
      LogicalAggregate(group=[{0, 1}], EXPR$0=[MAX($2)])
        LogicalProject(DEPTNO=[$7], EMPNO=[$0], SAL=[$5])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, lateDecorrelate=true, trim=true, NONE"

# testDecorrelateAggWithMultiParamsAggCall -------------------------------------
# RelDecorrelator leaves unchanged a LATERAL with a multi-arg aggregate.
# Not using !ok: uses mock catalog only.

SELECT *
FROM (SELECT MYAGG(sal, 1) AS c FROM emp) as m,
  LATERAL TABLE(ramp(m.c)) AS T(s);
LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{0}])
  LogicalAggregate(group=[{}], C=[MYAGG($0, $1)])
    LogicalProject(SAL=[$5], $f1=[1])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalTableFunctionScan(invocation=[RAMP($cor0.C)], rowType=[RecordType(INTEGER I)])
!sub-plan "lateDecorrelate=true, trim=true, NONE"
LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{0}])
  LogicalAggregate(group=[{}], C=[MYAGG($0, $1)])
    LogicalProject(SAL=[$5], $f1=[1])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalTableFunctionScan(invocation=[RAMP($cor0.C)], rowType=[RecordType(INTEGER I)])
!sub-plan "lateDecorrelate=true, trim=true, NONE"

# testDecorrelateAggWithMultiParamsAggCall2 ------------------------------------
# RelDecorrelator leaves unchanged a LATERAL with a multi-arg aggregate and
# constant group key.
# Not using !ok: uses mock catalog only.

SELECT *
FROM (SELECT MYAGG(sal, 1) AS c FROM emp group by empno, 'abc') as m,
  LATERAL TABLE(ramp(m.c)) AS T(s);
LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{0}])
  LogicalProject(C=[$2])
    LogicalAggregate(group=[{0, 1}], C=[MYAGG($2, $3)])
      LogicalProject(EMPNO=[$0], $f1=['abc'], SAL=[$5], $f3=[1])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalTableFunctionScan(invocation=[RAMP($cor0.C)], rowType=[RecordType(INTEGER I)])
!sub-plan "lateDecorrelate=true, trim=true, NONE"
LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{0}])
  LogicalProject(C=[$2])
    LogicalAggregate(group=[{0, 1}], C=[MYAGG($2, $3)])
      LogicalProject(EMPNO=[$0], $f1=['abc'], SAL=[$5], $f3=[1])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalTableFunctionScan(invocation=[RAMP($cor0.C)], rowType=[RecordType(INTEGER I)])
!sub-plan "lateDecorrelate=true, trim=true, NONE"

# testDecorrelateFilterWithFetchOne --------------------------------------------
# RelDecorrelator decorrelates a scalar subquery with LIMIT 1 in a WHERE
# condition.

SELECT dname
FROM dept
WHERE 10 > (
  SELECT emp.sal
  FROM emp
  where dept.deptno = emp.deptno
  ORDER BY emp.sal limit 1);
+-------+
| DNAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[>(10, $2)])
      LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0}])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalSort(sort0=[$0], dir0=[ASC], fetch=[1])
          LogicalProject(SAL=[$5])
            LogicalFilter(condition=[=($cor0.DEPTNO, $7)])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "FILTER_SUB_QUERY_TO_CORRELATE"
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], DEPTNO0=[CAST($2):INTEGER], $f1=[CAST($3):INTEGER])
    LogicalJoin(condition=[=($0, $2)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalFilter(condition=[>(10, $1)])
        LogicalAggregate(group=[{1}], agg#0=[MIN($0)])
          LogicalProject(SAL=[$5], DEPTNO=[$7])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "lateDecorrelate=true, FILTER_SUB_QUERY_TO_CORRELATE"

# testDecorrelateFilterWithFetchOneDesc ----------------------------------------
# RelDecorrelator decorrelates a scalar subquery with LIMIT 1 DESC NULLS LAST
# in a WHERE condition.

SELECT dname
FROM dept
WHERE 10 > (
  SELECT emp.sal
  FROM emp
  where dept.deptno = emp.deptno
  ORDER BY emp.sal desc nulls last limit 1);
+-------+
| DNAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[>(10, $2)])
      LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0}])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalSort(sort0=[$0], dir0=[DESC-nulls-last], fetch=[1])
          LogicalProject(SAL=[$5])
            LogicalFilter(condition=[=($cor0.DEPTNO, $7)])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "FILTER_SUB_QUERY_TO_CORRELATE"
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], DEPTNO0=[CAST($2):INTEGER], $f1=[CAST($3):INTEGER])
    LogicalJoin(condition=[=($0, $2)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalFilter(condition=[>(10, $1)])
        LogicalAggregate(group=[{1}], agg#0=[MAX($0)])
          LogicalProject(SAL=[$5], DEPTNO=[$7])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "lateDecorrelate=true, FILTER_SUB_QUERY_TO_CORRELATE"

# testDecorrelateFilterWithFetchOneDesc1 ---------------------------------------
# RelDecorrelator decorrelates a scalar subquery with LIMIT 1 DESC in a WHERE
# condition.

SELECT dname
FROM dept
WHERE 10 > (
  SELECT emp.sal
  FROM emp
  where dept.deptno = emp.deptno
  ORDER BY emp.sal desc limit 1);
+-------+
| DNAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[>(10, $2)])
      LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0}])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalSort(sort0=[$0], dir0=[DESC], fetch=[1])
          LogicalProject(SAL=[$5])
            LogicalFilter(condition=[=($cor0.DEPTNO, $7)])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "FILTER_SUB_QUERY_TO_CORRELATE"
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], SAL=[CAST($2):INTEGER], DEPTNO0=[CAST($3):INTEGER], rn=[CAST($4):BIGINT])
    LogicalJoin(condition=[=($0, $3)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalFilter(condition=[>(10, $0)])
        LogicalFilter(condition=[<=($2, 1)])
          LogicalProject(SAL=[$5], DEPTNO=[$7], rn=[ROW_NUMBER() OVER (PARTITION BY $7 ORDER BY $5 DESC NULLS FIRST)])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "lateDecorrelate=true, FILTER_SUB_QUERY_TO_CORRELATE"

# testDecorrelateFilterWithMultiKeyAndFetchOne ---------------------------------
# RelDecorrelator decorrelates a scalar subquery with multiple ORDER BY keys
# and LIMIT 1 in a WHERE condition.

SELECT dname
FROM dept
WHERE 10 > (
  SELECT emp.sal
  FROM emp
  where dept.deptno = emp.deptno
  order by year(hiredate), emp.sal desc limit 1);
+-------+
| DNAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[>(10, $2)])
      LogicalCorrelate(correlation=[$cor0], joinType=[left], requiredColumns=[{0}])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalProject(SAL=[$0])
          LogicalSort(sort0=[$1], sort1=[$0], dir0=[ASC], dir1=[DESC], fetch=[1])
            LogicalProject(SAL=[$5], EXPR$1=[EXTRACT(FLAG(YEAR), $4)])
              LogicalFilter(condition=[=($cor0.DEPTNO, $7)])
                LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "FILTER_SUB_QUERY_TO_CORRELATE"
LogicalProject(DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], SAL=[CAST($2):INTEGER], DEPTNO0=[CAST($3):INTEGER])
    LogicalJoin(condition=[=($0, $3)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalFilter(condition=[>(10, $0)])
        LogicalProject(SAL=[$0], DEPTNO=[$2])
          LogicalFilter(condition=[<=($3, 1)])
            LogicalProject(SAL=[$5], EXPR$1=[EXTRACT(FLAG(YEAR), $4)], DEPTNO=[$7], rn=[ROW_NUMBER() OVER (PARTITION BY $7 ORDER BY EXTRACT(FLAG(YEAR), $4) NULLS LAST, $5 DESC NULLS FIRST)])
              LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "lateDecorrelate=true, FILTER_SUB_QUERY_TO_CORRELATE"

# testDecorrelateProjectWithFetchOne -------------------------------------------
# RelDecorrelator decorrelates a scalar subquery with LIMIT 1 in a SELECT
# expression.

SELECT dname,
  (SELECT sal FROM emp where dept.deptno = emp.deptno order by sal limit 1) as sal
FROM dept;
+------------+---------+
| DNAME      | SAL     |
+------------+---------+
| ACCOUNTING | 1300.00 |
| OPERATIONS |         |
| RESEARCH   |  800.00 |
| SALES      |  950.00 |
