| 1500.00 | 1500.00 | 1500.00 | 1500.00 | 1500.00 |   1500.00 |  1500.00 |
| 1600.00 | 1600.00 | 1600.00 | 1600.00 | 1600.00 |   1600.00 |  1600.00 |
| 2450.00 | 2450.00 | 2450.00 | 2450.00 | 2450.00 |   2450.00 |  2450.00 |
| 2850.00 | 2850.00 | 2850.00 | 2850.00 | 2850.00 |   2850.00 |  2850.00 |
| 2975.00 | 2975.00 | 2975.00 | 2975.00 | 2975.00 |   2975.00 |  2975.00 |
| 3000.00 | 3000.00 | 3000.00 | 3000.00 | 3000.00 |   3000.00 |  3000.00 |
| 5000.00 | 5000.00 | 5000.00 | 5000.00 | 5000.00 |   5000.00 |  5000.00 |
|  800.00 |  800.00 |  800.00 |  800.00 |  800.00 |    800.00 |   800.00 |
|  950.00 |  950.00 |  950.00 |  950.00 |  950.00 |    950.00 |   950.00 |
