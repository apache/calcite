        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_UNION_AGGREGATE"

# testReduceAggregateFunctionsByGroup ------------------------------------------
# [CALCITE-5000] AGGREGATE_REDUCE_FUNCTIONS simplifies aggregate calls whose
# argument is in the GROUP BY key.

select sal, max(sal) as sal_max, min(sal) as sal_min,
  avg(sal) sal_avg, any_value(sal) as sal_val, first_value(sal) as sal_first,
  last_value(sal) as sal_last
from emp group by sal, deptno;
