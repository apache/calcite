# Tests planner rules related to GROUP BY (Aggregate relational operator).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testAggregateGroupingSetsProjectMerge ---------------------------------------
# Tests that AggregateProjectMergeRule merges a Project into an Aggregate
# that uses grouping sets (ROLLUP).

select x, sum(z), y
from (select deptno as x, empno as y, sal as z, sal * 2 as zz
  from emp)
group by rollup(x, y);
+----+----------+------+
| X  | EXPR$1   | Y    |
+----+----------+------+
| 20 | 10875.00 |      |
|    | 29025.00 |      |
| 10 |  1300.00 | 7934 |
| 10 |  2450.00 | 7782 |
| 10 |  5000.00 | 7839 |
| 10 |  8750.00 |      |
| 20 |  1100.00 | 7876 |
| 20 |  2975.00 | 7566 |
| 20 |  3000.00 | 7788 |
| 20 |  3000.00 | 7902 |
| 20 |   800.00 | 7369 |
| 30 |  1250.00 | 7521 |
| 30 |  1250.00 | 7654 |
| 30 |  1500.00 | 7844 |
| 30 |  1600.00 | 7499 |
| 30 |  2850.00 | 7698 |
| 30 |  9400.00 |      |
| 30 |   950.00 | 7900 |
+----+----------+------+
(18 rows)

!ok
LogicalProject(X=[$0], EXPR$1=[$2], Y=[$1])
  LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], EXPR$1=[SUM($2)])
    LogicalProject(X=[$7], Y=[$0], Z=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(X=[$0], EXPR$1=[$2], Y=[$1])
  LogicalProject(DEPTNO=[$1], EMPNO=[$0], EXPR$1=[$2])
    LogicalAggregate(group=[{0, 7}], groups=[[{0, 7}, {7}, {}]], EXPR$1=[SUM($5)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE"

# testAggregateGroupingSetsToUnionRuleGroupingGrouId ---------------------------
# [CALCITE-7116] AGGREGATE_GROUPING_SETS_TO_UNION converts GROUPING SETS with
# GROUPING() and GROUP_ID() functions.

# Not using !ok: GROUP_ID() may not be supported by HSQLDB.
select deptno, job, sal, sum(comm),
  grouping(deptno) as deptno_flag,
  grouping(job) as job_flag,
  grouping(sal) as sal_flag,
  grouping(deptno, sal) as deptno_sal_flag,
  group_id() as group_id
from emp
group by grouping sets ((deptno, job),(deptno, job, sal),(deptno, sal));
LogicalProject(DEPTNO=[$0], JOB=[$1], SAL=[$2], EXPR$3=[$3], DEPTNO_FLAG=[$4], JOB_FLAG=[$5], SAL_FLAG=[$6], DEPTNO_SAL_FLAG=[$7], GROUP_ID=[0:BIGINT])
  LogicalAggregate(group=[{0, 1, 2}], groups=[[{0, 1, 2}, {0, 1}, {0, 2}]], EXPR$3=[SUM($3)], DEPTNO_FLAG=[GROUPING($0)], JOB_FLAG=[GROUPING($1)], SAL_FLAG=[GROUPING($2)], DEPTNO_SAL_FLAG=[GROUPING($0, $2)])
    LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5], COMM=[$6])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalProject(DEPTNO=[$0], JOB=[$1], SAL=[$2], EXPR$3=[$3], DEPTNO_FLAG=[$4], JOB_FLAG=[$5], SAL_FLAG=[$6], DEPTNO_SAL_FLAG=[$7], GROUP_ID=[0:BIGINT])
  LogicalUnion(all=[true])
    LogicalProject(DEPTNO=[$0], JOB=[$1], SAL=[$2], EXPR$3=[$3], DEPTNO_FLAG=[0:BIGINT], JOB_FLAG=[0:BIGINT], SAL_FLAG=[0:BIGINT], DEPTNO_SAL_FLAG=[0:BIGINT])
      LogicalAggregate(group=[{0, 1, 2}], EXPR$3=[SUM($3)])
        LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5], COMM=[$6])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(DEPTNO=[$0], JOB=[$1], SAL=[null:INTEGER], EXPR$3=[$2], DEPTNO_FLAG=[0:BIGINT], JOB_FLAG=[0:BIGINT], SAL_FLAG=[1:BIGINT], DEPTNO_SAL_FLAG=[1:BIGINT])
      LogicalAggregate(group=[{0, 1}], EXPR$3=[SUM($3)])
        LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5], COMM=[$6])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(DEPTNO=[$0], JOB=[null:VARCHAR(10)], SAL=[$1], EXPR$3=[$2], DEPTNO_FLAG=[0:BIGINT], JOB_FLAG=[1:BIGINT], SAL_FLAG=[0:BIGINT], DEPTNO_SAL_FLAG=[0:BIGINT])
      LogicalAggregate(group=[{0, 2}], EXPR$3=[SUM($3)])
        LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5], COMM=[$6])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_GROUPING_SETS_TO_UNION"

# testAggregateMerge1 ---------------------------------------------------------
# AggregateMergeRule should merge 2 aggregates into a single aggregate.

select deptno c, min(y), max(z) z,
sum(r), sum(m) n, sum(x) sal
from (
  select deptno, ename, sum(sal) x, max(sal) z,
    min(sal) y, count(hiredate) m, count(mgr) r
  from emp
  group by deptno, ename) t
group by deptno;
+----+---------+---------+--------+---+----------+
| C  | EXPR$1  | Z       | EXPR$3 | N | SAL      |
+----+---------+---------+--------+---+----------+
| 10 | 1300.00 | 5000.00 |      2 | 3 |  8750.00 |
| 20 |  800.00 | 3000.00 |      5 | 5 | 10875.00 |
| 30 |  950.00 | 2850.00 |      6 | 6 |  9400.00 |
+----+---------+---------+--------+---+----------+
(3 rows)

!ok
LogicalAggregate(group=[{1}], EXPR$1=[MIN($4)], Z=[MAX($3)], EXPR$3=[SUM($6)], N=[SUM($5)], SAL=[SUM($2)])
  LogicalAggregate(group=[{1, 7}], X=[SUM($5)], Z=[MAX($5)], Y=[MIN($5)], M=[COUNT()], R=[COUNT($3)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{7}], EXPR$1=[MIN($5)], Z=[MAX($5)], EXPR$3=[COUNT($3)], N=[COUNT()], SAL=[SUM($5)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge10 --------------------------------------------------------
# [CALCITE-7162] AggregateMergeRule throws 'type mismatch' AssertionError.

SELECT min(mn), max(mx)
FROM (
    SELECT min(deptno) mn, max(deptno) mx
    FROM dept
    GROUP BY dname);
+--------+--------+
| EXPR$0 | EXPR$1 |
+--------+--------+
|     10 |     40 |
+--------+--------+
(1 row)

!ok
LogicalAggregate(group=[{}], EXPR$0=[MIN($1)], EXPR$1=[MAX($2)])
  LogicalAggregate(group=[{1}], MN=[MIN($0)], MX=[MAX($0)])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{}], EXPR$0=[MIN($0)], EXPR$1=[MAX($0)])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge2 ---------------------------------------------------------
# AggregateMergeRule should merge 2 aggregates into a single aggregate,
# top aggregate is not simple aggregate.

select deptno, empno, sum(x), sum(y)
from (
  select ename, empno, deptno, sum(sal) x, count(mgr) y
  from emp
  group by deptno, ename, empno) t
group by grouping sets(deptno, empno);
+--------+-------+----------+--------+
| DEPTNO | EMPNO | EXPR$2   | EXPR$3 |
+--------+-------+----------+--------+
|     10 |       |  8750.00 |      2 |
|     20 |       | 10875.00 |      5 |
|     30 |       |  9400.00 |      6 |
|        |  7369 |   800.00 |      1 |
|        |  7499 |  1600.00 |      1 |
|        |  7521 |  1250.00 |      1 |
|        |  7566 |  2975.00 |      1 |
|        |  7654 |  1250.00 |      1 |
|        |  7698 |  2850.00 |      1 |
|        |  7782 |  2450.00 |      1 |
|        |  7788 |  3000.00 |      1 |
|        |  7839 |  5000.00 |      0 |
|        |  7844 |  1500.00 |      1 |
|        |  7876 |  1100.00 |      1 |
|        |  7900 |   950.00 |      1 |
|        |  7902 |  3000.00 |      1 |
|        |  7934 |  1300.00 |      1 |
+--------+-------+----------+--------+
(17 rows)

!ok
LogicalProject(DEPTNO=[$1], EMPNO=[$0], EXPR$2=[$2], EXPR$3=[$3])
  LogicalAggregate(group=[{0, 2}], groups=[[{0}, {2}]], EXPR$2=[SUM($3)], EXPR$3=[SUM($4)])
    LogicalAggregate(group=[{0, 1, 7}], X=[SUM($5)], Y=[COUNT($3)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalProject(DEPTNO=[$1], EMPNO=[$0], EXPR$2=[$2], EXPR$3=[$3])
  LogicalAggregate(group=[{0, 7}], groups=[[{0}, {7}]], EXPR$2=[SUM($5)], EXPR$3=[COUNT($3)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge3 ---------------------------------------------------------
# AggregateMergeRule should not merge 2 aggregates into a single aggregate,
# since lower aggregate is not simple aggregate.

select deptno, sum(x)
from (
  select ename, deptno, sum(sal) x
  from emp
  group by cube(deptno, ename)) t
group by deptno;
+--------+----------+
| DEPTNO | EXPR$1   |
+--------+----------+
|     10 | 17500.00 |
|     20 | 21750.00 |
|     30 | 18800.00 |
|        | 58050.00 |
+--------+----------+
(4 rows)

!ok
LogicalAggregate(group=[{1}], EXPR$1=[SUM($2)])
  LogicalAggregate(group=[{1, 7}], groups=[[{1, 7}, {1}, {7}, {}]], X=[SUM($5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{1}], EXPR$1=[SUM($2)])
  LogicalAggregate(group=[{1, 7}], groups=[[{1, 7}, {1}, {7}, {}]], X=[SUM($5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge4 ---------------------------------------------------------
# AggregateMergeRule should not merge 2 aggregates since it contains distinct
# aggregate function.

select deptno, sum(x)
from (
  select ename, deptno, count(distinct sal) x
  from emp
  group by deptno, ename) t
group by deptno;
+--------+--------+
| DEPTNO | EXPR$1 |
+--------+--------+
|     10 |      3 |
|     20 |      5 |
|     30 |      6 |
+--------+--------+
(3 rows)

!ok
LogicalAggregate(group=[{1}], EXPR$1=[SUM($2)])
  LogicalAggregate(group=[{1, 7}], X=[COUNT(DISTINCT $5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{1}], EXPR$1=[SUM($2)])
  LogicalAggregate(group=[{1, 7}], X=[COUNT(DISTINCT $5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge5 ---------------------------------------------------------
# AggregateMergeRule should not merge 2 aggregates since AVG doesn't support
# splitting.

select deptno, avg(x)
from (
  select mgr, deptno, avg(sal) x
  from emp
  group by deptno, mgr) t
group by deptno;
+--------+---------+
| DEPTNO | EXPR$1  |
+--------+---------+
|     10 | 2916.66 |
|     20 | 1968.75 |
|     30 | 2080.00 |
+--------+---------+
(3 rows)

!ok
LogicalAggregate(group=[{1}], EXPR$1=[AVG($2)])
  LogicalAggregate(group=[{3, 7}], X=[AVG($5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{1}], EXPR$1=[AVG($2)])
  LogicalAggregate(group=[{3, 7}], X=[AVG($5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge6 ---------------------------------------------------------
# AggregateMergeRule should not merge 2 aggregates since top agg has no group
# key, and lower agg function is COUNT.

select sum(x)
from (
  select mgr, deptno, count(sal) x
  from emp
  group by deptno, mgr) t;
+--------+
| EXPR$0 |
+--------+
|     14 |
+--------+
(1 row)

!ok
LogicalAggregate(group=[{}], EXPR$0=[SUM($2)])
  LogicalAggregate(group=[{3, 7}], X=[COUNT()])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{}], EXPR$0=[SUM($2)])
  LogicalAggregate(group=[{3, 7}], X=[COUNT()])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge7 ---------------------------------------------------------
# AggregateMergeRule should not merge 2 aggregates since top agg contains empty
# grouping set, and lower agg function is COUNT.

select mgr, deptno, sum(x)
from (
  select mgr, deptno, count(sal) x
  from emp
  group by deptno, mgr) t
group by cube(mgr, deptno);
+------+--------+--------+
| MGR  | DEPTNO | EXPR$2 |
+------+--------+--------+
| 7566 |     20 |      2 |
| 7566 |        |      2 |
| 7698 |     30 |      5 |
| 7698 |        |      5 |
| 7782 |     10 |      1 |
| 7782 |        |      1 |
| 7788 |     20 |      1 |
| 7788 |        |      1 |
| 7839 |     10 |      1 |
| 7839 |     20 |      1 |
| 7839 |     30 |      1 |
| 7839 |        |      3 |
| 7902 |     20 |      1 |
| 7902 |        |      1 |
|      |     10 |      1 |
|      |     10 |      3 |
|      |     20 |      5 |
|      |     30 |      6 |
|      |        |      1 |
|      |        |     14 |
+------+--------+--------+
(20 rows)

!ok
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {1}, {}]], EXPR$2=[SUM($2)])
  LogicalAggregate(group=[{3, 7}], X=[COUNT()])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalProject(MGR=[$1], DEPTNO=[$0], EXPR$2=[$2])
  LogicalProject(DEPTNO=[$1], MGR=[$0], EXPR$2=[$2])
    LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {1}, {}]], EXPR$2=[SUM($2)])
      LogicalAggregate(group=[{3, 7}], X=[COUNT()])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge8 ---------------------------------------------------------
# AggregateMergeRule should merge 2 aggregates since both top and bottom
# aggregates contain empty grouping set and they are mergable.

select sum(x) x, min(y) z
from (
  select sum(sal) x, min(sal) y
  from emp);
+----------+--------+
| X        | Z      |
+----------+--------+
| 29025.00 | 800.00 |
+----------+--------+
(1 row)

!ok
LogicalAggregate(group=[{}], X=[SUM($0)], Z=[MIN($1)])
  LogicalAggregate(group=[{}], X=[SUM($5)], Y=[MIN($5)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{}], X=[SUM($5)], Z=[MIN($5)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateMerge9 ---------------------------------------------------------
# [CALCITE-6557] AggregateMergeRule throws 'type mismatch' AssertionError.

SELECT sum(deptno)
FROM (
    SELECT sum(deptno) AS deptno
    FROM dept
    GROUP BY dname);
+--------+
| EXPR$0 |
+--------+
|    100 |
+--------+
(1 row)

!ok
LogicalAggregate(group=[{}], EXPR$0=[SUM($1)])
  LogicalAggregate(group=[{1}], DEPTNO=[SUM($0)])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"
LogicalAggregate(group=[{}], EXPR$0=[SUM($0)])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_MERGE"

# testAggregateProjectMerge ---------------------------------------------------
# Tests that AggregateProjectMergeRule merges a Project into an Aggregate.

select x, sum(z), y
from (select deptno as x, empno as y, sal as z, sal * 2 as zz
  from emp)
group by x, y;
+----+---------+------+
| X  | EXPR$1  | Y    |
+----+---------+------+
| 10 | 1300.00 | 7934 |
| 10 | 2450.00 | 7782 |
| 10 | 5000.00 | 7839 |
| 20 | 1100.00 | 7876 |
| 20 | 2975.00 | 7566 |
| 20 | 3000.00 | 7788 |
| 20 | 3000.00 | 7902 |
| 20 |  800.00 | 7369 |
| 30 | 1250.00 | 7521 |
| 30 | 1250.00 | 7654 |
| 30 | 1500.00 | 7844 |
| 30 | 1600.00 | 7499 |
| 30 | 2850.00 | 7698 |
| 30 |  950.00 | 7900 |
+----+---------+------+
(14 rows)

!ok
LogicalProject(X=[$0], EXPR$1=[$2], Y=[$1])
  LogicalAggregate(group=[{0, 1}], EXPR$1=[SUM($2)])
    LogicalProject(X=[$7], Y=[$0], Z=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(X=[$0], EXPR$1=[$2], Y=[$1])
  LogicalProject(DEPTNO=[$1], EMPNO=[$0], EXPR$1=[$2])
    LogicalAggregate(group=[{0, 7}], EXPR$1=[SUM($5)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE"

# testAggregateRemove1 --------------------------------------------------------
# AggregateRemoveRule removes a GROUP BY where the grouping keys include a
# unique key (empno), so all aggregate functions are splittable.

select empno, sum(mgr) as s, min(mgr) as i, max(mgr) as x,
  bit_and(distinct mgr) as a, bit_or(mgr) as o, count(distinct mgr) as c,
  grouping(deptno) as g
from emp
group by empno, deptno;
+-------+------+------+------+------+------+---+---+
| EMPNO | S    | I    | X    | A    | O    | C | G |
+-------+------+------+------+------+------+---+---+
|  7369 | 7902 | 7902 | 7902 | 7902 | 7902 | 1 | 0 |
|  7499 | 7698 | 7698 | 7698 | 7698 | 7698 | 1 | 0 |
|  7521 | 7698 | 7698 | 7698 | 7698 | 7698 | 1 | 0 |
|  7566 | 7839 | 7839 | 7839 | 7839 | 7839 | 1 | 0 |
|  7654 | 7698 | 7698 | 7698 | 7698 | 7698 | 1 | 0 |
|  7698 | 7839 | 7839 | 7839 | 7839 | 7839 | 1 | 0 |
|  7782 | 7839 | 7839 | 7839 | 7839 | 7839 | 1 | 0 |
|  7788 | 7566 | 7566 | 7566 | 7566 | 7566 | 1 | 0 |
|  7839 |      |      |      |      |      | 0 | 0 |
|  7844 | 7698 | 7698 | 7698 | 7698 | 7698 | 1 | 0 |
|  7876 | 7788 | 7788 | 7788 | 7788 | 7788 | 1 | 0 |
|  7900 | 7698 | 7698 | 7698 | 7698 | 7698 | 1 | 0 |
|  7902 | 7566 | 7566 | 7566 | 7566 | 7566 | 1 | 0 |
|  7934 | 7782 | 7782 | 7782 | 7782 | 7782 | 1 | 0 |
+-------+------+------+------+------+------+---+---+
(14 rows)

!ok
LogicalProject(EMPNO=[$0], S=[$2], I=[$3], X=[$4], A=[$5], O=[$6], C=[$7], G=[$8])
  LogicalAggregate(group=[{0, 1}], S=[SUM($2)], I=[MIN($2)], X=[MAX($2)], A=[BIT_AND($2)], O=[BIT_OR($2)], C=[COUNT(DISTINCT $2)], G=[GROUPING($1)])
    LogicalProject(EMPNO=[$0], DEPTNO=[$7], MGR=[$3])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(EMPNO=[$0], S=[$3], I=[$3], X=[$3], A=[$3], O=[$3], C=[CASE(IS NOT NULL($3), 1:BIGINT, 0:BIGINT)], G=[0:BIGINT])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_REMOVE, PROJECT_MERGE"

# testAggregateRemove2 --------------------------------------------------------
# AggregateRemoveRule removes a GROUP BY with all-unique keys (DISTINCT on empno,
# deptno where empno is unique), so the Aggregate is eliminated.

select distinct empno, deptno from emp;
+-------+--------+
| EMPNO | DEPTNO |
+-------+--------+
|  7369 |     20 |
|  7499 |     30 |
|  7521 |     30 |
|  7566 |     20 |
|  7654 |     30 |
|  7698 |     30 |
|  7782 |     10 |
|  7788 |     20 |
|  7839 |     10 |
|  7844 |     30 |
|  7876 |     20 |
|  7900 |     30 |
|  7902 |     20 |
|  7934 |     10 |
+-------+--------+
(14 rows)

!ok

LogicalAggregate(group=[{0, 1}])
  LogicalProject(EMPNO=[$0], DEPTNO=[$7])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "aggregateUnique=true"
LogicalProject(EMPNO=[$0], DEPTNO=[$7])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "aggregateUnique=true, AGGREGATE_REMOVE, PROJECT_MERGE"

# testAggregateRemove3 --------------------------------------------------------
# AggregateRemoveRule removes a GROUP BY where the grouping keys include a
# unique key (empno); COUNT(mgr) is transformed to a CASE because mgr is
# nullable.

select empno, count(mgr)
from emp group by empno, deptno;
+-------+--------+
| EMPNO | EXPR$1 |
+-------+--------+
|  7369 |      1 |
|  7499 |      1 |
|  7521 |      1 |
|  7566 |      1 |
|  7654 |      1 |
|  7698 |      1 |
|  7782 |      1 |
|  7788 |      1 |
|  7839 |      0 |
|  7844 |      1 |
|  7876 |      1 |
|  7900 |      1 |
|  7902 |      1 |
|  7934 |      1 |
