(12 rows)

!ok
LogicalProject(SAL=[$0], SAL_MAX=[$2], SAL_MIN=[$3], SAL_AVG=[$4], SAL_VAL=[$5], SAL_FIRST=[$6], SAL_LAST=[$7])
  LogicalAggregate(group=[{0, 1}], SAL_MAX=[MAX($0)], SAL_MIN=[MIN($0)], SAL_AVG=[AVG($0)], SAL_VAL=[ANY_VALUE($0)], SAL_FIRST=[FIRST_VALUE($0)], SAL_LAST=[LAST_VALUE($0)])
    LogicalProject(SAL=[$5], DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalProject(SAL=[$0], SAL_MAX=[$0], SAL_MIN=[$0], SAL_AVG=[$0], SAL_VAL=[$0], SAL_FIRST=[$0], SAL_LAST=[$0])
  LogicalAggregate(group=[{0, 1}])
    LogicalProject(SAL=[$5], DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_REDUCE_FUNCTIONS, PROJECT_MERGE"

# testRemoveDistinctOnAgg ------------------------------------------------------
# AGGREGATE_REMOVE removes the aggregate when the group key contains a primary
# key, since each group has exactly one row. PROJECT_MERGE then merges projects.

select empno, sum(distinct mgr) as s, min(mgr) as i,
    min(distinct mgr) as id, max(distinct mgr) as xd,
    bit_and(distinct mgr) as ad, bit_or(mgr) as o, count(distinct mgr) as cd
from emp
group by empno, deptno;
+-------+------+------+------+------+------+------+----+
| EMPNO | S    | I    | ID   | XD   | AD   | O    | CD |
+-------+------+------+------+------+------+------+----+
|  7369 | 7902 | 7902 | 7902 | 7902 | 7902 | 7902 |  1 |
|  7499 | 7698 | 7698 | 7698 | 7698 | 7698 | 7698 |  1 |
|  7521 | 7698 | 7698 | 7698 | 7698 | 7698 | 7698 |  1 |
|  7566 | 7839 | 7839 | 7839 | 7839 | 7839 | 7839 |  1 |
|  7654 | 7698 | 7698 | 7698 | 7698 | 7698 | 7698 |  1 |
|  7698 | 7839 | 7839 | 7839 | 7839 | 7839 | 7839 |  1 |
|  7782 | 7839 | 7839 | 7839 | 7839 | 7839 | 7839 |  1 |
|  7788 | 7566 | 7566 | 7566 | 7566 | 7566 | 7566 |  1 |
|  7839 |      |      |      |      |      |      |  0 |
|  7844 | 7698 | 7698 | 7698 | 7698 | 7698 | 7698 |  1 |
|  7876 | 7788 | 7788 | 7788 | 7788 | 7788 | 7788 |  1 |
|  7900 | 7698 | 7698 | 7698 | 7698 | 7698 | 7698 |  1 |
|  7902 | 7566 | 7566 | 7566 | 7566 | 7566 | 7566 |  1 |
|  7934 | 7782 | 7782 | 7782 | 7782 | 7782 | 7782 |  1 |
+-------+------+------+------+------+------+------+----+
(14 rows)

!ok
LogicalProject(EMPNO=[$0], S=[$2], I=[$3], ID=[$3], XD=[$4], AD=[$5], O=[$6], CD=[$7])
  LogicalAggregate(group=[{0, 1}], S=[SUM(DISTINCT $2)], I=[MIN($2)], XD=[MAX($2)], AD=[BIT_AND($2)], O=[BIT_OR($2)], CD=[COUNT(DISTINCT $2)])
    LogicalProject(EMPNO=[$0], DEPTNO=[$7], MGR=[$3])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(EMPNO=[$0], S=[$3], I=[$3], ID=[$3], XD=[$3], AD=[$3], O=[$3], CD=[CASE(IS NOT NULL($3), 1:BIGINT, 0:BIGINT)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_REMOVE, PROJECT_MERGE"

