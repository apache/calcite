# testAggregateRemove7 --------------------------------------------------------
# The top Aggregate is removed because the filter "deptno=100" makes the
# input already distinct by "mgr".

select mgr, sum(sum_sal)
from (
  select mgr, deptno, sum(sal) sum_sal
  from emp
  group by mgr, deptno)
where deptno=100
group by mgr;
+-----+--------+
| MGR | EXPR$1 |
+-----+--------+
+-----+--------+
(0 rows)

!ok
LogicalAggregate(group=[{0}], EXPR$1=[SUM($1)])
  LogicalProject(MGR=[$0], SUM_SAL=[$2])
    LogicalFilter(condition=[=($1, 100)])
      LogicalAggregate(group=[{0, 1}], SUM_SAL=[SUM($2)])
        LogicalProject(MGR=[$3], DEPTNO=[$7], SAL=[$5])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(MGR=[$0], SUM_SAL=[$2])
  LogicalFilter(condition=[=($1, 100)])
    LogicalAggregate(group=[{0, 1}], SUM_SAL=[SUM($2)])
      LogicalProject(MGR=[$3], DEPTNO=[$7], SAL=[$5])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_REMOVE, PROJECT_MERGE"

# testAggregateToSemiJoinRule --------------------------------------------------
# AggregateToSemiJoinRule converts an Aggregate over a Join (where the right
# input is also an Aggregate) to a SemiJoin.
# [CALCITE-5740]

select distinct emp.deptno
from emp
join (select distinct mgr from emp) d on emp.deptno = d.mgr;
+--------+
| DEPTNO |
+--------+
+--------+
(0 rows)

!ok
LogicalAggregate(group=[{0}])
  LogicalProject(DEPTNO=[$7])
    LogicalJoin(condition=[=($7, $9)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalAggregate(group=[{0}])
        LogicalProject(MGR=[$3])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalAggregate(group=[{7}])
  LogicalJoin(condition=[=($7, $9)], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{3}])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE"
LogicalAggregate(group=[{7}])
  LogicalJoin(condition=[=($7, $12)], joinType=[semi])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_TO_SEMI_JOIN"

# testAggregateValuesRuleWithAggregation ---------------------------------------
# AggregateValuesRule does not apply because the aggregate has an aggregate
# function (COUNT), not just group keys.

select v1, v2, count(*) as v1_count
from (values (1, 'a'), (2, 'b'), (1, 'a'), (1, 'b')) as t(v1, v2)
group by v1, v2;
+----+----+----------+
| V1 | V2 | V1_COUNT |
+----+----+----------+
|  1 | a  |        2 |
|  1 | b  |        1 |
|  2 | b  |        1 |
+----+----+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0, 1}], V1_COUNT=[COUNT()])
  LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE"
LogicalAggregate(group=[{0, 1}], V1_COUNT=[COUNT()])
  LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_VALUES"

# testAggregateValuesRuleWithDifferentRowTypes ---------------------------------
# AggregateValuesRule does not apply because the aggregate's row type (just v1)
# differs from the Values row type (v1, v2).

select distinct v1
from (values (1, 'a'), (2, 'b'), (1, 'a'), (1, 'b')) as t(v1, v2);
+----+
| V1 |
+----+
|  1 |
|  2 |
+----+
(2 rows)

!ok
LogicalAggregate(group=[{0}])
  LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE"
LogicalAggregate(group=[{0}])
  LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_VALUES"

# testAggregateValuesRuleWithRepeatingValues -----------------------------------
# AggregateValuesRule deduplicates Values when Aggregate is directly over
# Values with a single column and repeating/null values.

select distinct v
from (values (1), (1), (3),
    (cast(null as integer)),
    (cast(null as integer))) as t(v);
+---+
| V |
+---+
| 1 |
| 3 |
|   |
+---+
(3 rows)

!ok
LogicalAggregate(group=[{0}])
  LogicalValues(tuples=[[{ 1 }, { 1 }, { 3 }, { null }, { null }]])
!sub-plan "AGGREGATE_PROJECT_MERGE"
LogicalValues(tuples=[[{ 1 }, { 3 }, { null }]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_VALUES"

# testAggregateValuesRuleWithSameRowType ---------------------------------------
# AggregateValuesRule deduplicates Values when Aggregate is directly over
# Values and the row type matches (group by all columns = DISTINCT).

select distinct v1, v2
from (values (1, 'a'), (2, 'b'), (1, 'a'), (1, 'b')) as t(v1, v2);
+----+----+
| V1 | V2 |
+----+----+
|  1 | a  |
|  1 | b  |
|  2 | b  |
+----+----+
(3 rows)

!ok
LogicalAggregate(group=[{0, 1}])
  LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE"
LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'b' }]])
!sub-plan "AGGREGATE_PROJECT_MERGE, AGGREGATE_VALUES"

# testDigestOfApproximateDistinctAggregateCall ---------------------------------
# AGGREGATE_PROJECT_MERGE merges a Project into an Aggregate, treating
# COUNT(DISTINCT) and APPROX_COUNT_DISTINCT as different aggregate calls.
# Not using !ok: approx_count_distinct is not supported in the scott HSQLDB.

select *
from (
  select deptno, count(distinct empno) from emp group by deptno
  union all
  select deptno, approx_count_distinct(empno) from emp group by deptno);
+--------+--------+
| DEPTNO | EXPR$1 |
+--------+--------+
|     10 |      3 |
|     10 |      3 |
|     20 |      5 |
|     20 |      5 |
|     30 |      6 |
|     30 |      6 |
+--------+--------+
(6 rows)

!ok
LogicalProject(DEPTNO=[$0], EXPR$1=[$1])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{0}], EXPR$1=[COUNT(DISTINCT $1)])
      LogicalProject(DEPTNO=[$7], EMPNO=[$0])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0}], EXPR$1=[COUNT(APPROXIMATE DISTINCT $1)])
      LogicalProject(DEPTNO=[$7], EMPNO=[$0])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan ""
LogicalProject(DEPTNO=[$0], EXPR$1=[$1])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{7}], EXPR$1=[COUNT(DISTINCT $0)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{7}], EXPR$1=[COUNT(APPROXIMATE DISTINCT $0)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "AGGREGATE_PROJECT_MERGE"

