|  7844 | TURNER | SALESMAN  | 7698 | 1981-09-08 | 1500.00 |    0.00 |     30 |   7844 | TURNER | SALESMAN  | 7698 | 1981-09-08 | 1500.00 |    0.00 |      30 |
|  7876 | ADAMS  | CLERK     | 7788 | 1987-05-23 | 1100.00 |         |     20 |   7876 | ADAMS  | CLERK     | 7788 | 1987-05-23 | 1100.00 |         |      20 |
|  7900 | JAMES  | CLERK     | 7698 | 1981-12-03 |  950.00 |         |     30 |   7900 | JAMES  | CLERK     | 7698 | 1981-12-03 |  950.00 |         |      30 |
|  7902 | FORD   | ANALYST   | 7566 | 1981-12-03 | 3000.00 |         |     20 |   7902 | FORD   | ANALYST   | 7566 | 1981-12-03 | 3000.00 |         |      20 |
|  7934 | MILLER | CLERK     | 7782 | 1982-01-23 | 1300.00 |         |     10 |   7934 | MILLER | CLERK     | 7782 | 1982-01-23 | 1300.00 |         |      10 |
+-------+--------+-----------+------+------------+---------+---------+--------+--------+--------+-----------+------+------------+---------+---------+---------+
(14 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], EMPNO0=[$9], ENAME0=[$10], JOB0=[$11], MGR0=[$12], HIREDATE0=[$13], SAL0=[$14], COMM0=[$15], DEPTNO0=[$16], SLACKER0=[$17])
  LogicalFilter(condition=[OR(AND(IS NULL($1), IS NULL($10)), IS TRUE(=($1, $10)))])
    LogicalJoin(condition=[=($7, $16)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], EMPNO0=[$9], ENAME0=[$10], JOB0=[$11], MGR0=[$12], HIREDATE0=[$13], SAL0=[$14], COMM0=[$15], DEPTNO0=[$16], SLACKER0=[$17])
  LogicalJoin(condition=[AND(=($7, $16), IS NOT DISTINCT FROM($1, $10))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN"

# testPushJoinCondDownToProject ------------------------------------------------
# FILTER_INTO_JOIN, JOIN_PUSH_EXPRESSIONS push conditions into projects below a join.

select d.deptno, e.deptno
from dept d, emp e
where d.deptno + 10 = e.deptno * 2;
+--------+--------+
| DEPTNO | DEPTNO |
+--------+--------+
|     10 |     10 |
|     10 |     10 |
|     10 |     10 |
|     30 |     20 |
|     30 |     20 |
|     30 |     20 |
|     30 |     20 |
|     30 |     20 |
+--------+--------+
(8 rows)

!ok
LogicalProject(DEPTNO=[$0], DEPTNO0=[$9])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], EMPNO=[$3], ENAME=[$4], JOB=[$5], MGR=[$6], HIREDATE=[$7], SAL=[$8], COMM=[$9], DEPTNO0=[$10], SLACKER=[$11])
    LogicalJoin(condition=[=($2, $12)], joinType=[inner])
      LogicalProject(DEPTNO=[$0], DNAME=[$1], $f2=[+($0, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], $f9=[*($7, 2)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN, JOIN_PUSH_EXPRESSIONS"

# testPushJoinConditionWithNonDeterministic ------------------------------------
# FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, and JOIN_CONDITION_PUSH do not
# push a join condition containing RAND() (non-deterministic) out of the join.
# [CALCITE-7373]

select *
from (
  select *
  from dept
  inner join emp on dept.deptno = emp.deptno and emp.mgr <= rand()) r;
# Not using !ok: RAND() gives non-deterministic results
LogicalProject(DEPTNO=[$0], DNAME=[$1], EMPNO=[$2], ENAME=[$3], JOB=[$4], MGR=[$5], HIREDATE=[$6], SAL=[$7], COMM=[$8], DEPTNO0=[$9], SLACKER=[$10])
  LogicalJoin(condition=[AND(=($0, $9), <=(CAST($5):DOUBLE, RAND()))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], DNAME=[$1], EMPNO=[$2], ENAME=[$3], JOB=[$4], MGR=[$5], HIREDATE=[$6], SAL=[$7], COMM=[$8], DEPTNO0=[$9], SLACKER=[$10])
  LogicalJoin(condition=[AND(=($0, $9), <=(CAST($5):DOUBLE, RAND()))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, JOIN_CONDITION_PUSH"

# testRightOuterJoinSimplificationToInner --------------------------------------
# FILTER_INTO_JOIN converts a right outer join to inner when the WHERE clause
# has a null-rejecting predicate on the left side.

select 1 as uno
from dept d
right outer join emp e on d.deptno = e.deptno
where d.dname = 'SALES';
+-----+
| UNO |
+-----+
|   1 |
|   1 |
|   1 |
|   1 |
|   1 |
|   1 |
+-----+
(6 rows)

!ok
LogicalProject(UNO=[1])
  LogicalFilter(condition=[=($1, 'SALES')])
    LogicalJoin(condition=[=($0, $9)], joinType=[right])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(UNO=[1])
  LogicalProject(DEPTNO=[CAST($0):INTEGER], DNAME=[CAST($1):VARCHAR(10)], EMPNO=[$2], ENAME=[$3], JOB=[$4], MGR=[$5], HIREDATE=[$6], SAL=[$7], COMM=[$8], DEPTNO0=[$9], SLACKER=[$10])
    LogicalJoin(condition=[=($0, $9)], joinType=[inner])
      LogicalFilter(condition=[=($1, 'SALES')])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN"

# testStrengthenJoinType -------------------------------------------------------
# FILTER_INTO_JOIN strengthens a left outer join to inner join when the WHERE
# clause has a null-rejecting predicate on the right side.

select dept.*, emp.ename
from dept left join emp on dept.deptno = emp.deptno
where emp.deptno is not null and emp.sal > 100;
+--------+------------+----------+--------+
| DEPTNO | DNAME      | LOC      | ENAME  |
+--------+------------+----------+--------+
|     10 | ACCOUNTING | NEW YORK | CLARK  |
|     10 | ACCOUNTING | NEW YORK | KING   |
|     10 | ACCOUNTING | NEW YORK | MILLER |
|     20 | RESEARCH   | DALLAS   | ADAMS  |
|     20 | RESEARCH   | DALLAS   | FORD   |
|     20 | RESEARCH   | DALLAS   | JONES  |
|     20 | RESEARCH   | DALLAS   | SCOTT  |
|     20 | RESEARCH   | DALLAS   | SMITH  |
|     30 | SALES      | CHICAGO  | ALLEN  |
|     30 | SALES      | CHICAGO  | BLAKE  |
|     30 | SALES      | CHICAGO  | JAMES  |
|     30 | SALES      | CHICAGO  | MARTIN |
|     30 | SALES      | CHICAGO  | TURNER |
|     30 | SALES      | CHICAGO  | WARD   |
+--------+------------+----------+--------+
(14 rows)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1], ENAME=[$2])
  LogicalFilter(condition=[AND(>($3, 100), IS NOT NULL($4))])
    LogicalJoin(condition=[=($0, $4)], joinType=[left])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalProject(ENAME=[$1], SAL=[$5], DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "trim=true, PROJECT_MERGE, FILTER_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$0], DNAME=[$1], ENAME=[$2])
  LogicalProject(DEPTNO=[$0], DNAME=[$1], ENAME=[CAST($2):VARCHAR(20)], SAL=[CAST($3):INTEGER], DEPTNO0=[CAST($4):INTEGER])
    LogicalJoin(condition=[=($0, $4)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalFilter(condition=[>($1, 100)])
        LogicalProject(ENAME=[$1], SAL=[$5], DEPTNO=[$7])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "trim=true, PROJECT_MERGE, FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN"

# End filter-into-join.iq
