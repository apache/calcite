    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_CONDITION_PUSH, PROJECT_MERGE, FILTER_PROJECT_TRANSPOSE"

# testJoinConditionPushdown3 ---------------------------------------------------
# JOIN_CONDITION_PUSH does not push conditions from a FULL JOIN (unchanged).
# [CALCITE-5073]

select *
from emp e full join dept d
on e.deptno = d.deptno and e.empno = d.deptno;
# Not using !ok: FULL JOIN with self-referential condition may give empty result
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalJoin(condition=[AND(=($7, $9), =($0, $9))], joinType=[full])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalJoin(condition=[AND(=($7, $9), =($0, $9))], joinType=[full])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_CONDITION_PUSH, PROJECT_MERGE, FILTER_PROJECT_TRANSPOSE"

