(0 rows)

!ok
LogicalProject(MGR=[$3])
  LogicalFilter(condition=[=($3, 10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(MGR=[CAST(10):INTEGER])
  LogicalFilter(condition=[=($3, 10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS, JOIN_REDUCE_EXPRESSIONS"

# testReduceConstantsWindow ----------------------------------------------------
# WINDOW_REDUCE_EXPRESSIONS reduces sum(100) to a constant in a window.

select col1, col2, col3
from (
  select empno,
    sum(100) over (partition by deptno, sal order by sal) as col1,
    sum(100) over (partition by sal order by deptno) as col2,
    sum(sal) over (partition by deptno order by sal) as col3
  from emp
  where sal = 5000);
+------+------+---------+
| COL1 | COL2 | COL3    |
+------+------+---------+
|  100 |  100 | 5000.00 |
+------+------+---------+
(1 row)

!ok
LogicalProject(COL1=[SUM(100) OVER (PARTITION BY $7, $5 ORDER BY $5)], COL2=[SUM(100) OVER (PARTITION BY $5 ORDER BY $7)], COL3=[SUM($5) OVER (PARTITION BY $7 ORDER BY $5)])
  LogicalFilter(condition=[=($5, 5000)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(COL1=[$2], COL2=[$3], COL3=[$4])
  LogicalWindow(window#0=[window(partition {1} range between UNBOUNDED PRECEDING and CURRENT ROW aggs [SUM($2)])], window#1=[window(order by [1] aggs [SUM($2)])], window#2=[window(partition {1} range between UNBOUNDED PRECEDING and CURRENT ROW aggs [SUM(5000)])], constants=[[100]])
    LogicalProject(SAL=[$5], DEPTNO=[$7])
      LogicalFilter(condition=[=($5, 5000)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_MERGE, PROJECT_WINDOW_TRANSPOSE, WINDOW_REDUCE_EXPRESSIONS"

# testReduceConstantsWithMultipleOrderByWindow ---------------------------------
# WINDOW_REDUCE_EXPRESSIONS reduces sum(100) with multiple ORDER BY keys.

select col1, col2
from (
  select empno,
    sum(100) over (order by deptno, empno
      range between current row and unbounded following) as col1,
    sum(100) over (partition by sal, deptno order by deptno, empno
      range between unbounded preceding and unbounded following) as col2
  from emp
  where sal = 5000);
+------+------+
| COL1 | COL2 |
+------+------+
|  100 |  100 |
+------+------+
(1 row)

!ok
LogicalProject(COL1=[SUM(100) OVER (ORDER BY $7, $0 RANGE BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING)], COL2=[SUM(100) OVER (PARTITION BY $5, $7 ORDER BY $7, $0 RANGE BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING)])
  LogicalFilter(condition=[=($5, 5000)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(COL1=[$3], COL2=[$4])
  LogicalWindow(window#0=[window(order by [2, 0] range between CURRENT ROW and UNBOUNDED FOLLOWING aggs [SUM($3)])], window#1=[window(partition {2} order by [2, 0] range between UNBOUNDED PRECEDING and UNBOUNDED FOLLOWING aggs [SUM($3)])], constants=[[100]])
    LogicalProject(EMPNO=[$0], SAL=[$5], DEPTNO=[$7])
      LogicalFilter(condition=[=($5, 5000)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_MERGE, PROJECT_WINDOW_TRANSPOSE, WINDOW_REDUCE_EXPRESSIONS"

# testReduceConstantsWithRow ---------------------------------------------------
# [CALCITE-7140] Improve constant reduction of expressions containing SqlRowOperator.

SELECT 1+1, ARRAY[1+1, 2+2], ROW('a', 3+3), MAP['a'||'b', 6+6],
ROW(1+2, ARRAY[1+2, 2+3], ROW('a', 3+4), MAP['ab'||'cd', 6+7]),
ARRAY[2*3, 2, 1],
ARRAY[ROW(4*2, 'a'), ROW(4+4, 'b')],
ARRAY[MAP['abc'||'def', 8+8], MAP['ghi'||'jkl', 9+9]],
ARRAY[ROW(1+2, ARRAY[1+1, 2+2], ROW('a', 3+3), MAP['x'||'y', 8+8])],
CARDINALITY(ARRAY[2*3, 2*2, 1*4]),
CARDINALITY(ARRAY[ROW(4*3, 'm'), ROW(4+6, 'b')]),
CARDINALITY(ARRAY[MAP['ac'||'bd', 1+8], MAP['gi'||'jl', 1+9]]),
CARDINALITY(ARRAY[ROW(1+7, ARRAY[1+4, 4+2],
    ROW('t', 5+5), MAP['y'||'z', 9+9])]);
+--------+--------+--------+---------+--------------------------------+-----------+------------------+----------------------------+--------------------------------+--------+---------+---------+---------+
| EXPR$0 | EXPR$1 | EXPR$2 | EXPR$3  | EXPR$4                         | EXPR$5    | EXPR$6           | EXPR$7                     | EXPR$8                         | EXPR$9 | EXPR$10 | EXPR$11 | EXPR$12 |
+--------+--------+--------+---------+--------------------------------+-----------+------------------+----------------------------+--------------------------------+--------+---------+---------+---------+
|      2 | [2, 4] | {a, 6} | {ab=12} | {3, [3, 5], {a, 7}, {abcd=13}} | [6, 2, 1] | [{8, a}, {8, b}] | [{abcdef=16}, {ghijkl=18}] | [{3, [2, 4], {a, 6}, {xy=16}}] |      3 |       2 |       2 |       1 |
+--------+--------+--------+---------+--------------------------------+-----------+------------------+----------------------------+--------------------------------+--------+---------+---------+---------+
(1 row)

!ok
LogicalProject(EXPR$0=[+(1, 1)], EXPR$1=[ARRAY(+(1, 1), +(2, 2))], EXPR$2=[ROW('a', +(3, 3))], EXPR$3=[MAP(||('a', 'b'), +(6, 6))], EXPR$4=[ROW(+(1, 2), ARRAY(+(1, 2), +(2, 3)), ROW('a', +(3, 4)), MAP(||('ab', 'cd'), +(6, 7)))], EXPR$5=[ARRAY(*(2, 3), 2, 1)], EXPR$6=[ARRAY(ROW(*(4, 2), 'a'), ROW(+(4, 4), 'b'))], EXPR$7=[ARRAY(MAP(||('abc', 'def'), +(8, 8)), MAP(||('ghi', 'jkl'), +(9, 9)))], EXPR$8=[ARRAY(ROW(+(1, 2), ARRAY(+(1, 1), +(2, 2)), ROW('a', +(3, 3)), MAP(||('x', 'y'), +(8, 8))))], EXPR$9=[CARDINALITY(ARRAY(*(2, 3), *(2, 2), 4))], EXPR$10=[CARDINALITY(ARRAY(ROW(*(4, 3), 'm'), ROW(+(4, 6), 'b')))], EXPR$11=[CARDINALITY(ARRAY(MAP(||('ac', 'bd'), +(1, 8)), MAP(||('gi', 'jl'), +(1, 9))))], EXPR$12=[CARDINALITY(ARRAY(ROW(+(1, 7), ARRAY(+(1, 4), +(4, 2)), ROW('t', +(5, 5)), MAP(||('y', 'z'), +(9, 9)))))])
  LogicalValues(tuples=[[{ 0 }]])
!transform ""
LogicalProject(EXPR$0=[2], EXPR$1=[ARRAY(2, 4)], EXPR$2=[ROW('a', 6)], EXPR$3=[MAP('ab', 12)], EXPR$4=[ROW(3, ARRAY(3, 5), ROW('a', 7), MAP('abcd', 13))], EXPR$5=[ARRAY(6, 2, 1)], EXPR$6=[ARRAY(ROW(8, 'a'), ROW(8, 'b'))], EXPR$7=[ARRAY(MAP('abcdef', 16), MAP('ghijkl', 18))], EXPR$8=[ARRAY(ROW(3, ARRAY(2, 4), ROW('a', 6), MAP('xy', 16)))], EXPR$9=[3], EXPR$10=[2], EXPR$11=[2], EXPR$12=[1])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testReduceDecimal ------------------------------------------------------------
# FILTER_TO_CALC, CALC_REDUCE_DECIMALS reduce a CAST to DECIMAL.
# [CALCITE-3319]

select ename
from emp
where sal > cast (100.0 as decimal(4, 1));
+--------+
| ENAME  |
+--------+
| ADAMS  |
| ALLEN  |
| BLAKE  |
| CLARK  |
| FORD   |
| JAMES  |
| JONES  |
| KING   |
| MARTIN |
| MILLER |
| SCOTT  |
| SMITH  |
| TURNER |
| WARD   |
+--------+
(14 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalCalc(expr#0..8=[{inputs}], expr#9=[10:BIGINT], expr#10=[*($t5, $t9)], expr#11=[Reinterpret($t10)], expr#12=[Reinterpret($t11)], expr#13=[100.0:DECIMAL(11, 1)], expr#14=[Reinterpret($t13)], expr#15=[>($t12, $t14)], proj#0..8=[{exprs}], $condition=[$t15])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_TO_CALC, CALC_REDUCE_DECIMALS"

# testReduceExpressionsNot -----------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS does not reduce NOT(col1) when col1 is a boolean
# from a VALUES clause (checkUnchanged).

select *
from (values (false),(true)) as q (col1)
where not(col1);
+-------+
| COL1  |
+-------+
| false |
+-------+
(1 row)

!ok
LogicalProject(COL1=[$0])
  LogicalFilter(condition=[NOT($0)])
    LogicalValues(tuples=[[{ false }, { true }]])
!transform ""
LogicalProject(COL1=[$0])
  LogicalFilter(condition=[NOT($0)])
    LogicalValues(tuples=[[{ false }, { true }]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testReduceNestedCaseWhen -----------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS simplifies a nested CASE when condition.

select sal
from emp
where case when (sal = 1000) then
(case when sal = 1000 then null else 1 end is null) else
(case when sal = 2000 then null else 1 end is null) end is true;
+-----+
| SAL |
+-----+
+-----+
(0 rows)

!ok
LogicalProject(SAL=[$5])
  LogicalFilter(condition=[IS TRUE(CASE(=($5, 1000), IS NULL(CASE(=($5, 1000), null:INTEGER, 1)), IS NULL(CASE(=($5, 2000), null:INTEGER, 1))))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(SAL=[$5])
  LogicalFilter(condition=[SEARCH($5, Sarg[1000, 2000])])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testReduceNot ----------------------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS does not simplify NOT of a nullable CASE (checkUnchanged).

select *
from (
    select (case when sal > 1000 then null else false end) as caseCol
    from emp)
where NOT(caseCol);
+---------+
| CASECOL |
+---------+
| false   |
| false   |
+---------+
(2 rows)

!ok
LogicalProject(CASECOL=[$0])
  LogicalFilter(condition=[NOT($0)])
    LogicalProject(CASECOL=[AND(>($5, 1000), null)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(CASECOL=[$0])
  LogicalFilter(condition=[NOT($0)])
    LogicalProject(CASECOL=[AND(>($5, 1000), null)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testReduceNullableCase -------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS does not simplify CASE WHEN 1=2 when the THEN
# branch contains a scalar subquery (expand=true, checkUnchanged).

SELECT CASE WHEN 1=2
       THEN cast((values(1)) as integer)
       ELSE 2 end AS x
FROM (VALUES(1));
+---+
| X |
+---+
| 2 |
+---+
(1 row)

!ok
LogicalProject(X=[CAST(2):INTEGER])
  LogicalJoin(condition=[true], joinType=[left])
    LogicalValues(tuples=[[{ 1 }]])
    LogicalValues(tuples=[[{ 1 }]])
!transform "Sql2Rel(expand=true), PROJECT_REDUCE_EXPRESSIONS"

# testReduceNullableCase2 ------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS does not simplify CASE WHEN 1=2 when already
# reduced to null during conversion (expand=true, checkUnchanged).

SELECT deptno, ename,
  CASE WHEN 1=2 THEN substring(ename, 1, cast(2 as int)) ELSE NULL end AS x
FROM emp
GROUP BY deptno, ename,
  case when 1=2 then substring(ename,1, cast(2 as int)) else null end;
+--------+--------+---+
| DEPTNO | ENAME  | X |
+--------+--------+---+
|     10 | CLARK  |   |
|     10 | KING   |   |
|     10 | MILLER |   |
|     20 | ADAMS  |   |
|     20 | FORD   |   |
|     20 | JONES  |   |
|     20 | SCOTT  |   |
|     20 | SMITH  |   |
|     30 | ALLEN  |   |
|     30 | BLAKE  |   |
|     30 | JAMES  |   |
|     30 | MARTIN |   |
|     30 | TURNER |   |
|     30 | WARD   |   |
+--------+--------+---+
(14 rows)

!ok
LogicalAggregate(group=[{0, 1, 2}])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], X=[null:VARCHAR(20)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true), PROJECT_REDUCE_EXPRESSIONS"

# testReduceNullableToNotNull --------------------------------------------------
# [CALCITE-902] PROJECT_REDUCE_EXPRESSIONS reduces a nullable CASE expression
# whose condition is always true to a NOT NULL literal.

select empno + case when 'a' = 'a' then 1 else null end as newcol
from emp;
+--------+
| NEWCOL |
+--------+
|   7370 |
|   7500 |
|   7522 |
|   7567 |
|   7655 |
|   7699 |
|   7783 |
|   7789 |
|   7840 |
|   7845 |
|   7877 |
|   7901 |
|   7903 |
|   7935 |
+--------+
(14 rows)

!ok
LogicalProject(NEWCOL=[+($0, CASE(=('a', 'a'), 1, null:INTEGER))])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "RelBuilder(simplify=false)"
LogicalProject(NEWCOL=[+($0, 1)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "RelBuilder(simplify=false), PROJECT_REDUCE_EXPRESSIONS"

# testReduceOrCaseWhen ---------------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS should reduce OR(IS NULL(CASE...), IS NULL(CASE...))
# to SEARCH(sal, Sarg[1000, 2000]).

select sal
from emp
where case when sal = 1000 then null else 1 end is null
OR case when sal = 2000 then null else 1 end is null;
+-----+
| SAL |
+-----+
+-----+
(0 rows)

!ok
LogicalProject(SAL=[$5])
  LogicalFilter(condition=[OR(IS NULL(CASE(=($5, 1000), null:INTEGER, 1)), IS NULL(CASE(=($5, 2000), null:INTEGER, 1)))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(SAL=[$5])
  LogicalFilter(condition=[SEARCH($5, Sarg[1000, 2000])])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testReduceValuesToEmpty ------------------------------------------------------
# FILTER_PROJECT_TRANSPOSE, PROJECT_MERGE, PROJECT_FILTER_VALUES_MERGE reduce
# a filtered VALUES with no matching rows to empty Values.

select a + b as x, b, a
from (values (10, 1), (30, 7)) as t(a, b)
where a - b < 0;
+---+---+---+
| X | B | A |
+---+---+---+
+---+---+---+
(0 rows)

!ok
LogicalProject(X=[+($0, $1)], B=[$1], A=[$0])
  LogicalFilter(condition=[<(-($0, $1), 0)])
    LogicalValues(tuples=[[{ 10, 1 }, { 30, 7 }]])
!transform ""
LogicalValues(tuples=[[]])
!transform "FILTER_PROJECT_TRANSPOSE, PROJECT_MERGE, PROJECT_FILTER_VALUES_MERGE"

# testReducingConstantsInferredFromCorrelate -----------------------------------
# [CALCITE-3111] PROJECT_REDUCE_EXPRESSIONS reduces CASE to a constant when
# the correlate's inner query always has __source__type__ = 'bounded'.

# Not using !ok: ramp() is a mock table function, not in the scott database.
SELECT ename,
  empno,
  T.empno_r,
  CASE
    WHEN __source__type__ = 'bounded'
      THEN 1
    ELSE 2
    END AS type
FROM (
  SELECT ename,
    empno,
    'bounded' AS __source__type__
  FROM emp
  ) a,
  lateral TABLE (ramp(empno)) AS T(empno_r);
LogicalProject(ENAME=[$0], EMPNO=[$1], EMPNO_R=[$3], TYPE=[CASE(=($2, 'bounded'), 1, 2)])
  LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{1}])
    LogicalProject(ENAME=[$1], EMPNO=[$0], __SOURCE__TYPE__=['bounded'])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableFunctionScan(invocation=[RAMP($cor0.EMPNO)], rowType=[RecordType(INTEGER I)])
!transform "RelBuilder(simplifyValues=false)"
LogicalProject(ENAME=[$0], EMPNO=[$1], EMPNO_R=[$3], TYPE=[1])
  LogicalCorrelate(correlation=[$cor0], joinType=[inner], requiredColumns=[{1}])
    LogicalProject(ENAME=[$1], EMPNO=[$0], __SOURCE__TYPE__=['bounded'])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableFunctionScan(invocation=[RAMP($cor0.EMPNO)], rowType=[RecordType(INTEGER I)])
!transform "RelBuilder(simplifyValues=false), PROJECT_REDUCE_EXPRESSIONS"

