#
# Tests for rules related to reducing constant expressions
# (FILTER_REDUCE_EXPRESSIONS, PROJECT_REDUCE_EXPRESSIONS, JOIN_REDUCE_EXPRESSIONS rules).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testAlreadyFalseEliminatesFilter ---------------------------------------------
# Tests that a filter with a false condition is eliminated.

select * from (values (1,2)) where false;
+--------+--------+
| EXPR$0 | EXPR$1 |
+--------+--------+
+--------+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
  LogicalFilter(condition=[false])
    LogicalValues(tuples=[[{ 1, 2 }]])
!transform ""
LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
  LogicalValues(tuples=[[]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testAsofOpt ------------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS does not modify an ASOF join plan (checkUnchanged).

SELECT *
FROM (VALUES (NULL, 0), (1, NULL), (1, 0), (1, 1), (1, 2),
    (1, 3), (1, 4), (2, 3), (3, 4)) AS t1(k, t)
ASOF JOIN (VALUES (1, NULL), (1, 2), (1, 3), (2, 10), (2, 0)) AS t2(k, t)
MATCH_CONDITION t2.t < t1.t
ON t1.k = t2.k;
+---+---+----+----+
| K | T | K0 | T0 |
+---+---+----+----+
| 1 | 3 |  1 |  2 |
| 1 | 4 |  1 |  3 |
| 2 | 3 |  2 |  0 |
+---+---+----+----+
(3 rows)

!ok
LogicalProject(K=[$0], T=[$1], K0=[$2], T0=[$3])
  LogicalAsofJoin(condition=[=($0, $2)], joinType=[asof], matchCondition=[<($3, $1)])
    LogicalValues(tuples=[[{ null, 0 }, { 1, null }, { 1, 0 }, { 1, 1 }, { 1, 2 }, { 1, 3 }, { 1, 4 }, { 2, 3 }, { 3, 4 }]])
    LogicalValues(tuples=[[{ 1, null }, { 1, 2 }, { 1, 3 }, { 2, 10 }, { 2, 0 }]])
!transform ""
LogicalProject(K=[$0], T=[$1], K0=[$2], T0=[$3])
  LogicalAsofJoin(condition=[=($0, $2)], joinType=[asof], matchCondition=[<($3, $1)])
    LogicalValues(tuples=[[{ null, 0 }, { 1, null }, { 1, 0 }, { 1, 1 }, { 1, 2 }, { 1, 3 }, { 1, 4 }, { 2, 3 }, { 3, 4 }]])
    LogicalValues(tuples=[[{ 1, null }, { 1, 2 }, { 1, 3 }, { 2, 10 }, { 2, 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testCasePushIsAlwaysWorking --------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS reduces a CASE-in-filter to a simpler expression.

select empno
from emp
where case when sal > 1000 then empno else sal end = 1;
+-------+
| EMPNO |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0])
  LogicalFilter(condition=[=(CASE(>($5, 1000), $0, $5), 1)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0])
  LogicalFilter(condition=[OR(AND(>($5, 1000), =($0, 1)), =($5, 1))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS, CALC_REDUCE_EXPRESSIONS, PROJECT_REDUCE_EXPRESSIONS"

# testCastRemove ---------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS does not remove a CAST in a complex CASE with
# COALESCE (checkUnchanged).

select case when cast(dname as double) < 5 then 0.0
            else coalesce(cast(dname as double), 1.0)
            end as t
from (select case when dname > 'abc' then dname
             else null
             end as dname
    from dept);
+-----+
| T   |
+-----+
| 1.0 |
| 1.0 |
| 1.0 |
| 1.0 |
+-----+
(4 rows)

!ok
LogicalProject(T=[CASE(<(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE, 5.0E0), 0.0E0:DOUBLE, CASE(IS NOT NULL(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE), CAST(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE):DOUBLE NOT NULL, 1.0E0:DOUBLE))])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(T=[CASE(<(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE, 5.0E0), 0.0E0:DOUBLE, CASE(IS NOT NULL(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE), CAST(CAST(CASE(>($1, 'abc'), $1, null:VARCHAR(10))):DOUBLE):DOUBLE NOT NULL, 1.0E0:DOUBLE))])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testCorrelationScalarAggAndFilter --------------------------------------------
# [CALCITE-2110] Reduce-expressions rules should not change a plan with a
# correlated scalar sub-query (checkUnchanged).
# Not using !ok: fails with "Correlation variable $cor0 should be defined"
# in CoreQuidemTest2. Add '!ok' when [CALCITE-7430] is fixed.

SELECT e1.empno
FROM emp e1,
  dept d1
where e1.deptno = d1.deptno
and e1.deptno < 10 and d1.deptno < 15
and e1.sal > (select avg(sal) from emp e2 where e1.empno = e2.empno);
LogicalProject(EMPNO=[$0])
  LogicalJoin(condition=[AND(=($0, $4), >($1, $5))], joinType=[inner])
    LogicalJoin(condition=[=($2, $3)], joinType=[inner])
      LogicalFilter(condition=[<($2, 10)])
        LogicalProject(EMPNO=[$0], SAL=[$5], DEPTNO=[$7])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalFilter(condition=[<($0, 15)])
        LogicalProject(DEPTNO=[$0])
          LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}], EXPR$0=[AVG($1)])
      LogicalProject(EMPNO=[$0], SAL=[$5])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true, trim=true)"
LogicalProject(EMPNO=[$0])
  LogicalJoin(condition=[AND(=($0, $4), >($1, $5))], joinType=[inner])
    LogicalJoin(condition=[=($2, $3)], joinType=[inner])
      LogicalFilter(condition=[<($2, 10)])
        LogicalProject(EMPNO=[$0], SAL=[$5], DEPTNO=[$7])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalFilter(condition=[<($0, 15)])
        LogicalProject(DEPTNO=[$0])
          LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}], EXPR$0=[AVG($1)])
      LogicalProject(EMPNO=[$0], SAL=[$5])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true, trim=true), PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS, JOIN_REDUCE_EXPRESSIONS"

# testDoubleReduction ----------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS reduces a POWER expression to a floating-point
# constant. Without [CALCITE-2067], the result was 1008618.49 (less accurate).
# [CALCITE-2067] RexLiteral cannot represent accurately floating point values,
# including NaN, Infinity

SELECT power(1004.3, 2) as p;
+--------------------+
| P                  |
+--------------------+
| 1008618.4899999999 |
+--------------------+
(1 row)

!ok
LogicalProject(P=[POWER(1004.3:DECIMAL(5, 1), 2)])
  LogicalValues(tuples=[[{ 0 }]])
!transform ""
LogicalProject(P=[1008618.4899999999E0:DOUBLE])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testDoubleReduction2 ---------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS reduces 1.0 / 0.0e0 to Infinity. Without
# [CALCITE-2067], Infinity cannot be represented as a BigDecimal value and
# the expression is not reduced.
# [CALCITE-2067] RexLiteral cannot represent accurately floating point values,
# including NaN, Infinity

SELECT 1.0 / 0.0e0;
# Not using !ok: this test focuses on plan transformation (see !transform).
LogicalProject(EXPR$0=[/(1.0:DECIMAL(2, 1), 0.0E0:DOUBLE)])
  LogicalValues(tuples=[[{ 0 }]])
!transform ""
LogicalProject(EXPR$0=[Infinity:DOUBLE])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testExpressionPreceding ------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS does not modify a plan when applied after a window
# function has already been expanded (checkUnchanged).

select COUNT(*) over (
  ORDER BY empno
  ROWS BETWEEN 5 + 5 PRECEDING AND 1 PRECEDING) AS w_count
from emp;
+---------+
| W_COUNT |
+---------+
|       0 |
|       1 |
|      10 |
|      10 |
|      10 |
|      10 |
|       2 |
|       3 |
|       4 |
|       5 |
|       6 |
|       7 |
|       8 |
|       9 |
+---------+
(14 rows)

!ok
LogicalProject(W_COUNT=[$1])
  LogicalWindow(window#0=[window(order by [0] rows between $1 PRECEDING and $2 PRECEDING aggs [COUNT()])], constants=[[10, 1]])
    LogicalProject(EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_REDUCE_EXPRESSIONS, PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW"
LogicalProject(W_COUNT=[$1])
  LogicalWindow(window#0=[window(order by [0] rows between $1 PRECEDING and $2 PRECEDING aggs [COUNT()])], constants=[[10, 1]])
    LogicalProject(EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_REDUCE_EXPRESSIONS, PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_REDUCE_EXPRESSIONS"

# testExpressionSimplification1 ------------------------------------------------
# [CALCITE-5169] 'xx < 1 OR xx > 1' cannot be simplified to 'xx <> 1'.
# ename <> '' and ename <> '3' should be simplified to Sarg.

select *
from emp
where ename <> '' and ename <> '3';
+-------+--------+-----------+------+------------+---------+---------+--------+
| EMPNO | ENAME  | JOB       | MGR  | HIREDATE   | SAL     | COMM    | DEPTNO |
+-------+--------+-----------+------+------------+---------+---------+--------+
|  7369 | SMITH  | CLERK     | 7902 | 1980-12-17 |  800.00 |         |     20 |
|  7499 | ALLEN  | SALESMAN  | 7698 | 1981-02-20 | 1600.00 |  300.00 |     30 |
|  7521 | WARD   | SALESMAN  | 7698 | 1981-02-22 | 1250.00 |  500.00 |     30 |
|  7566 | JONES  | MANAGER   | 7839 | 1981-02-04 | 2975.00 |         |     20 |
|  7654 | MARTIN | SALESMAN  | 7698 | 1981-09-28 | 1250.00 | 1400.00 |     30 |
|  7698 | BLAKE  | MANAGER   | 7839 | 1981-01-05 | 2850.00 |         |     30 |
|  7782 | CLARK  | MANAGER   | 7839 | 1981-06-09 | 2450.00 |         |     10 |
|  7788 | SCOTT  | ANALYST   | 7566 | 1987-04-19 | 3000.00 |         |     20 |
|  7839 | KING   | PRESIDENT |      | 1981-11-17 | 5000.00 |         |     10 |
|  7844 | TURNER | SALESMAN  | 7698 | 1981-09-08 | 1500.00 |    0.00 |     30 |
|  7876 | ADAMS  | CLERK     | 7788 | 1987-05-23 | 1100.00 |         |     20 |
|  7900 | JAMES  | CLERK     | 7698 | 1981-12-03 |  950.00 |         |     30 |
|  7902 | FORD   | ANALYST   | 7566 | 1981-12-03 | 3000.00 |         |     20 |
|  7934 | MILLER | CLERK     | 7782 | 1982-01-23 | 1300.00 |         |     10 |
+-------+--------+-----------+------+------------+---------+---------+--------+
(14 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[AND(<>($1, ''), <>($1, '3'))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[SEARCH($1, Sarg[(-∞..'':VARCHAR(20)), ('':VARCHAR(20)..'3':VARCHAR(20)), ('3':VARCHAR(20)..+∞)]:VARCHAR(20))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testExpressionSimplification2 ------------------------------------------------
# [CALCITE-5169] 'xx < 1 OR xx > 1' cannot be simplified to 'xx <> 1'.
# (ename < '' or ename > '') and (ename < '3' or ename > '3') should be simplified to Sarg too.

select *
from emp
where (ename < '' or ename > '') and (ename < '3' or ename > '3');
+-------+--------+-----------+------+------------+---------+---------+--------+
| EMPNO | ENAME  | JOB       | MGR  | HIREDATE   | SAL     | COMM    | DEPTNO |
+-------+--------+-----------+------+------------+---------+---------+--------+
|  7369 | SMITH  | CLERK     | 7902 | 1980-12-17 |  800.00 |         |     20 |
|  7499 | ALLEN  | SALESMAN  | 7698 | 1981-02-20 | 1600.00 |  300.00 |     30 |
|  7521 | WARD   | SALESMAN  | 7698 | 1981-02-22 | 1250.00 |  500.00 |     30 |
|  7566 | JONES  | MANAGER   | 7839 | 1981-02-04 | 2975.00 |         |     20 |
|  7654 | MARTIN | SALESMAN  | 7698 | 1981-09-28 | 1250.00 | 1400.00 |     30 |
|  7698 | BLAKE  | MANAGER   | 7839 | 1981-01-05 | 2850.00 |         |     30 |
|  7782 | CLARK  | MANAGER   | 7839 | 1981-06-09 | 2450.00 |         |     10 |
|  7788 | SCOTT  | ANALYST   | 7566 | 1987-04-19 | 3000.00 |         |     20 |
|  7839 | KING   | PRESIDENT |      | 1981-11-17 | 5000.00 |         |     10 |
|  7844 | TURNER | SALESMAN  | 7698 | 1981-09-08 | 1500.00 |    0.00 |     30 |
|  7876 | ADAMS  | CLERK     | 7788 | 1987-05-23 | 1100.00 |         |     20 |
|  7900 | JAMES  | CLERK     | 7698 | 1981-12-03 |  950.00 |         |     30 |
|  7902 | FORD   | ANALYST   | 7566 | 1981-12-03 | 3000.00 |         |     20 |
|  7934 | MILLER | CLERK     | 7782 | 1982-01-23 | 1300.00 |         |     10 |
+-------+--------+-----------+------+------------+---------+---------+--------+
(14 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[AND(OR(<($1, ''), >($1, '')), OR(<($1, '3'), >($1, '3')))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[SEARCH($1, Sarg[(-∞..'':VARCHAR(20)), ('':VARCHAR(20)..'3':VARCHAR(20)), ('3':VARCHAR(20)..+∞)]:VARCHAR(20))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testFilterReduceCrash --------------------------------------------------------
# [CALCITE-7070] FILTER_REDUCE_EXPRESSIONS crashes on expression BETWEEN ( NULL) AND X.

SELECT + 54
FROM emp
WHERE NOT CAST ( CAST(empno AS DOUBLE) AS INTEGER ) NOT BETWEEN ( NULL ) AND 89;
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[54])
  LogicalFilter(condition=[NOT(NOT(AND(>=(CAST(CAST($0):DOUBLE NOT NULL):INTEGER NOT NULL, null), <=(CAST(CAST($0):DOUBLE NOT NULL):INTEGER NOT NULL, 89))))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EXPR$0=[54])
  LogicalValues(tuples=[[]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testIsNullPushDown -----------------------------------------------------------
# [CALCITE-5861] ReduceExpressionsRule rules should constant-fold expressions
# in window bounds. COUNT over window is never null, so IS NULL is always false.

select empno, deptno, w_count
from (
  select empno, deptno, count(empno) over (w) w_count
  from emp
  window w as (partition by deptno order by empno)
) sub_query where w_count is null;
+-------+--------+---------+
| EMPNO | DEPTNO | W_COUNT |
+-------+--------+---------+
+-------+--------+---------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], DEPTNO=[$1], W_COUNT=[$2])
  LogicalFilter(condition=[IS NULL($2)])
    LogicalProject(EMPNO=[$0], DEPTNO=[$7], W_COUNT=[$9])
      LogicalWindow(window#0=[window(partition {7} order by [0] aggs [COUNT($0)])])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW"
LogicalProject(EMPNO=[$0], DEPTNO=[$1], W_COUNT=[$2])
  LogicalValues(tuples=[[]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS"

# testIsNullPushDown2 ----------------------------------------------------------
# As testIsNullPushDown but with ROWS window frame.

select empno, deptno, w_count
from (
  select empno, deptno,
    count(empno) over (ROWS BETWEEN 10 PRECEDING AND 1 PRECEDING) w_count
  from emp
) sub_query where w_count is null;
+-------+--------+---------+
| EMPNO | DEPTNO | W_COUNT |
+-------+--------+---------+
+-------+--------+---------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], DEPTNO=[$1], W_COUNT=[$2])
  LogicalFilter(condition=[IS NULL($2)])
    LogicalWindow(window#0=[window(rows between $2 PRECEDING and $3 PRECEDING aggs [COUNT($0)])], constants=[[10, 1]])
      LogicalProject(EMPNO=[$0], DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW"
LogicalProject(EMPNO=[$0], DEPTNO=[$1], W_COUNT=[$2])
  LogicalValues(tuples=[[]])
!transform "PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS"

# testNoOversimplificationBelowIsNull ------------------------------------------
# [CALCITE-2726] FILTER_REDUCE_EXPRESSIONS should not oversimplify conditions
# below IS NULL.

select *
from emp
where ( (empno=1 and mgr=1) or (empno=null and mgr=1) ) is null;
+-------+-------+-----------+-----+------------+---------+------+--------+
| EMPNO | ENAME | JOB       | MGR | HIREDATE   | SAL     | COMM | DEPTNO |
+-------+-------+-----------+-----+------------+---------+------+--------+
|  7839 | KING  | PRESIDENT |     | 1981-11-17 | 5000.00 |      |     10 |
+-------+-------+-----------+-----+------------+---------+------+--------+
(1 row)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[IS NULL(OR(AND(=($0, 1), =($3, 1)), AND(=($0, null), =($3, 1))))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[IS NULL(OR(AND(=($0, 1), =($3, 1)), AND(null, =($3, 1))))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testOrAlwaysTrue -------------------------------------------------------------
# Tests that "sal is null or sal is not null" is always true and the filter is removed.

select *
from EMPNULLABLES_20
where sal is null or sal is not null;
# Not using !ok: query uses EMPNULLABLES, which is not in the scott database.

LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$7])
  LogicalFilter(condition=[OR(IS NULL($5), IS NOT NULL($5))])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$8])
      LogicalFilter(condition=[AND(=($7, 20), >($5, 1000))])
        LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$7])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$8])
    LogicalFilter(condition=[AND(=($7, 20), >($5, 1000))])
      LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS, JOIN_REDUCE_EXPRESSIONS"

# testOrAlwaysTrue2 ------------------------------------------------------------
# Tests that "sal is not null or sal is null" is always true and the filter is removed.

select *
from EMPNULLABLES_20
where sal is not null or sal is null;
# Not using !ok: query uses EMPNULLABLES, which is not in the scott database.

LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$7])
  LogicalFilter(condition=[OR(IS NOT NULL($5), IS NULL($5))])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$8])
      LogicalFilter(condition=[AND(=($7, 20), >($5, 1000))])
        LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$7])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], SLACKER=[$8])
    LogicalFilter(condition=[AND(=($7, 20), >($5, 1000))])
      LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "PROJECT_REDUCE_EXPRESSIONS, FILTER_REDUCE_EXPRESSIONS, JOIN_REDUCE_EXPRESSIONS"

# testOversimplifiedCaseStatement ----------------------------------------------
# [CALCITE-2726] FILTER_REDUCE_EXPRESSIONS should not oversimplify CASE in a
# compound WHERE condition.

select *
from emp
where MGR > 0
    and case when MGR > 0 then deptno / MGR else null end > 1;
+-------+-------+-----+-----+----------+-----+------+--------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO |
+-------+-------+-----+-----+----------+-----+------+--------+
+-------+-------+-----+-----+----------+-----+------+--------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[AND(>($3, 0), >(CASE(>($3, 0), /($7, $3), null:INTEGER), 1))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[AND(>($3, 0), CASE(>($3, 0), >(/($7, $3), 1), false))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_REDUCE_EXPRESSIONS"

# testPredicatePull ------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS pulls constants from filter predicates into a
# rollup aggregate's project.

select deptno, sal
from emp
where deptno = 10
group by rollup(sal, deptno);
+--------+---------+
| DEPTNO | SAL     |
+--------+---------+
|     10 | 1300.00 |
|     10 | 2450.00 |
|     10 | 5000.00 |
|        | 1300.00 |
|        | 2450.00 |
|        | 5000.00 |
|        |         |
+--------+---------+
(7 rows)

!ok
LogicalProject(DEPTNO=[$1], SAL=[$0])
  LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]])
    LogicalProject(SAL=[$5], DEPTNO=[$7])
      LogicalFilter(condition=[=($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$1], SAL=[$0])
  LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]])
    LogicalProject(SAL=[$5], DEPTNO=[10])
      LogicalFilter(condition=[=($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_REDUCE_EXPRESSIONS"

# testProjectOverWithAvg -------------------------------------------------------
# PROJECT_OVER_SUM_TO_SUM0_RULE and WINDOW_REDUCE_EXPRESSIONS convert
# avg(sal) over window to sum0(sal)/count(sal).

select avg(sal) over (order by empno rows 3 preceding)
from emp;
+---------+
| EXPR$0  |
+---------+
| 1200.00 |
| 1216.66 |
| 1587.50 |
| 1637.50 |
| 1656.25 |
| 1768.75 |
| 2081.25 |
| 2137.50 |
| 2381.25 |
| 2387.50 |
| 2650.00 |
| 2987.50 |
| 3325.00 |
|  800.00 |
+---------+
(14 rows)

!ok
LogicalProject(EXPR$0=[CAST(/(CASE(>(COUNT($5) OVER (ORDER BY $0 ROWS 3 PRECEDING), 0), SUM($5) OVER (ORDER BY $0 ROWS 3 PRECEDING), null:INTEGER), COUNT($5) OVER (ORDER BY $0 ROWS 3 PRECEDING))):INTEGER])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EXPR$0=[CAST(/(CASE(>($2, 0), $3, null:INTEGER), $2)):INTEGER])
  LogicalWindow(window#0=[window(order by [0] rows between $2 PRECEDING and CURRENT ROW aggs [COUNT($1), $SUM0($1)])], constants=[[3]])
    LogicalProject(EMPNO=[$0], SAL=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_OVER_SUM_TO_SUM0_RULE, PROJECT_TO_LOGICAL_PROJECT_AND_WINDOW, PROJECT_MERGE, PROJECT_WINDOW_TRANSPOSE, WINDOW_REDUCE_EXPRESSIONS"

# testPullConstantIntoJoin -----------------------------------------------------
# JOIN_PUSH_TRANSITIVE_PREDICATES + JOIN_REDUCE_EXPRESSIONS pull empno = 10
# into the join condition.

select *
from (select * from emp where empno = 10) as e
left join dept as d on e.empno = d.deptno;
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+-----+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO | DEPTNO0 | DNAME | LOC |
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+-----+
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+-----+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalJoin(condition=[=($0, $9)], joinType=[left])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($0, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE"
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalJoin(condition=[true], joinType=[left])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($0, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalFilter(condition=[=($0, 10)])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE, JOIN_PUSH_TRANSITIVE_PREDICATES, JOIN_REDUCE_EXPRESSIONS"

# testPullConstantIntoProject --------------------------------------------------
# JOIN_PUSH_TRANSITIVE_PREDICATES + PROJECT_REDUCE_EXPRESSIONS pull the constant
# deptno = 10 into a project, replacing references with the literal 10.
# Not using !ok: uses schema-qualified table name.

select deptno, deptno + 1, empno + deptno
from emp
where deptno = 10;
LogicalProject(DEPTNO=[$7], EXPR$1=[+($7, 1)], EXPR$2=[+($0, $7)])
  LogicalFilter(condition=[=($7, 10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE"
LogicalProject(DEPTNO=[10], EXPR$1=[11], EXPR$2=[+($0, 10)])
  LogicalFilter(condition=[=($7, 10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE, JOIN_PUSH_TRANSITIVE_PREDICATES, PROJECT_REDUCE_EXPRESSIONS"

# testPullConstantIntoProjectWithIsNotDistinctFrom -----------------------------
# JOIN_PUSH_TRANSITIVE_PREDICATES + FILTER/PROJECT_REDUCE_EXPRESSIONS pull the
# constant deptno IS NOT DISTINCT FROM 10 into a project.

select deptno, deptno + 1 as d1, empno + deptno as ed
from emp
where deptno is not distinct from 10;
+--------+----+------+
| DEPTNO | D1 | ED   |
+--------+----+------+
|     10 | 11 | 7792 |
|     10 | 11 | 7849 |
|     10 | 11 | 7944 |
+--------+----+------+
(3 rows)

!ok
LogicalProject(DEPTNO=[$7], D1=[+($7, 1)], ED=[+($0, $7)])
  LogicalFilter(condition=[OR(AND(IS NULL($7), IS NULL(10)), IS TRUE(=($7, 10)))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE"
LogicalProject(DEPTNO=[10], D1=[11], ED=[+($0, 10)])
  LogicalFilter(condition=[=($7, 10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE, JOIN_PUSH_TRANSITIVE_PREDICATES, FILTER_REDUCE_EXPRESSIONS, PROJECT_REDUCE_EXPRESSIONS"

