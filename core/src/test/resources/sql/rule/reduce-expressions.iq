LogicalProject(EXPR$0=[true], EXPR$1=[false])
  LogicalFilter(condition=[AND(=($6, 2), =($0, 1))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE, FILTER_REDUCE_EXPRESSIONS, PROJECT_REDUCE_EXPRESSIONS"

