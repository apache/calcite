# testSplit --------------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS reduces a compile-time SPLIT expression.
# [CALCITE-5882] Compile-time evaluation of SPLIT function returns incorrect
# result
# Not using !ok: the 'split' function resides in the BigQuery operator table

select split('1|2|3', '|');
LogicalProject(EXPR$0=[SPLIT('1|2|3', '|')])
  LogicalValues(tuples=[[{ 0 }]])
!transform "operatorTable=BIG_QUERY"
LogicalProject(EXPR$0=[ARRAY('1':VARCHAR, '2':VARCHAR, '3':VARCHAR)])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS, operatorTable=BIG_QUERY"

# testSplitNull ----------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS reduces SPLIT(str, NULL) to null.
# [CALCITE-5879] AssertionError during constant reduction of SPLIT expression
# that returns NULL
# Not using !ok: the 'split' function resides in the BigQuery operator table

select split('1|2|3', NULL) as x;
LogicalProject(X=[SPLIT('1|2|3', null:NULL)])
  LogicalValues(tuples=[[{ 0 }]])
!transform "operatorTable=BIG_QUERY"
LogicalProject(X=[null:VARCHAR NOT NULL ARRAY])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS, operatorTable=BIG_QUERY"

# testSplitNull1 ---------------------------------------------------------------
# PROJECT_REDUCE_EXPRESSIONS reduces SPLIT(NULL, sep) to null.
# [CALCITE-5879] AssertionError during constant reduction of SPLIT expression
# that returns NULL
# Not using !ok: the 'split' function resides in the BigQuery operator table

select split(NULL, '|');
LogicalProject(EXPR$0=[SPLIT(null:NULL, '|')])
  LogicalValues(tuples=[[{ 0 }]])
!transform "operatorTable=BIG_QUERY"
LogicalProject(EXPR$0=[null:VARCHAR NOT NULL ARRAY])
  LogicalValues(tuples=[[{ 0 }]])
!transform "PROJECT_REDUCE_EXPRESSIONS, operatorTable=BIG_QUERY"

