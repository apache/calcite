  LogicalFilter(condition=[=($6, 2)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN_DUMB, JOIN_CONDITION_PUSH, FILTER_PROJECT_TRANSPOSE, FILTER_SET_OP_TRANSPOSE, PROJECT_REDUCE_EXPRESSIONS"

