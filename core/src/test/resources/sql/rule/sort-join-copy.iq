#
# Tests for SortJoinCopyRule (CALCITE-7089).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testSortJoinCopySemiJoinOrderBy ----------------------------------------------
# SortJoinCopyRule copies SORT into the inputs of a SemiJoin.

select * from dept d where d.deptno in
  (select e.deptno from emp e) order by d.deptno;
+--------+------------+----------+
| DEPTNO | DNAME      | LOC      |
+--------+------------+----------+
|     10 | ACCOUNTING | NEW YORK |
|     20 | RESEARCH   | DALLAS   |
|     30 | SALES      | CHICAGO  |
+--------+------------+----------+
(3 rows)

!ok
LogicalSort(sort0=[$0], dir0=[ASC])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN"
LogicalSort(sort0=[$0], dir0=[ASC])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalSort(sort0=[$0], dir0=[ASC])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN, SORT_JOIN_COPY"

# testSortJoinCopySemiJoinOrderByLimitOffset -----------------------------------
# SortJoinCopyRule does not copy the LIMIT or OFFSET into SemiJoin inputs.

select * from dept d where d.deptno in
  (select e.deptno from emp e) order by d.deptno limit 10 offset 2;
+--------+-------+---------+
| DEPTNO | DNAME | LOC     |
+--------+-------+---------+
|     30 | SALES | CHICAGO |
+--------+-------+---------+
(1 row)

!ok
LogicalSort(sort0=[$0], dir0=[ASC], offset=[2], fetch=[10])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN"
LogicalSort(sort0=[$0], dir0=[ASC], offset=[2], fetch=[10])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalSort(sort0=[$0], dir0=[ASC])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN, SORT_JOIN_COPY"

# testSortJoinCopySemiJoinOrderByOffset ----------------------------------------
# SortJoinCopyRule does not copy the OFFSET into SemiJoin inputs.

select * from dept d where d.deptno in
  (select e.deptno from emp e) order by d.deptno offset 2;
+--------+-------+---------+
| DEPTNO | DNAME | LOC     |
+--------+-------+---------+
|     30 | SALES | CHICAGO |
+--------+-------+---------+
(1 row)

!ok
LogicalSort(sort0=[$0], dir0=[ASC], offset=[2])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN"
LogicalSort(sort0=[$0], dir0=[ASC], offset=[2])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalSort(sort0=[$0], dir0=[ASC])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "expand=true, PROJECT_TO_SEMI_JOIN, SORT_JOIN_COPY"

# End sort-join-copy.iq
