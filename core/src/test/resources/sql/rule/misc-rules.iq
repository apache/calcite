# Tests for miscellaneous planner rules.
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testBushyJoinRule ------------------------------------------------------------
# MULTI_JOIN_OPTIMIZE_BUSHY does not reorder a left outer join
# (result should be unchanged).

select emp.ename
from emp
LEFT JOIN emp AS emp1 on emp.ename = emp1.ename;
+--------+
| ENAME  |
+--------+
| ADAMS  |
| ALLEN  |
| BLAKE  |
| CLARK  |
| FORD   |
| JAMES  |
| JONES  |
| KING   |
| MARTIN |
| MILLER |
| SCOTT  |
| SMITH  |
| TURNER |
| WARD   |
+--------+
(14 rows)

!ok
LogicalProject(ENAME=[$1])
  MultiJoin(joinFilter=[true], isFullOuterJoin=[false], joinTypes=[[INNER, LEFT]], outerJoinConditions=[[NULL, =($1, $10)]], projFields=[[ALL, ALL]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_TO_MULTI_JOIN"
LogicalProject(ENAME=[$1])
  MultiJoin(joinFilter=[true], isFullOuterJoin=[false], joinTypes=[[INNER, LEFT]], outerJoinConditions=[[NULL, =($1, $10)]], projFields=[[ALL, ALL]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_TO_MULTI_JOIN, MULTI_JOIN_OPTIMIZE_BUSHY"

# testExpandFilterDisjunctionForJoinInput --------------------------------------
# EXPAND_FILTER_DISJUNCTION_LOCAL expands a disjunctive filter over a join,
# then JOIN_CONDITION_PUSH and FILTER_INTO_JOIN push parts of the condition
# down to the join inputs.

select e.empno
from emp as e, empnullables as en, emp_b as eb
where e.empno = en.empno and e.empno = eb.empno
    and ((e.mgr > 100 and eb.sal < 200)
        or (en.comm < 50 and eb.deptno > 10));
# Not using !ok: query uses EMPNULLABLES and EMP_B, not in the scott database.
LogicalProject(EMPNO=[$0])
  LogicalFilter(condition=[AND(=($0, $9), =($0, $18), OR(AND(>($3, 100), <($23, 200)), AND(<($15, 50), >($25, 10))), OR(>($3, 100), <($15, 50)), OR(<($23, 200), >($25, 10)))])
    LogicalJoin(condition=[true], joinType=[inner])
      LogicalJoin(condition=[true], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP_B]])
!transform "EXPAND_FILTER_DISJUNCTION_LOCAL"
LogicalProject(EMPNO=[$0])
  LogicalJoin(condition=[AND(=($0, $18), OR(AND(>($3, 100), <($23, 200)), AND(<($15, 50), >($25, 10))))], joinType=[inner])
    LogicalJoin(condition=[AND(=($0, $9), OR(>($3, 100), <($15, 50)))], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
    LogicalFilter(condition=[OR(<($5, 200), >($7, 10))])
      LogicalTableScan(table=[[CATALOG, SALES, EMP_B]])
!transform "EXPAND_FILTER_DISJUNCTION_LOCAL, JOIN_CONDITION_PUSH, FILTER_INTO_JOIN"

# testExpandJoinDisjunctionForTable --------------------------------------------
# JOIN_CONDITION_PUSH pushes parts of a disjunctive join condition to filter
# inputs after EXPAND_JOIN_DISJUNCTION_GLOBAL has expanded the condition.

select e.empno
from emp as e
inner join empnullables as en on e.empno = en.empno
    and ((e.mgr > 100 and en.sal < 200)
        or (e.comm < 50 and en.deptno > 10));
# Not using !ok: query uses EMPNULLABLES, which is not in the scott database.
LogicalProject(EMPNO=[$0])
  LogicalJoin(condition=[AND(=($0, $9), OR(AND(>($3, 100), <($14, 200)), AND(<($6, 50), >($16, 10))), OR(<($14, 200), >($16, 10)), OR(>($3, 100), <($6, 50)))], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "EXPAND_JOIN_DISJUNCTION_GLOBAL"
LogicalProject(EMPNO=[$0])
  LogicalJoin(condition=[AND(=($0, $9), OR(AND(>($3, 100), <($14, 200)), AND(<($6, 50), >($16, 10))))], joinType=[inner])
    LogicalFilter(condition=[OR(>($3, 100), <($6, 50))])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalFilter(condition=[OR(<($5, 200), >($7, 10))])
      LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "EXPAND_JOIN_DISJUNCTION_GLOBAL, JOIN_CONDITION_PUSH"

# testFilterCalcMergeRule ------------------------------------------------------
# FILTER_CALC_MERGE cannot merge a Filter into a Calc when the Filter contains
# a subquery (result should be unchanged).

select deptno
from emp
where exists (select deptno from emp where empno < 20);
+--------+
| DEPTNO |
+--------+
+--------+
(0 rows)

!ok
LogicalFilter(condition=[EXISTS({
LogicalFilter(condition=[<($0, 20)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
})])
  LogicalCalc(expr#0..8=[{inputs}], DEPTNO=[$t7])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_FILTER_TRANSPOSE, PROJECT_TO_CALC"
LogicalFilter(condition=[EXISTS({
LogicalFilter(condition=[<($0, 20)])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
})])
  LogicalCalc(expr#0..8=[{inputs}], DEPTNO=[$t7])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_FILTER_TRANSPOSE, PROJECT_TO_CALC, FILTER_CALC_MERGE"

# testFilterToCalc -------------------------------------------------------------
# FILTER_TO_CALC does not convert a Filter containing a subquery to a Calc
# (result should be unchanged).

select ename
from emp
where sal > all (select comm from emp);
+-------+
| ENAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalFilter(condition=[NOT(<= SOME($5, {
LogicalProject(COMM=[$6])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
}))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(ENAME=[$1])
  LogicalFilter(condition=[NOT(<= SOME($5, {
LogicalProject(COMM=[$6])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
}))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_TO_CALC"

# testLimitMerge6 --------------------------------------------------------------
# LIMIT_MERGE cannot merge LIMIT 10 into OFFSET 100 when there is no inner
# FETCH (result should be unchanged).

select deptno
from (select deptno from emp where sal > 100 offset 100)
limit 10;
+--------+
| DEPTNO |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(fetch=[10])
      LogicalSort(offset=[100])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "SORT_PROJECT_TRANSPOSE"
LogicalProject(DEPTNO=[$0])
  LogicalProject(DEPTNO=[$7])
    LogicalSort(fetch=[10])
      LogicalSort(offset=[100])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "SORT_PROJECT_TRANSPOSE, LIMIT_MERGE"

# testLoptOptimizeJoinRulePrioritizeSelfJoin -----------------------------------
# MULTI_JOIN_OPTIMIZE prioritizes joining emp with itself (self-join) before
# joining with dept.

select e.empno
from emp e
inner join dept d on d.deptno = e.deptno
inner join emp e2 on e.empno = e2.empno;
+-------+
| EMPNO |
+-------+
|  7369 |
|  7499 |
|  7521 |
|  7566 |
|  7654 |
|  7698 |
|  7782 |
|  7788 |
|  7839 |
|  7844 |
|  7876 |
|  7900 |
|  7902 |
|  7934 |
+-------+
(14 rows)

!ok
LogicalProject(EMPNO=[$0])
  MultiJoin(joinFilter=[=($0, $11)], isFullOuterJoin=[false], joinTypes=[[INNER, INNER]], outerJoinConditions=[[NULL, NULL]], projFields=[[ALL, ALL]])
    MultiJoin(joinFilter=[=($9, $7)], isFullOuterJoin=[false], joinTypes=[[INNER, INNER]], outerJoinConditions=[[NULL, NULL]], projFields=[[ALL, ALL]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_TO_MULTI_JOIN"
LogicalProject(EMPNO=[$0])
  LogicalProject(EMPNO=[$9], ENAME=[$10], JOB=[$11], MGR=[$12], HIREDATE=[$13], SAL=[$14], COMM=[$15], DEPTNO=[$16], SLACKER=[$17], DEPTNO0=[$18], DNAME=[$19], EMPNO0=[$0], ENAME0=[$1], JOB0=[$2], MGR0=[$3], HIREDATE0=[$4], SAL0=[$5], COMM0=[$6], DEPTNO1=[$7], SLACKER0=[$8])
    LogicalJoin(condition=[=($9, $0)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalJoin(condition=[=($9, $7)], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "JOIN_TO_MULTI_JOIN, MULTI_JOIN_OPTIMIZE"

# testManyFiltersOnTopOfMultiJoinShouldCollapse --------------------------------
# FILTER_MULTI_JOIN_MERGE and PROJECT_MULTI_JOIN_MERGE collapse multiple filters
# and a project on top of a MultiJoin into the MultiJoin.

select *
from (
  select *
  from emp e1
  left outer join (select deptno, dname from dept) d
    on e1.deptno = d.deptno
  where d.deptno > 3)
where ename like 'bar';
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO | DEPTNO0 | DNAME |
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+
+-------+-------+-----+-----+----------+-----+------+--------+---------+-------+
(0 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalFilter(condition=[LIKE($1, 'bar')])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
      LogicalFilter(condition=[>($9, 3)])
        MultiJoin(joinFilter=[true], isFullOuterJoin=[false], joinTypes=[[INNER, LEFT]], outerJoinConditions=[[NULL, =($7, $9)]], projFields=[[ALL, ALL]])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
          LogicalProject(DEPTNO=[$0], DNAME=[$1])
            LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "JOIN_TO_MULTI_JOIN"
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  MultiJoin(joinFilter=[true], isFullOuterJoin=[false], joinTypes=[[INNER, LEFT]], outerJoinConditions=[[NULL, =($7, $9)]], projFields=[[{0, 1, 2, 3, 4, 5, 6, 7, 8}, {0, 1}]], postJoinFilter=[AND(LIKE($1, 'bar'), >($9, 3))])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(DEPTNO=[$0], DNAME=[$1])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "JOIN_TO_MULTI_JOIN, FILTER_MULTI_JOIN_MERGE, PROJECT_MULTI_JOIN_MERGE, FILTER_MULTI_JOIN_MERGE"

# testMergeFilterWithJoinCondition ---------------------------------------------
# JOIN_EXTRACT_FILTER, FILTER_TO_CALC, PROJECT_TO_CALC and CALC_MERGE together
# merge a filter and project above a join into a single Calc.

select d.dname, e.ename
from emp e inner join dept d on e.deptno = d.deptno
where d.dname = 'Propane';
+-------+-------+
| DNAME | ENAME |
+-------+-------+
+-------+-------+
(0 rows)

!ok
LogicalProject(DNAME=[$10], ENAME=[$1])
  LogicalFilter(condition=[=($10, 'Propane')])
    LogicalJoin(condition=[=($7, $9)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalCalc(expr#0..10=[{inputs}], expr#11=[=($t7, $t9)], expr#12=['Propane':VARCHAR(10)], expr#13=[=($t10, $t12)], expr#14=[AND($t11, $t13)], DNAME=[$t10], ENAME=[$t1], $condition=[$t14])
  LogicalJoin(condition=[true], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "JOIN_EXTRACT_FILTER, FILTER_TO_CALC, PROJECT_TO_CALC, CALC_MERGE"

# testProjectCalcMergeRule -----------------------------------------------------
# PROJECT_CALC_MERGE cannot merge a Project into a Calc when the Project
# contains a subquery (result should be unchanged).

select exists (select deptno from emp)
from (select deptno from emp where empno < 20);
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[EXISTS({
LogicalTableScan(table=[[CATALOG, SALES, EMP]])
})])
  LogicalCalc(expr#0=[{inputs}], expr#1=[20], expr#2=[<($t0, $t1)], EMPNO=[$t0], $condition=[$t2])
    LogicalProject(EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_FILTER_TRANSPOSE, FILTER_TO_CALC"
LogicalProject(EXPR$0=[EXISTS({
LogicalTableScan(table=[[CATALOG, SALES, EMP]])
})])
  LogicalCalc(expr#0=[{inputs}], expr#1=[20], expr#2=[<($t0, $t1)], EMPNO=[$t0], $condition=[$t2])
    LogicalProject(EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_FILTER_TRANSPOSE, FILTER_TO_CALC, PROJECT_CALC_MERGE"

# testProjectToCalc ------------------------------------------------------------
# PROJECT_TO_CALC does not convert a Project containing a subquery to a Calc
# (result should be unchanged).

select sal > all (select comm from emp)
from emp;
+--------+
| EXPR$0 |
+--------+
| false  |
| false  |
| false  |
| false  |
| false  |
| false  |
|        |
|        |
|        |
|        |
|        |
|        |
|        |
|        |
+--------+
(14 rows)

!ok
LogicalProject(EXPR$0=[NOT(<= SOME($5, {
LogicalProject(COMM=[$6])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
}))])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EXPR$0=[NOT(<= SOME($5, {
LogicalProject(COMM=[$6])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
}))])
  LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_TO_CALC"

# testPullConstantIntoFilter ---------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS simplifies a filter condition using a constant
# predicate from an inner filter (deptno = 10 implies deptno + 5 = 15).

select *
from (select * from emp where deptno = 10)
where deptno + 5 > empno;
# Not using !ok: uses SELECT * which returns different columns in scott vs mock.
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[>(+($7, 5), $0)])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[>(15, $0)])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_PUSH_TRANSITIVE_PREDICATES, FILTER_REDUCE_EXPRESSIONS"

# testPushProjectWithIsNotDistinctFromPastJoin ---------------------------------
# PROJECT_JOIN_TRANSPOSE pushes a project past a join with IS NOT DISTINCT FROM
# in the join condition.

select e.sal + b.comm
from emp e
inner join bonus b
  on (e.ename || e.job) IS NOT DISTINCT FROM (b.ename || b.job)
    and e.deptno = 10;
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[+($5, $13)])
  LogicalJoin(condition=[AND(IS NOT DISTINCT FROM($9, $14), =($7, 10))], joinType=[inner])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], $f9=[||($1, $2)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(ENAME=[$0], JOB=[$1], SAL=[$2], COMM=[$3], $f4=[||($0, $1)])
      LogicalTableScan(table=[[CATALOG, SALES, BONUS]])
!transform ""
LogicalProject(EXPR$0=[+($0, $3)])
  LogicalJoin(condition=[AND(IS NOT DISTINCT FROM($1, $4), $2)], joinType=[inner])
    LogicalProject(SAL=[$5], $f9=[$9], EXPR$0=[=($7, 10)])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], $f9=[||($1, $2)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(COMM=[$3], $f4=[$4])
      LogicalProject(ENAME=[$0], JOB=[$1], SAL=[$2], COMM=[$3], $f4=[||($0, $1)])
        LogicalTableScan(table=[[CATALOG, SALES, BONUS]])
!transform "PROJECT_JOIN_TRANSPOSE"

# testReduceValuesNull ---------------------------------------------------------
# PROJECT_VALUES_MERGE merges a Project containing NULL literals into a Values
# (tests the NULL literal handling in an INSERT statement).

insert into EMPNULLABLES(EMPNO, ENAME, JOB) (select 0, 'null', NULL);
# Not using !ok: query uses EMPNULLABLES, which is not in the scott database.
LogicalTableModify(table=[[CATALOG, SALES, EMPNULLABLES]], operation=[INSERT], flattened=[false])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[null:INTEGER], HIREDATE=[null:TIMESTAMP(0)], SAL=[null:INTEGER], COMM=[null:INTEGER], DEPTNO=[null:INTEGER], SLACKER=[null:BOOLEAN])
    LogicalValues(tuples=[[{ 0, 'null', null }]])
!transform ""
LogicalTableModify(table=[[CATALOG, SALES, EMPNULLABLES]], operation=[INSERT], flattened=[false])
  LogicalValues(tuples=[[{ 0, 'null', null, null, null, null, null, null, null }]])
!transform "PROJECT_VALUES_MERGE"

# testSimplifyFilter -----------------------------------------------------------
# FILTER_REDUCE_EXPRESSIONS removes a redundant predicate in an outer filter
# (deptno > 5 is redundant given deptno > 10 in the inner filter).

select *
from (select * from emp where deptno > 10)
where empno > 3 and deptno > 5;
# Not using !ok: uses SELECT * which returns different columns in scott vs mock.
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[AND(>($0, 3), >($7, 5))])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[>($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
  LogicalFilter(condition=[>($0, 3)])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[>($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_PUSH_TRANSITIVE_PREDICATES, FILTER_REDUCE_EXPRESSIONS"

# End misc-rules.iq
