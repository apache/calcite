# testPushSumConstantGroupingSetsThroughUnion ----------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes SUM(constant) through ROLLUP grouping sets.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select deptno, job, sum(u) as s from
(select *, 2 u from emp as e1 union all
 select *, 3 u from emp as e2)
group by rollup(deptno, job);
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], S=[SUM($2)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], U=[$9])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], U=[2])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], U=[3])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], S=[SUM($2)])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{0, 1}], S=[SUM($2)])
      LogicalProject(DEPTNO=[$7], JOB=[$2], U=[2])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0, 1}], S=[SUM($2)])
      LogicalProject(DEPTNO=[$7], JOB=[$2], U=[3])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

# testPushSumConstantThroughUnion ----------------------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes SUM(constant) through UNION ALL where the
# two branches have different constants.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select ename, sum(u) as s from
(select *, 2 u from emp as e1 union all
 select *, 3 u from emp as e2)
group by ename;
LogicalAggregate(group=[{0}], S=[SUM($1)])
  LogicalProject(ENAME=[$1], U=[$9])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], U=[2])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], U=[3])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], S=[SUM($1)])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{0}], S=[SUM($1)])
      LogicalProject(ENAME=[$1], U=[2])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0}], S=[SUM($1)])
      LogicalProject(ENAME=[$1], U=[3])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

# testPushSumCountStarGroupingSetsThroughUnion ---------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes multiple aggregates through ROLLUP grouping
# sets.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select deptno, job, sum(empno) as s, count(*) as c, min(deptno) as n,
    max(empno) as m from
(select * from emp as e1 union all
 select * from emp as e2)
group by rollup(deptno, job);
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], S=[SUM($2)], C=[COUNT()], N=[MIN($0)], M=[MAX($2)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], S=[SUM($2)], C=[$SUM0($3)], N=[MIN($4)], M=[MAX($5)])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{0, 1}], S=[SUM($2)], C=[COUNT()], N=[MIN($0)], M=[MAX($2)])
      LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0, 1}], S=[SUM($2)], C=[COUNT()], N=[MIN($0)], M=[MAX($2)])
      LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

