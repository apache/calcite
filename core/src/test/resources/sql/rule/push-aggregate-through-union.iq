# Tests for AGGREGATE_UNION_TRANSPOSE rule (push aggregate through union).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testPushAvgGroupingSetsThroughUnion ------------------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes AVG aggregate through ROLLUP grouping sets.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select deptno, job, avg(empno) as a from
(select * from emp as e1 union all
 select * from emp as e2)
group by rollup(deptno, job);
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], A=[AVG($2)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], A=[AVG($2)])
  LogicalUnion(all=[true])
    LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(DEPTNO=[$7], JOB=[$2], EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

# testPushAvgThroughUnion ------------------------------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes AVG aggregate through UNION ALL.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select ename, avg(empno) as a from
(select * from emp as e1 union all
 select * from emp as e2)
group by ename;
LogicalAggregate(group=[{0}], A=[AVG($1)])
  LogicalProject(ENAME=[$1], EMPNO=[$0])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], A=[AVG($1)])
  LogicalUnion(all=[true])
    LogicalProject(ENAME=[$1], EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(ENAME=[$1], EMPNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

# testPushCountFilterThroughUnion ----------------------------------------------
# AGGREGATE_UNION_TRANSPOSE pushes a filtered COUNT(*) through UNION ALL.
# Not using !ok: GROUP BY results are unordered without ORDER BY.

select deptno, count(*) filter (where job = 'CLERK') as c
from (
  select * from emp where deptno = 10
  union all
  select * from emp where deptno > 20)
group by deptno;
LogicalAggregate(group=[{0}], C=[COUNT() FILTER $1])
  LogicalProject(DEPTNO=[$7], $f1=[=($2, 'CLERK')])
    LogicalUnion(all=[true])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalFilter(condition=[=($7, 10)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
        LogicalFilter(condition=[>($7, 20)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], C=[$SUM0($1)])
  LogicalUnion(all=[true])
    LogicalAggregate(group=[{0}], C=[COUNT() FILTER $1])
      LogicalProject(DEPTNO=[$7], $f1=[=($2, 'CLERK')])
        LogicalFilter(condition=[=($7, 10)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0}], C=[COUNT() FILTER $1])
      LogicalProject(DEPTNO=[$7], $f1=[=($2, 'CLERK')])
        LogicalFilter(condition=[>($7, 20)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "PROJECT_SET_OP_TRANSPOSE, PROJECT_MERGE, AGGREGATE_UNION_TRANSPOSE"

