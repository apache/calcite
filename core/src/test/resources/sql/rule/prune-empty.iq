!transform "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.JOIN_LEFT_INSTANCE, PruneEmptyRules.JOIN_RIGHT_INSTANCE"

# testLeftEmptyRightJoin -------------------------------------------------------
# JOIN_LEFT_INSTANCE: left input is empty, RIGHT join → right side is padded
# with nulls (cannot eliminate join).

select *
from (select * from emp where false) e
right join dept d on e.deptno = d.deptno;
+-------+-------+-----+-----+----------+-----+------+--------+---------+------------+----------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO | DEPTNO0 | DNAME      | LOC      |
+-------+-------+-----+-----+----------+-----+------+--------+---------+------------+----------+
|       |       |     |     |          |     |      |        |      10 | ACCOUNTING | NEW YORK |
|       |       |     |     |          |     |      |        |      20 | RESEARCH   | DALLAS   |
|       |       |     |     |          |     |      |        |      30 | SALES      | CHICAGO  |
|       |       |     |     |          |     |      |        |      40 | OPERATIONS | BOSTON   |
+-------+-------+-----+-----+----------+-----+------+--------+---------+------------+----------+
(4 rows)

!ok
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalJoin(condition=[=($7, $9)], joinType=[right])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[false])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[$9], DNAME=[$10])
  LogicalProject(EMPNO=[null:INTEGER], ENAME=[null:VARCHAR(20)], JOB=[null:VARCHAR(10)], MGR=[null:INTEGER], HIREDATE=[null:TIMESTAMP(0)], SAL=[null:INTEGER], COMM=[null:INTEGER], DEPTNO=[null:INTEGER], SLACKER=[null:BOOLEAN], DEPTNO0=[$0], DNAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.JOIN_LEFT_INSTANCE, PruneEmptyRules.JOIN_RIGHT_INSTANCE"

# testLeftJoinRemoveConditionIsAlwaysFalse -------------------------------------
# [CALCITE-7071] LEFT JOIN where condition is always false: right input becomes
# empty, and JOIN_RIGHT_INSTANCE removes the join.

select e.deptno
from emp e
left join dept d on e.deptno = d.deptno and e.deptno between 3 and 1;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
+--------+
(14 rows)

!ok
LogicalProject(DEPTNO=[$7])
  LogicalJoin(condition=[false], joinType=[left])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "NONE"
LogicalProject(DEPTNO=[$7])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8], DEPTNO0=[null:INTEGER], DNAME=[null:VARCHAR(10)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_CONDITION_PUSH, PruneEmptyRules.JOIN_RIGHT_INSTANCE"

# testPruneEmptyRuleForLeftMarkJoin --------------------------------------------
# [CALCITE-7396] PruneEmptyRules does not support LEFT_MARK JOIN.
# Pre-rules convert NOT IN to a LEFT_MARK JOIN; FILTER_REDUCE_EXPRESSIONS
# reduces the inner 'false' condition; PROJECT_INSTANCE propagates empty.
# Then JOIN_RIGHT_INSTANCE handles the LEFT_MARK JOIN with empty right input.

select * from dept
where deptno not in (select deptno from emp where false);
+--------+------------+----------+
| DEPTNO | DNAME      | LOC      |
+--------+------------+----------+
|     10 | ACCOUNTING | NEW YORK |
|     20 | RESEARCH   | DALLAS   |
|     30 | SALES      | CHICAGO  |
|     40 | OPERATIONS | BOSTON   |
+--------+------------+----------+
(4 rows)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[NOT($2)])
      LogicalJoin(condition=[=($0, $2)], joinType=[left_mark])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalValues(tuples=[[]])
!transform "FILTER_SUB_QUERY_TO_MARK_CORRELATE, FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE"
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalFilter(condition=[NOT($2)])
      LogicalProject(DEPTNO=[$0], DNAME=[$1], markCol=[false])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_SUB_QUERY_TO_MARK_CORRELATE, FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.JOIN_RIGHT_INSTANCE"

# testRightEmptyFullJoin -------------------------------------------------------
# JOIN_RIGHT_INSTANCE: right input is empty, FULL join → left side is padded
# with nulls (cannot eliminate join).

select *
from emp e
full join (select * from dept where false) as d
  on e.deptno = d.deptno;
+-------+--------+-----------+------+------------+---------+---------+--------+---------+-------+-----+
| EMPNO | ENAME  | JOB       | MGR  | HIREDATE   | SAL     | COMM    | DEPTNO | DEPTNO0 | DNAME | LOC |
+-------+--------+-----------+------+------------+---------+---------+--------+---------+-------+-----+
