# testRightJoinRemoveConditionIsAlwaysFalse ------------------------------------
# [CALCITE-7071] RIGHT JOIN where condition is always false: left input becomes
# empty, and JOIN_LEFT_INSTANCE removes the join.

select e.deptno
from dept d
right join emp e on e.deptno = d.deptno and e.deptno between 3 and 1;
+--------+
| DEPTNO |
+--------+
|     10 |
|     10 |
|     10 |
|     20 |
|     20 |
|     20 |
|     20 |
|     20 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
|     30 |
+--------+
(14 rows)

!ok
LogicalProject(DEPTNO=[$9])
  LogicalJoin(condition=[false], joinType=[right])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "NONE"
LogicalProject(DEPTNO=[$9])
  LogicalProject(DEPTNO=[null:INTEGER], DNAME=[null:VARCHAR(10)], EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO0=[$7], SLACKER=[$8])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "JOIN_CONDITION_PUSH, PruneEmptyRules.JOIN_LEFT_INSTANCE"

