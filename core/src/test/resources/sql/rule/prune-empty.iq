#
# Tests for PruneEmptyRules (removing relational expressions that produce
# no rows due to empty inputs).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testEmptyAggregate -----------------------------------------------------------
# AGGREGATE_INSTANCE removes an Aggregate over an empty input.

select sum(empno) from emp where false group by deptno;
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[$1])
  LogicalAggregate(group=[{0}], EXPR$0=[SUM($1)])
    LogicalProject(DEPTNO=[$7], EMPNO=[$0])
      LogicalFilter(condition=[false])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalProject(EXPR$0=[$1])
  LogicalAggregate(group=[{0}], EXPR$0=[SUM($1)])
    LogicalValues(tuples=[[]])
!sub-plan "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE"
LogicalValues(tuples=[[]])
!sub-plan "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.AGGREGATE_INSTANCE, PruneEmptyRules.PROJECT_INSTANCE"

# testEmptyAggregateEmptyKey ---------------------------------------------------
# AGGREGATE_INSTANCE does not remove an Aggregate with no GROUP BY (empty key),
# even when the input is empty.

select sum(empno) from emp where false;
+--------+
| EXPR$0 |
+--------+
|        |
+--------+
(1 row)

!ok
LogicalAggregate(group=[{}], EXPR$0=[SUM($0)])
  LogicalProject(EMPNO=[$0])
    LogicalFilter(condition=[false])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalAggregate(group=[{}], EXPR$0=[SUM($0)])
  LogicalValues(tuples=[[]])
!sub-plan "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE"
LogicalAggregate(group=[{}], EXPR$0=[SUM($0)])
  LogicalValues(tuples=[[]])
!sub-plan "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.AGGREGATE_INSTANCE"

# testEmptyIntersect -----------------------------------------------------------
# INTERSECT_INSTANCE removes an INTERSECT when any input is empty.

select * from (values (30, 3))
intersect
select * from (values (10, 1), (30, 3)) as t (x, y) where x > 50
intersect
select * from (values (30, 3));
+--------+--------+
| EXPR$0 | EXPR$1 |
+--------+--------+
+--------+--------+
(0 rows)

!ok
LogicalIntersect(all=[false])
  LogicalIntersect(all=[false])
    LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
      LogicalValues(tuples=[[{ 30, 3 }]])
    LogicalProject(X=[$0], Y=[$1])
      LogicalFilter(condition=[>($0, 50)])
        LogicalValues(tuples=[[{ 10, 1 }, { 30, 3 }]])
  LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
    LogicalValues(tuples=[[{ 30, 3 }]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "PROJECT_FILTER_VALUES_MERGE, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.INTERSECT_INSTANCE"

# testEmptyMinus ---------------------------------------------------------------
# MINUS_INSTANCE removes a MINUS when the first input is empty.

select * from (values (30, 3)) as t (x, y)
where x > 30
except
select * from (values (20, 2))
except
select * from (values (40, 4));
+---+---+
| X | Y |
+---+---+
+---+---+
(0 rows)

!ok
LogicalMinus(all=[false])
  LogicalMinus(all=[false])
    LogicalProject(X=[$0], Y=[$1])
      LogicalFilter(condition=[>($0, 30)])
        LogicalValues(tuples=[[{ 30, 3 }]])
    LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
      LogicalValues(tuples=[[{ 20, 2 }]])
  LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
    LogicalValues(tuples=[[{ 40, 4 }]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "PROJECT_FILTER_VALUES_MERGE, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.MINUS_INSTANCE"

# testEmptyMinus2 --------------------------------------------------------------
# MINUS_INSTANCE removes empty non-first inputs from a MINUS (EXCEPT).

select * from (values (30, 3)) as t (x, y)
except
select * from (values (20, 2)) as t (x, y) where x > 30
except
select * from (values (40, 4))
except
select * from (values (50, 5)) as t (x, y) where x > 50;
+----+---+
| X  | Y |
+----+---+
| 30 | 3 |
+----+---+
(1 row)

!ok
LogicalMinus(all=[false])
  LogicalMinus(all=[false])
    LogicalMinus(all=[false])
      LogicalProject(X=[$0], Y=[$1])
        LogicalValues(tuples=[[{ 30, 3 }]])
      LogicalProject(X=[$0], Y=[$1])
        LogicalFilter(condition=[>($0, 30)])
          LogicalValues(tuples=[[{ 20, 2 }]])
    LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
      LogicalValues(tuples=[[{ 40, 4 }]])
  LogicalProject(X=[$0], Y=[$1])
    LogicalFilter(condition=[>($0, 50)])
      LogicalValues(tuples=[[{ 50, 5 }]])
!sub-plan "NONE"
LogicalMinus(all=[false])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 30, 3 }]])
  LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
    LogicalValues(tuples=[[{ 40, 4 }]])
!sub-plan "PROJECT_FILTER_VALUES_MERGE, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.MINUS_INSTANCE"

# testEmptyMinus3 --------------------------------------------------------------
# [CALCITE-6955] PruneEmptyRules does not handle the all attribute of SetOp
# correctly: MINUS (EXCEPT) of a first empty input yields empty, even when ALL.

select * from (values (30, 3), (30, 3)) as t (x, y)
except
select * from (values (20, 2)) as t (x, y) where x > 30;
+----+---+
| X  | Y |
+----+---+
| 30 | 3 |
+----+---+
(1 row)

!ok
LogicalMinus(all=[false])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 30, 3 }, { 30, 3 }]])
  LogicalProject(X=[$0], Y=[$1])
    LogicalFilter(condition=[>($0, 30)])
      LogicalValues(tuples=[[{ 20, 2 }]])
!sub-plan "NONE"
LogicalAggregate(group=[{0, 1}])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 30, 3 }, { 30, 3 }]])
!sub-plan "PROJECT_FILTER_VALUES_MERGE, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.MINUS_INSTANCE"

# testEmptyProject -------------------------------------------------------------
# [CALCITE-1488] ValuesReduceRule should ignore empty Values.
# PROJECT_FILTER_VALUES_MERGE and FILTER_VALUES_MERGE work together; then
# PROJECT_VALUES_MERGE simplifies the outer project.

select z + x from (
  select x + y as z, x from (
    select * from (values (10, 1), (30, 3)) as t (x, y)
    where x + y > 50));
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[+(+($0, $1), $0)])
  LogicalFilter(condition=[>(+($0, $1), 50)])
    LogicalValues(tuples=[[{ 10, 1 }, { 30, 3 }]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "PROJECT_FILTER_VALUES_MERGE, FILTER_VALUES_MERGE, PROJECT_VALUES_MERGE"

# testEmptyProject2 ------------------------------------------------------------
# Same query as testEmptyProject; PruneEmptyRules can achieve the same result.

select z + x from (
  select x + y as z, x from (
    select * from (values (10, 1), (30, 3)) as t (x, y)
    where x + y > 50));
+--------+
| EXPR$0 |
+--------+
+--------+
(0 rows)

!ok
LogicalProject(EXPR$0=[+(+($0, $1), $0)])
  LogicalFilter(condition=[>(+($0, $1), 50)])
    LogicalValues(tuples=[[{ 10, 1 }, { 30, 3 }]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "FILTER_VALUES_MERGE, PruneEmptyRules.PROJECT_INSTANCE"

# testEmptySort ----------------------------------------------------------------
# SORT_INSTANCE removes a Sort over an empty input.

select * from emp where false order by deptno;
+-------+-------+-----+-----+----------+-----+------+--------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO |
+-------+-------+-----+-----+----------+-----+------+--------+
+-------+-------+-----+-----+----------+-----+------+--------+
(0 rows)

!ok
LogicalSort(sort0=[$7], dir0=[ASC])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalFilter(condition=[false])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "FILTER_REDUCE_EXPRESSIONS, PruneEmptyRules.PROJECT_INSTANCE, PruneEmptyRules.SORT_INSTANCE"

# testEmptySortLimitZero -------------------------------------------------------
# SORT_FETCH_ZERO_INSTANCE removes a Sort with LIMIT 0.

select * from emp order by deptno limit 0;
+-------+-------+-----+-----+----------+-----+------+--------+
| EMPNO | ENAME | JOB | MGR | HIREDATE | SAL | COMM | DEPTNO |
+-------+-------+-----+-----+----------+-----+------+--------+
+-------+-------+-----+-----+----------+-----+------+--------+
(0 rows)

!ok
LogicalSort(sort0=[$7], dir0=[ASC], fetch=[0])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!sub-plan "NONE"
LogicalValues(tuples=[[]])
!sub-plan "PruneEmptyRules.SORT_FETCH_ZERO_INSTANCE"

# End prune-empty.iq
