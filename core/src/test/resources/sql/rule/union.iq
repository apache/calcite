    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($7, 10)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
      LogicalFilter(condition=[=($7, 20)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalFilter(condition=[=($7, 30)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalUnion(all=[false])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalFilter(condition=[=($7, 10)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalFilter(condition=[=($7, 20)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalProject(EMPNO=[$0], ENAME=[$1], JOB=[$2], MGR=[$3], HIREDATE=[$4], SAL=[$5], COMM=[$6], DEPTNO=[$7], SLACKER=[$8])
    LogicalFilter(condition=[=($7, 30)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "UNION_MERGE"

# testPullConstantThroughUnion -------------------------------------------------
# UNION_PULL_UP_CONSTANTS + PROJECT_MERGE pull constant columns (literal 2)
# out of a UNION ALL and add a Project above.

select 2 as c2, dname from dept as e1
union all
select 2 as c2, dname from dept as d2;
+----+------------+
| C2 | DNAME      |
+----+------------+
|  2 | ACCOUNTING |
|  2 | ACCOUNTING |
|  2 | OPERATIONS |
|  2 | OPERATIONS |
|  2 | RESEARCH   |
|  2 | RESEARCH   |
|  2 | SALES      |
|  2 | SALES      |
+----+------------+
(8 rows)

!ok
LogicalUnion(all=[true])
  LogicalProject(C2=[2], DNAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(C2=[2], DNAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(trim=true)"
LogicalProject(C2=[2], DNAME=[$0])
  LogicalUnion(all=[true])
    LogicalProject(DNAME=[$1])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DNAME=[$1])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(trim=true), UNION_PULL_UP_CONSTANTS, PROJECT_MERGE"

# testPullConstantThroughUnion2 ------------------------------------------------
# Negative test: UNION_PULL_UP_CONSTANTS does not fire when constants differ
# across inputs.

select 2 as c2, deptno from dept as d1
union all
select 1 as c2, deptno from dept as d2;
+----+--------+
| C2 | DEPTNO |
+----+--------+
|  1 |     10 |
|  1 |     20 |
|  1 |     30 |
|  1 |     40 |
|  2 |     10 |
|  2 |     20 |
|  2 |     30 |
|  2 |     40 |
+----+--------+
(8 rows)

!ok
LogicalUnion(all=[true])
  LogicalProject(C2=[2], DEPTNO=[$0])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(C2=[1], DEPTNO=[$0])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalUnion(all=[true])
  LogicalProject(C2=[2], DEPTNO=[$0])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(C2=[1], DEPTNO=[$0])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "UNION_PULL_UP_CONSTANTS, PROJECT_MERGE"

# testPullConstantThroughUnion3 ------------------------------------------------
# UNION_PULL_UP_CONSTANTS + PROJECT_MERGE pull both constant columns out, but
# leave at least one column in each input to keep the UNION well-formed.

select 2 as c2, 3 as c3 from dept as d1
union all
select 2 as c2, 3 as c3 from dept as d2;
+----+----+
| C2 | C3 |
+----+----+
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
|  2 |  3 |
+----+----+
(8 rows)

!ok
LogicalUnion(all=[true])
  LogicalProject(C2=[2], C3=[3])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(C2=[2], C3=[3])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(trim=true)"
LogicalProject(C2=[2], C3=[3])
  LogicalUnion(all=[true])
    LogicalProject(C2=[2])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(C2=[2])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(trim=true), UNION_PULL_UP_CONSTANTS, PROJECT_MERGE"

# testPullConstantThroughUnionSameTypeNullableField ----------------------------
# UNION_PULL_UP_CONSTANTS + PROJECT_MERGE pull constant deptno (= 1) from both
# UNION inputs.
# Not using !ok: query uses EMPNULLABLES, which is not in the scott database.

select deptno, ename from sales.empnullables where deptno = 1
union all
select deptno, ename from sales.empnullables where deptno = 1;
LogicalUnion(all=[true])
  LogicalProject(DEPTNO=[$1], ENAME=[$0])
    LogicalFilter(condition=[=($1, 1)])
      LogicalProject(ENAME=[$1], DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
  LogicalProject(DEPTNO=[$1], ENAME=[$0])
    LogicalFilter(condition=[=($1, 1)])
      LogicalProject(ENAME=[$1], DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "Sql2Rel(trim=true)"
LogicalProject(DEPTNO=[CAST(1):INTEGER], ENAME=[$0])
  LogicalUnion(all=[true])
    LogicalProject(ENAME=[$0])
      LogicalFilter(condition=[=($1, 1)])
        LogicalProject(ENAME=[$1], DEPTNO=[$7])
          LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
    LogicalProject(ENAME=[$0])
      LogicalFilter(condition=[=($1, 1)])
        LogicalProject(ENAME=[$1], DEPTNO=[$7])
          LogicalTableScan(table=[[CATALOG, SALES, EMPNULLABLES]])
!transform "Sql2Rel(trim=true), UNION_PULL_UP_CONSTANTS, PROJECT_MERGE"

# testUnionToDistinctRule ------------------------------------------------------
# UNION_TO_DISTINCT converts a UNION (distinct) to UNION ALL + Aggregate.

select deptno, dname from dept
union
select deptno, dname from dept;
+--------+------------+
| DEPTNO | DNAME      |
+--------+------------+
|     10 | ACCOUNTING |
|     20 | RESEARCH   |
|     30 | SALES      |
|     40 | OPERATIONS |
+--------+------------+
(4 rows)

!ok
LogicalUnion(all=[false])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(DEPTNO=[$0], DNAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalAggregate(group=[{0, 1}])
  LogicalUnion(all=[true])
    LogicalProject(DEPTNO=[$0], DNAME=[$1])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$0], DNAME=[$1])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "UNION_TO_DISTINCT"

# End union.iq
