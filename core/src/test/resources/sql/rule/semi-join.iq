    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_JOIN_TRANSPOSE"

# testPushSemiJoinPastProject --------------------------------------------------
# SEMI_JOIN_PROJECT_TRANSPOSE pushes a semi-join past a project.

select e.*
from (select ename, trim(job) as j, sal * 2 as s2, deptno
    from emp) e,
  dept d
where e.deptno = d.deptno;
+--------+-----------+----------+--------+
| ENAME  | J         | S2       | DEPTNO |
+--------+-----------+----------+--------+
| ADAMS  | CLERK     |  2200.00 |     20 |
| ALLEN  | SALESMAN  |  3200.00 |     30 |
| BLAKE  | MANAGER   |  5700.00 |     30 |
| CLARK  | MANAGER   |  4900.00 |     10 |
| FORD   | ANALYST   |  6000.00 |     20 |
| JAMES  | CLERK     |  1900.00 |     30 |
| JONES  | MANAGER   |  5950.00 |     20 |
| KING   | PRESIDENT | 10000.00 |     10 |
| MARTIN | SALESMAN  |  2500.00 |     30 |
| MILLER | CLERK     |  2600.00 |     10 |
| SCOTT  | ANALYST   |  6000.00 |     20 |
| SMITH  | CLERK     |  1600.00 |     20 |
| TURNER | SALESMAN  |  3000.00 |     30 |
| WARD   | SALESMAN  |  2500.00 |     30 |
+--------+-----------+----------+--------+
(14 rows)

!ok
LogicalProject(ENAME=[$0], J=[$1], S2=[$2], DEPTNO=[$3])
  LogicalFilter(condition=[=($3, $4)])
    LogicalJoin(condition=[true], joinType=[inner])
      LogicalProject(ENAME=[$1], J=[TRIM(FLAG(BOTH), ' ', $2)], S2=[*($5, 2)], DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(ENAME=[$0], J=[$1], S2=[$2], DEPTNO=[$3])
  LogicalJoin(condition=[=($3, $4)], joinType=[inner], semiJoinDone=[true])
    LogicalProject(ENAME=[$1], J=[TRIM(FLAG(BOTH), ' ', $2)], S2=[*($5, 2)], DEPTNO=[$7])
      LogicalJoin(condition=[=($7, $9)], joinType=[semi])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_PROJECT_TRANSPOSE"

# testRemoveSemiJoin -----------------------------------------------------------
# SEMI_JOIN_REMOVE removes a redundant semi-join when the join is already
# enforced by an inner join.

select e.ename
from emp e, dept d
where e.deptno = d.deptno;
+--------+
| ENAME  |
+--------+
| ADAMS  |
| ALLEN  |
| BLAKE  |
| CLARK  |
| FORD   |
| JAMES  |
| JONES  |
| KING   |
| MARTIN |
| MILLER |
| SCOTT  |
| SMITH  |
| TURNER |
| WARD   |
+--------+
(14 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalJoin(condition=[=($7, $9)], joinType=[inner], semiJoinDone=[true])
    LogicalJoin(condition=[=($7, $9)], joinType=[semi])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN"
LogicalProject(ENAME=[$1])
  LogicalJoin(condition=[=($7, $9)], joinType=[inner], semiJoinDone=[true])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_REMOVE"

