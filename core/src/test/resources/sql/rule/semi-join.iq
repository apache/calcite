#
# Tests planner rules related to semi-join optimizations.
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testIncorrectInType ----------------------------------------------------------
# PROJECT_TO_SEMI_JOIN should not match an IN with a literal right side.

select ename
from emp
where ename in ( 'Sebastian' ) and ename = 'Sebastian' and deptno < 100;
+-------+
| ENAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(ENAME=[$0])
  LogicalFilter(condition=[AND(=($0, 'Sebastian'), <($1, 100))])
    LogicalProject(ENAME=[$1], DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(trim=true)"

# testPushAggregateThroughSemiJoin ---------------------------------------------
# PROJECT_TO_SEMI_JOIN, AGGREGATE_JOIN_TRANSPOSE_EXTENDED push an aggregate
# through a semi-join.
# [CALCITE-6600]

select distinct sal
from (select *
  from emp e
  where e.job in (select d.dname from dept d));
+-----+
| SAL |
+-----+
+-----+
(0 rows)

!ok
LogicalAggregate(group=[{1}])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalAggregate(group=[{0, 1}])
      LogicalProject(JOB=[$2], SAL=[$5])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{0}])
      LogicalProject(DNAME=[$1])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(trim=true), lateDecorrelate=true, subQueryRules, PROJECT_MERGE, PROJECT_TO_SEMI_JOIN, AGGREGATE_PROJECT_MERGE, AGGREGATE_JOIN_TRANSPOSE_EXTENDED"

# testPushFilterThroughSemiJoin ------------------------------------------------
# FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, JOIN_CONDITION_PUSH push filters
# through a semi-join.
# [CALCITE-438]

select *
from (
  select *
  from dept
  where dept.deptno in (
    select emp.deptno from emp))R
where R.deptno <=10;
+--------+------------+----------+
| DEPTNO | DNAME      | LOC      |
+--------+------------+----------+
|     10 | ACCOUNTING | NEW YORK |
+--------+------------+----------+
(1 row)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalFilter(condition=[<=($0, 10)])
    LogicalJoin(condition=[=($0, $2)], joinType=[semi])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalProject(DEPTNO=[$7])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true), PROJECT_TO_SEMI_JOIN"
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[semi])
    LogicalFilter(condition=[<=($0, 10)])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true), PROJECT_TO_SEMI_JOIN, FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, JOIN_CONDITION_PUSH"

# testPushSemiJoinPastFilter ---------------------------------------------------
# SEMI_JOIN_FILTER_TRANSPOSE pushes a semi-join past a filter.

select e.ename
from emp e, dept d
where e.deptno = d.deptno and e.ename = 'foo';
+-------+
| ENAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalFilter(condition=[AND(=($7, $9), =($1, 'foo'))])
    LogicalJoin(condition=[true], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(ENAME=[$1])
  LogicalJoin(condition=[=($7, $9)], joinType=[inner], semiJoinDone=[true])
    LogicalFilter(condition=[=($1, 'foo')])
      LogicalJoin(condition=[=($7, $9)], joinType=[semi])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_FILTER_TRANSPOSE"

# testPushSemiJoinPastJoinRuleLeft ---------------------------------------------
# SEMI_JOIN_JOIN_TRANSPOSE pushes a semi-join to the left input of a join.

select e1.ename
from emp e1, dept d, emp e2
where e1.deptno = d.deptno and e1.empno = e2.empno;
+--------+
| ENAME  |
+--------+
| ADAMS  |
| ALLEN  |
| BLAKE  |
| CLARK  |
| FORD   |
| JAMES  |
| JONES  |
| KING   |
| MARTIN |
| MILLER |
| SCOTT  |
| SMITH  |
| TURNER |
| WARD   |
+--------+
(14 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalFilter(condition=[AND(=($7, $9), =($0, $11))])
    LogicalJoin(condition=[true], joinType=[inner])
      LogicalJoin(condition=[true], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(ENAME=[$1])
  LogicalJoin(condition=[=($0, $11)], joinType=[inner], semiJoinDone=[true])
    LogicalJoin(condition=[=($7, $9)], joinType=[inner], semiJoinDone=[true])
      LogicalJoin(condition=[=($0, $9)], joinType=[semi])
        LogicalJoin(condition=[=($7, $9)], joinType=[semi])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
          LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_JOIN_TRANSPOSE"

# testPushSemiJoinPastJoinRuleNotHappensJoinKeysDifferentOrigin ----------------
# SEMI_JOIN_JOIN_TRANSPOSE cannot push a semi-join whose keys come from both
# inputs of the bottom join, but JOIN_ADD_REDUNDANT_SEMI_JOIN still fires.

select e.ename
from emp e, dept d, bonus b
where e.deptno = d.deptno and e.ename = b.ename and d.dname = b.job;
+-------+
| ENAME |
+-------+
+-------+
(0 rows)

!ok
LogicalProject(ENAME=[$1])
  LogicalFilter(condition=[AND(=($7, $9), =($1, $11), =($10, $12))])
    LogicalJoin(condition=[true], joinType=[inner])
      LogicalJoin(condition=[true], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, BONUS]])
!transform ""
LogicalProject(ENAME=[$1])
  LogicalJoin(condition=[AND(=($1, $11), =($10, $12))], joinType=[inner], semiJoinDone=[true])
    LogicalJoin(condition=[AND(=($1, $11), =($10, $12))], joinType=[semi])
      LogicalJoin(condition=[=($7, $9)], joinType=[inner], semiJoinDone=[true])
        LogicalJoin(condition=[=($7, $9)], joinType=[semi])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
          LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
      LogicalTableScan(table=[[CATALOG, SALES, BONUS]])
    LogicalTableScan(table=[[CATALOG, SALES, BONUS]])
!transform "FILTER_INTO_JOIN, JOIN_ADD_REDUNDANT_SEMI_JOIN, SEMI_JOIN_JOIN_TRANSPOSE"

