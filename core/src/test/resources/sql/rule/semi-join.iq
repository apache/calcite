# testSemiJoinRuleExists -------------------------------------------------------
# PROJECT_TO_SEMI_JOIN converts a join from EXISTS to a semi-join.

select *
from dept
where exists (
  select *
  from emp
  where emp.deptno = dept.deptno
  and emp.sal > 100);
+--------+------------+----------+
| DEPTNO | DNAME      | LOC      |
+--------+------------+----------+
|     10 | ACCOUNTING | NEW YORK |
|     20 | RESEARCH   | DALLAS   |
|     30 | SALES      | CHICAGO  |
+--------+------------+----------+
(3 rows)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalProject(DEPTNO=[$7])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE"
LogicalJoin(condition=[=($0, $2)], joinType=[semi])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
  LogicalProject(DEPTNO=[$7])
    LogicalFilter(condition=[>($5, 100)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(expand=true, decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE, PROJECT_TO_SEMI_JOIN"

# testSemiJoinRuleFull ---------------------------------------------------------
# PROJECT_TO_SEMI_JOIN does not apply to FULL joins.

select dept.deptno, dept.dname
from dept
full join (
  select distinct deptno
  from emp
  where sal > 100) using (deptno);
+--------+------------+
| DEPTNO | DNAME      |
+--------+------------+
|     10 | ACCOUNTING |
|     20 | RESEARCH   |
|     30 | SALES      |
|     40 | OPERATIONS |
+--------+------------+
(4 rows)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[full])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalProject(DEPTNO=[$7])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE"
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[full])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalProject(DEPTNO=[$7])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE, PROJECT_TO_SEMI_JOIN"

# testSemiJoinRuleLeft ---------------------------------------------------------
# PROJECT_TO_SEMI_JOIN simplifies LEFT join to a plain scan when the result
# only uses the left side.

select dname
from dept
left join (
  select distinct deptno
  from emp
  where sal > 100) using (deptno);
+------------+
| DNAME      |
+------------+
| ACCOUNTING |
| OPERATIONS |
| RESEARCH   |
| SALES      |
+------------+
(4 rows)

!ok
LogicalProject(DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[left])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalProject(DEPTNO=[$7])
        LogicalFilter(condition=[>($5, 100)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "Sql2Rel(decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE"
LogicalProject(DNAME=[$1])
  LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "Sql2Rel(decorrelate=true, trim=true), FILTER_PROJECT_TRANSPOSE, FILTER_INTO_JOIN, PROJECT_MERGE, PROJECT_TO_SEMI_JOIN"

