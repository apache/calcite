#
# Tests the UNION_TO_VALUES rule (and related PROJECT_VALUES_MERGE rule).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testUnionToValuesByInList -----------------------------------------------------
# UNION_TO_VALUES merges a UNION ALL into a single VALUES node; with
# inSubQueryThreshold=0 an IN-list is converted to a join+aggregate+union.

with t1(a, y) as (
    select *
    from (values (1, 2), (3, null), (7369, null),
        (7499, 30), (null, 20), (null, 5)) as t1)
select *
from t1
where (t1.a, t1.y) in (
    (1, 2), (3, null), (7369, null),
    (7499, 30), (null, 20), (null, 5));
+------+----+
| A    | Y  |
+------+----+
|    1 |  2 |
| 7499 | 30 |
+------+----+
(2 rows)

!ok
LogicalProject(A=[$0], Y=[$1])
  LogicalJoin(condition=[AND(=($0, $2), =($1, $3))], joinType=[inner])
    LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
      LogicalValues(tuples=[[{ 1, 2 }, { 3, null }, { 7369, null }, { 7499, 30 }, { null, 20 }, { null, 5 }]])
    LogicalAggregate(group=[{0, 1}])
      LogicalUnion(all=[true])
        LogicalProject(EXPR$0=[3], EXPR$1=[null:INTEGER])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[7369], EXPR$1=[null:INTEGER])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[null:INTEGER], EXPR$1=[20])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[null:INTEGER], EXPR$1=[5])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalValues(tuples=[[{ 1, 2 }, { 7499, 30 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0"
LogicalProject(A=[$0], Y=[$1])
  LogicalJoin(condition=[AND(=($0, $2), =($1, $3))], joinType=[inner])
    LogicalValues(tuples=[[{ 1, 2 }, { 3, null }, { 7369, null }, { 7499, 30 }, { null, 20 }, { null, 5 }]])
    LogicalAggregate(group=[{0, 1}])
      LogicalValues(tuples=[[{ 3, null }, { 7369, null }, { null, 20 }, { null, 5 }, { 1, 2 }, { 7499, 30 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByInList2 ----------------------------------------------------
# UNION_TO_VALUES with IN-list containing CAST expressions.

with t1(a, y) as (
    select *
    from (values (1, 2), (3, null), (7369, null),
        (7499, 30), (null, 20), (null, 5)) as t1)
select *
from t1
where (t1.a, t1.y) in (
    (cast(1.1 as int), 2), (3, null), (7369, null),
    (7499, 30), (null, cast(20.2 as int)), (null, 5));
# Not using !ok: this test focuses on plan transformation (see !sub-plan).
LogicalProject(A=[$0], Y=[$1])
  LogicalJoin(condition=[AND(=($0, $2), =($1, $3))], joinType=[inner])
    LogicalProject(EXPR$0=[$0], EXPR$1=[$1])
      LogicalValues(tuples=[[{ 1, 2 }, { 3, null }, { 7369, null }, { 7499, 30 }, { null, 20 }, { null, 5 }]])
    LogicalAggregate(group=[{0, 1}])
      LogicalUnion(all=[true])
        LogicalProject(EXPR$0=[1], EXPR$1=[2])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[3], EXPR$1=[null:INTEGER])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[7369], EXPR$1=[null:INTEGER])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[null:INTEGER], EXPR$1=[20])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[null:INTEGER], EXPR$1=[5])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalValues(tuples=[[{ 7499, 30 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0"
LogicalProject(A=[$0], Y=[$1])
  LogicalJoin(condition=[AND(=($0, $2), =($1, $3))], joinType=[inner])
    LogicalValues(tuples=[[{ 1, 2 }, { 3, null }, { 7369, null }, { 7499, 30 }, { null, 20 }, { null, 5 }]])
    LogicalAggregate(group=[{0, 1}])
      LogicalValues(tuples=[[{ 1, 2 }, { 3, null }, { 7369, null }, { null, 20 }, { null, 5 }, { 7499, 30 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByInList3 ----------------------------------------------------
# UNION_TO_VALUES with IN-list containing an integer CAST.

select * from dept where deptno in (12, 34, cast(30.4 as int));
+--------+-------+---------+
| DEPTNO | DNAME | LOC     |
+--------+-------+---------+
|     30 | SALES | CHICAGO |
+--------+-------+---------+
(1 row)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalUnion(all=[true])
        LogicalProject(EXPR$0=[30])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalValues(tuples=[[{ 12 }, { 34 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0"
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($0, $2)], joinType=[inner])
    LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalValues(tuples=[[{ 30 }, { 12 }, { 34 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByInList4 ----------------------------------------------------
# UNION_TO_VALUES with IN-list of doubles (promotes comparison to double).

select *
from dept
where deptno in (12, 34, cast(56.4 as double));
+--------+-------+-----+
| DEPTNO | DNAME | LOC |
+--------+-------+-----+
+--------+-------+-----+
(0 rows)

!ok
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($2, $3)], joinType=[inner])
    LogicalProject(DEPTNO=[$0], DNAME=[$1], DEPTNO0=[CAST($0):DOUBLE NOT NULL])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalUnion(all=[true])
        LogicalProject(EXPR$0=[12.0E0:DOUBLE])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[34.0E0:DOUBLE])
          LogicalValues(tuples=[[{ 0 }]])
        LogicalProject(EXPR$0=[56.4E0:DOUBLE])
          LogicalValues(tuples=[[{ 0 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0"
LogicalProject(DEPTNO=[$0], DNAME=[$1])
  LogicalJoin(condition=[=($2, $3)], joinType=[inner])
    LogicalProject(DEPTNO=[$0], DNAME=[$1], DEPTNO0=[CAST($0):DOUBLE NOT NULL])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
    LogicalAggregate(group=[{0}])
      LogicalValues(tuples=[[{ 12.0E0 }, { 34.0E0 }, { 56.4E0 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByInList5 ----------------------------------------------------
# UNION_TO_VALUES with an IN predicate in the SELECT list.

select deptno in (12, 34, cast(56.4 as double)) as b from dept;
+-------+
| B     |
+-------+
| false |
| false |
| false |
| false |
+-------+
(4 rows)

!ok
LogicalProject(B=[CAST(OR(AND(IS NOT NULL($6), <>($2, 0)), AND(<($3, $2), null, <>($2, 0), IS NULL($6)))):BOOLEAN NOT NULL])
  LogicalJoin(condition=[=($4, $5)], joinType=[left])
    LogicalProject(DEPTNO=[$0], DNAME=[$1], $f0=[$2], $f1=[$3], DEPTNO0=[CAST($0):DOUBLE NOT NULL])
      LogicalJoin(condition=[true], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalAggregate(group=[{}], agg#0=[COUNT()], agg#1=[COUNT($0)])
          LogicalProject(EXPR$0=[$0], $f1=[true])
            LogicalUnion(all=[true])
              LogicalProject(EXPR$0=[12.0E0:DOUBLE])
                LogicalValues(tuples=[[{ 0 }]])
              LogicalProject(EXPR$0=[34.0E0:DOUBLE])
                LogicalValues(tuples=[[{ 0 }]])
              LogicalProject(EXPR$0=[56.4E0:DOUBLE])
                LogicalValues(tuples=[[{ 0 }]])
    LogicalAggregate(group=[{0}], agg#0=[MIN($1)])
      LogicalProject(EXPR$0=[$0], $f1=[true])
        LogicalUnion(all=[true])
          LogicalProject(EXPR$0=[12.0E0:DOUBLE])
            LogicalValues(tuples=[[{ 0 }]])
          LogicalProject(EXPR$0=[34.0E0:DOUBLE])
            LogicalValues(tuples=[[{ 0 }]])
          LogicalProject(EXPR$0=[56.4E0:DOUBLE])
            LogicalValues(tuples=[[{ 0 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0"
LogicalProject(B=[CAST(OR(AND(IS NOT NULL($6), <>($2, 0)), AND(<($3, $2), null, <>($2, 0), IS NULL($6)))):BOOLEAN NOT NULL])
  LogicalJoin(condition=[=($4, $5)], joinType=[left])
    LogicalProject(DEPTNO=[$0], DNAME=[$1], $f0=[$2], $f1=[$3], DEPTNO0=[CAST($0):DOUBLE NOT NULL])
      LogicalJoin(condition=[true], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
        LogicalAggregate(group=[{}], agg#0=[COUNT()], agg#1=[COUNT($0)])
          LogicalProject(EXPR$0=[$0], $f1=[true])
            LogicalValues(tuples=[[{ 12.0E0 }, { 34.0E0 }, { 56.4E0 }]])
    LogicalAggregate(group=[{0}], agg#0=[MIN($1)])
      LogicalProject(EXPR$0=[$0], $f1=[true])
        LogicalValues(tuples=[[{ 12.0E0 }, { 34.0E0 }, { 56.4E0 }]])
!sub-plan "expand=true, simplifyValues=false, inSubQueryThreshold=0, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByUnion ------------------------------------------------------
# UNION_TO_VALUES collapses UNION (distinct) of two VALUES into one VALUES.

select *
from (values (1, 'a'), (2, 'b')) as t(x, y)
union
select *
from (values (1, 'a'), (2, 'b'), (1, 'b'), (2, 'c'), (2, 'c')) as t(x, y);
+---+---+
| X | Y |
+---+---+
| 1 | a |
| 1 | b |
| 2 | b |
| 2 | c |
+---+---+
(4 rows)

!ok
LogicalUnion(all=[false])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }]])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'b' }, { 2, 'c' }, { 2, 'c' }]])
!sub-plan ""
LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'b' }, { 2, 'c' }]])
!sub-plan "PROJECT_REMOVE, UNION_TO_VALUES"

# testUnionToValuesByUnion2 -----------------------------------------------------
# UNION_TO_VALUES collapses UNION (distinct) of two single-column VALUES.

select *
from (values ('a'), ('b')) as t(x)
union
select *
from (values ('a'), ('b'), ('b'), ('c'), ('c')) as t(y);
+---+
| X |
+---+
| a |
| b |
| c |
+---+
(3 rows)

!ok
LogicalUnion(all=[false])
  LogicalProject(X=[$0])
    LogicalValues(tuples=[[{ 'a' }, { 'b' }]])
  LogicalProject(Y=[$0])
    LogicalValues(tuples=[[{ 'a' }, { 'b' }, { 'b' }, { 'c' }, { 'c' }]])
!sub-plan ""
LogicalValues(tuples=[[{ 'a' }, { 'b' }, { 'c' }]])
!sub-plan "PROJECT_REMOVE, UNION_TO_VALUES"

# testUnionToValuesByUnion3 -----------------------------------------------------
# UNION_TO_VALUES collapses UNION (distinct) of DECIMAL and INTEGER VALUES.

select *
from (values (5.0)) as t(x)
union
select *
from (values (5)) as t(y);
+-----+
| X   |
+-----+
| 5.0 |
+-----+
(1 row)

!ok
LogicalUnion(all=[false])
  LogicalProject(X=[CAST($0):DECIMAL(11, 1) NOT NULL])
    LogicalValues(tuples=[[{ 5.0 }]])
  LogicalProject(Y=[CAST($0):DECIMAL(11, 1) NOT NULL])
    LogicalValues(tuples=[[{ 5 }]])
!sub-plan ""
LogicalValues(tuples=[[{ 5.0 }]])
!sub-plan "PROJECT_REMOVE, PROJECT_VALUES_MERGE, UNION_TO_VALUES"

# testUnionToValuesByUnion4 -----------------------------------------------------
# UNION_TO_VALUES collapses UNION (distinct) when both inputs have same type.

select *
from (values (cast(5.0 as int))) as t(x)
union
select *
from (values (5)) as t(y);
+---+
| X |
+---+
| 5 |
+---+
(1 row)

!ok
LogicalUnion(all=[false])
  LogicalProject(X=[$0])
    LogicalValues(tuples=[[{ 5 }]])
  LogicalProject(Y=[$0])
    LogicalValues(tuples=[[{ 5 }]])
!sub-plan ""
LogicalValues(tuples=[[{ 5 }]])
!sub-plan "PROJECT_REMOVE, UNION_TO_VALUES"

# testUnionToValuesByUnionAll ---------------------------------------------------
# UNION_TO_VALUES collapses UNION ALL of two VALUES into one VALUES.

select *
from (values (1, 'a'), (2, 'b')) as t(x, y)
union all
select *
from (values (1, 'a'), (2, 'b'), (1, 'b'), (2, 'c'), (2, 'c')) as t(x, y);
+---+---+
| X | Y |
+---+---+
| 1 | a |
| 1 | a |
| 1 | b |
| 2 | b |
| 2 | b |
| 2 | c |
| 2 | c |
+---+---+
(7 rows)

!ok
LogicalUnion(all=[true])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }]])
  LogicalProject(X=[$0], Y=[$1])
    LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'b' }, { 2, 'c' }, { 2, 'c' }]])
!sub-plan ""
LogicalValues(tuples=[[{ 1, 'a' }, { 2, 'b' }, { 1, 'a' }, { 2, 'b' }, { 1, 'b' }, { 2, 'c' }, { 2, 'c' }]])
!sub-plan "PROJECT_REMOVE, UNION_TO_VALUES"

