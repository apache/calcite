      LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {}]], $g=[GROUPING($0, $1)])
        LogicalProject(C=[>($5, 1000)], D=[<($5, 500)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
