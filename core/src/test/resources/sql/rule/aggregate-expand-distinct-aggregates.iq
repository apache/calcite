LogicalAggregate(group=[{0}], C=[COUNT()], S=[SUM(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], C=[$SUM0($2)], S=[SUM($1)])
  LogicalAggregate(group=[{0, 1}], C=[COUNT()])
    LogicalProject(DEPTNO=[$7], SAL=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

# testDistinctNonDistinctAggregatesWithGroupingSets ----------------------------
# [CALCITE-5465] Rule of AGGREGATE_EXPAND_DISTINCT_AGGREGATES produces an
# incorrect plan when sql has distinct agg-call with rollup.

SELECT deptno, COUNT(DISTINCT sal) as c
FROM emp
GROUP BY ROLLUP(deptno);
+--------+----+
| DEPTNO | C  |
+--------+----+
|     10 |  3 |
|     20 |  4 |
|     30 |  5 |
|        | 12 |
+--------+----+
(4 rows)

!ok
LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C=[CAST(CASE(=($5, 0), $1, =($5, 1), $2, null:BIGINT)):BIGINT NOT NULL])
  LogicalFilter(condition=[OR(AND(=($5, 0), >($3, 0)), =($5, 1))])
    LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C_g0=[COUNT($1) FILTER $2], C_g1=[COUNT($1) FILTER $4], $g_present_0=[COUNT() FILTER $3], $g_present_1=[COUNT() FILTER $5], $g_final=[GROUPING($0)])
      LogicalProject(DEPTNO=[$0], SAL=[$1], $g_0=[=($2, 0)], $g_1=[=($2, 1)], $g_2=[=($2, 2)], $g_3=[=($2, 3)])
        LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {1}, {}]], $g=[GROUPING($0, $1)])
          LogicalProject(DEPTNO=[$7], SAL=[$5])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctNonDistinctAggregatesWithGroupingSets2 ---------------------------
# [CALCITE-5465] Rule of AGGREGATE_EXPAND_DISTINCT_AGGREGATES produces an
# incorrect plan when sql has distinct agg-call with rollup (with SUM).

SELECT deptno, COUNT(DISTINCT sal) as c, SUM(sal) as s
FROM emp
GROUP BY GROUPING SETS ((deptno), ());
+--------+----+----------+
| DEPTNO | C  | S        |
+--------+----+----------+
|     10 |  3 |  8750.00 |
|     20 |  4 | 10875.00 |
|     30 |  5 |  9400.00 |
|        | 12 | 29025.00 |
+--------+----+----------+
(4 rows)

!ok
LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C=[COUNT(DISTINCT $1)], S=[SUM($1)])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C=[CAST(CASE(=($7, 0), $1, =($7, 1), $2, null:BIGINT)):BIGINT NOT NULL], S=[CASE(=($7, 0), $3, =($7, 1), $4, null:INTEGER)])
  LogicalFilter(condition=[OR(AND(=($7, 0), >($5, 0)), =($7, 1))])
    LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C_g0=[COUNT($1) FILTER $3], C_g1=[COUNT($1) FILTER $5], S_g0=[MIN($2) FILTER $4], S_g1=[MIN($2) FILTER $6], $g_present_0=[COUNT() FILTER $4], $g_present_1=[COUNT() FILTER $6], $g_final=[GROUPING($0)])
      LogicalProject(DEPTNO=[$0], SAL=[$1], S=[$2], $g_0=[=($3, 0)], $g_1=[=($3, 1)], $g_2=[=($3, 2)], $g_3=[=($3, 3)])
        LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {1}, {}]], S=[SUM($1)], $g=[GROUPING($0, $1)])
          LogicalProject(DEPTNO=[$7], SAL=[$5])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctNonDistinctAggregatesWithGroupingSets3 ---------------------------
# [CALCITE-5465] Rule of AGGREGATE_EXPAND_DISTINCT_AGGREGATES produces an
# incorrect plan when sql has distinct agg-call with rollup (with COUNT(*)).

SELECT deptno, COUNT(DISTINCT sal) as c1, SUM(DISTINCT sal) as s, COUNT(*) as c2
FROM emp
GROUP BY GROUPING SETS ((deptno), ());
+--------+----+----------+----+
| DEPTNO | C1 | S        | C2 |
+--------+----+----------+----+
|     10 |  3 |  8750.00 |  3 |
|     20 |  4 |  7875.00 |  5 |
|     30 |  5 |  8150.00 |  6 |
|        | 12 | 24775.00 | 14 |
+--------+----+----------+----+
(4 rows)

!ok
LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C1=[COUNT(DISTINCT $1)], S=[SUM(DISTINCT $1)], C2=[COUNT()])
  LogicalProject(DEPTNO=[$7], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C1=[CAST(CASE(=($9, 0), $1, =($9, 1), $2, null:BIGINT)):BIGINT NOT NULL], S=[CASE(=($9, 0), $3, =($9, 1), $4, null:INTEGER)], C2=[CAST(CASE(=($9, 0), $5, =($9, 1), $6, null:BIGINT)):BIGINT NOT NULL])
  LogicalFilter(condition=[OR(AND(=($9, 0), >($7, 0)), =($9, 1))])
    LogicalAggregate(group=[{0}], groups=[[{0}, {}]], C1_g0=[COUNT($1) FILTER $3], C1_g1=[COUNT($1) FILTER $5], S_g0=[SUM($1) FILTER $3], S_g1=[SUM($1) FILTER $5], C2_g0=[MIN($2) FILTER $4], C2_g1=[MIN($2) FILTER $6], $g_present_0=[COUNT() FILTER $4], $g_present_1=[COUNT() FILTER $6], $g_final=[GROUPING($0)])
      LogicalProject(DEPTNO=[$0], SAL=[$1], C2=[$2], $g_0=[=($3, 0)], $g_1=[=($3, 1)], $g_2=[=($3, 2)], $g_3=[=($3, 3)])
        LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {1}, {}]], C2=[COUNT()], $g=[GROUPING($0, $1)])
          LogicalProject(DEPTNO=[$7], SAL=[$5])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctNonDistinctTwoAggregatesWithGrouping -----------------------------
# Tests expansion when two non-distinct aggregates (SUM, MIN) accompany
# a DISTINCT SUM on a different column.

SELECT deptno, SUM(comm) as s1, MIN(comm) as n, SUM(DISTINCT sal) as s2
FROM emp
GROUP BY deptno;
+--------+---------+------+---------+
| DEPTNO | S1      | N    | S2      |
+--------+---------+------+---------+
|     10 |         |      | 8750.00 |
|     20 |         |      | 7875.00 |
|     30 | 2200.00 | 0.00 | 8150.00 |
+--------+---------+------+---------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], S1=[SUM($1)], N=[MIN($1)], S2=[SUM(DISTINCT $2)])
  LogicalProject(DEPTNO=[$7], COMM=[$6], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], S1=[SUM($2)], N=[MIN($3)], S2=[SUM($1)])
  LogicalAggregate(group=[{0, 2}], S1=[SUM($1)], N=[MIN($1)])
    LogicalProject(DEPTNO=[$7], COMM=[$6], SAL=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

# testDistinctWithDiffFiltersAndSameGroupSet -----------------------------------
# Tests expansion of DISTINCT aggregates with different FILTER conditions
# but the same group set.

SELECT COUNT(DISTINCT c) FILTER (WHERE d) as c1,
  COUNT(DISTINCT d) FILTER (WHERE c) as c2
FROM (select sal > 1000 is true as c, sal < 500 is true as d, comm
  from emp);
+----+----+
| C1 | C2 |
+----+----+
|  0 |  1 |
+----+----+
(1 row)

!ok
LogicalAggregate(group=[{}], C1=[COUNT(DISTINCT $0) FILTER $1], C2=[COUNT(DISTINCT $1) FILTER $0])
  LogicalProject(C=[>($5, 1000)], D=[<($5, 500)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(C1=[$0], C2=[$1])
  LogicalAggregate(group=[{}], C1_g0=[COUNT($0) FILTER $3], C2_g0=[COUNT($1) FILTER $2])
    LogicalProject(C=[$0], D=[$1], $g_0_f_0=[AND(=($2, 0), IS TRUE($0))], $g_0_f_1=[AND(=($2, 0), IS TRUE($1))])
      LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {}]], $g=[GROUPING($0, $1)])
        LogicalProject(C=[>($5, 1000)], D=[<($5, 500)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctWithFilterAndGroupBy ---------------------------------------------
# Tests expansion of COUNT(DISTINCT) with a FILTER clause alongside a
# non-distinct SUM in a group-by query.

SELECT deptno, SUM(comm) as s, COUNT(DISTINCT sal) FILTER (WHERE sal > 1000) as c
FROM emp
GROUP BY deptno;
+--------+---------+---+
| DEPTNO | S       | C |
+--------+---------+---+
|     10 |         | 3 |
|     20 |         | 3 |
|     30 | 2200.00 | 4 |
+--------+---------+---+
(3 rows)

!ok
LogicalAggregate(group=[{0}], S=[SUM($1)], C=[COUNT(DISTINCT $2) FILTER $3])
  LogicalProject(DEPTNO=[$7], COMM=[$6], SAL=[$5], $f3=[>($5, 1000)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], S=[CAST($1):INTEGER NOT NULL], C=[$2])
  LogicalAggregate(group=[{0}], S_g0=[MIN($2) FILTER $4], C_g0=[COUNT($1) FILTER $3])
    LogicalProject(DEPTNO=[$0], SAL=[$1], S=[$3], $g_0_f_2=[AND(=($4, 0), IS TRUE($2))], $g_3=[=($4, 3)])
      LogicalAggregate(group=[{0, 2, 3}], groups=[[{0, 2, 3}, {0}]], S=[SUM($1)], $g=[GROUPING($0, $2, $3)])
        LogicalProject(DEPTNO=[$7], COMM=[$6], SAL=[$5], $f3=[>($5, 1000)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctWithFilterWithoutGroupBy -----------------------------------------
