#
# Tests planner rules that expand DISTINCT aggregates (AggregateExpandDistinctAggregatesRule).
#
# Ensure that tests occur in alphabetical order:
# // lint: sort where '^[#] test'
#

!use scott
!set outputformat mysql

# testBitAndReuseDistinctAttrWithMixedOptionality ------------------------------
# Tests that BIT_AND (non-distinct) can share the inner aggregate with
# DISTINCT agg-calls on the same column.

select sum(distinct deptno) as s, count(distinct deptno) as c, bit_and(deptno) as ba
from emp;
+----+---+----+
| S  | C | BA |
+----+---+----+
| 60 | 3 |  0 |
+----+---+----+
(1 row)

!ok
LogicalAggregate(group=[{}], S=[SUM(DISTINCT $0)], C=[COUNT(DISTINCT $0)], BA=[BIT_AND($0)])
  LogicalProject(DEPTNO=[$7])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{}], S=[SUM($0)], C=[COUNT($0)], BA=[BIT_AND($0)])
  LogicalAggregate(group=[{0}])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testBitOrReuseDistinctAttrWithMixedOptionality -------------------------------
# Tests that BIT_OR (non-distinct) can share the inner aggregate with
# DISTINCT agg-calls on the same column.

select sum(distinct deptno) as s, count(distinct deptno) as c, bit_or(deptno) as bo
from emp;
+----+---+----+
| S  | C | BO |
+----+---+----+
| 60 | 3 | 30 |
+----+---+----+
(1 row)

!ok
LogicalAggregate(group=[{}], S=[SUM(DISTINCT $0)], C=[COUNT(DISTINCT $0)], BO=[BIT_OR($0)])
  LogicalProject(DEPTNO=[$7])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{}], S=[SUM($0)], C=[COUNT($0)], BO=[BIT_OR($0)])
  LogicalAggregate(group=[{0}])
    LogicalProject(DEPTNO=[$7])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testCastInAggregateExpandDistinctAggregatesRule ------------------------------
# [CALCITE-1621] Adding a cast around the null literal in aggregate rules.

select dname, sum(distinct cn) as s1, sum(distinct sm) as s2
from (
  select dname, count(dept.deptno) as cn,sum(dept.deptno) as sm
  from dept group by dname)
group by dname;
+------------+----+----+
| DNAME      | S1 | S2 |
+------------+----+----+
| ACCOUNTING |  1 | 10 |
| OPERATIONS |  1 | 40 |
| RESEARCH   |  1 | 20 |
| SALES      |  1 | 30 |
+------------+----+----+
(4 rows)

!ok
LogicalAggregate(group=[{0}], S1=[SUM(DISTINCT $1)], S2=[SUM(DISTINCT $2)])
  LogicalAggregate(group=[{0}], CN=[COUNT()], SM=[SUM($1)])
    LogicalProject(DNAME=[$1], DEPTNO=[$0])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalProject(DNAME=[$0], S1=[CAST($1):BIGINT NOT NULL], S2=[CAST($2):INTEGER NOT NULL])
  LogicalAggregate(group=[{0}], S1_g0=[SUM($1) FILTER $3], S2_g0=[SUM($2) FILTER $4])
    LogicalProject(DNAME=[$0], CN=[$1], SM=[$2], $g_1=[=($3, 1)], $g_2=[=($3, 2)])
      LogicalAggregate(group=[{0, 1, 2}], groups=[[{0, 1}, {0, 2}, {0}]], $g=[GROUPING($0, $1, $2)])
        LogicalAggregate(group=[{0}], CN=[COUNT()], SM=[SUM($1)])
          LogicalProject(DNAME=[$1], DEPTNO=[$0])
            LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctCount1 -----------------------------------------------------------
# Tests expansion of COUNT(DISTINCT) in a group-by query without non-distinct
# aggregates.

select deptno, count(distinct ename) as c
from emp group by deptno;
+--------+---+
| DEPTNO | C |
+--------+---+
|     10 | 3 |
|     20 | 5 |
|     30 | 6 |
+--------+---+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{1}], C=[COUNT($0)])
  LogicalAggregate(group=[{1, 7}])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE"

# testDistinctCount2 -----------------------------------------------------------
# Tests expansion of COUNT(DISTINCT) alongside a non-distinct SUM in a
# group-by query.

select deptno, count(distinct ename) as c, sum(sal) as s
from emp group by deptno;
+--------+---+----------+
| DEPTNO | C | S        |
+--------+---+----------+
|     10 | 3 |  8750.00 |
|     20 | 5 | 10875.00 |
|     30 | 6 |  9400.00 |
+--------+---+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C=[COUNT(DISTINCT $1)], S=[SUM($2)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C=[$1], S=[CAST($2):INTEGER NOT NULL])
  LogicalAggregate(group=[{0}], C_g0=[COUNT($1) FILTER $3], S_g0=[MIN($2) FILTER $4])
    LogicalProject(DEPTNO=[$0], ENAME=[$1], S=[$2], $g_0=[=($3, 0)], $g_1=[=($3, 1)])
      LogicalProject(DEPTNO=[$1], ENAME=[$0], S=[$2], $g=[$3])
        LogicalAggregate(group=[{1, 7}], groups=[[{1, 7}, {7}]], S=[SUM($5)], $g=[GROUPING($7, $1)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE"

# testDistinctCount3 -----------------------------------------------------------
# Tests expansion of COUNT(DISTINCT) with a non-distinct SUM in a group-by query.
# [CALCITE-1293]

select count(distinct deptno) as c, sum(sal) as s
from emp
group by deptno;
+---+----------+
| C | S        |
+---+----------+
| 1 | 10875.00 |
| 1 |  8750.00 |
| 1 |  9400.00 |
+---+----------+
(3 rows)

!ok
LogicalProject(C=[$1], S=[$2])
  LogicalAggregate(group=[{0}], C=[COUNT(DISTINCT $0)], S=[SUM($1)])
    LogicalProject(DEPTNO=[$7], SAL=[$5])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(C=[$1], S=[$2])
  LogicalProject(DEPTNO=[$0], C=[$1], S=[CAST($2):INTEGER NOT NULL])
    LogicalAggregate(group=[{0}], C_g0=[COUNT($0) FILTER $2], S_g0=[MIN($1) FILTER $2])
      LogicalProject(DEPTNO=[$0], S=[$1], $g_0=[=($2, 0)])
        LogicalAggregate(group=[{0}], S=[SUM($1)], $g=[GROUPING($0)])
          LogicalProject(DEPTNO=[$7], SAL=[$5])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctCountGroupingSets1 -----------------------------------------------
# Tests expansion of COUNT(DISTINCT) with ROLLUP grouping sets.

select deptno, job, count(distinct ename) as c
from emp group by rollup(deptno, job);
+--------+-----------+----+
| DEPTNO | JOB       | C  |
+--------+-----------+----+
|     10 | CLERK     |  1 |
|     10 | MANAGER   |  1 |
|     10 | PRESIDENT |  1 |
|     10 |           |  3 |
|     20 | ANALYST   |  2 |
|     20 | CLERK     |  2 |
|     20 | MANAGER   |  1 |
|     20 |           |  5 |
|     30 | CLERK     |  1 |
|     30 | MANAGER   |  1 |
|     30 | SALESMAN  |  4 |
|     30 |           |  6 |
|        |           | 14 |
+--------+-----------+----+
(13 rows)

!ok
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], C=[COUNT(DISTINCT $2)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], ENAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], JOB=[$1], C=[CAST(CASE(=($8, 0), $2, =($8, 1), $3, =($8, 3), $4, null:BIGINT)):BIGINT NOT NULL])
  LogicalFilter(condition=[OR(AND(=($8, 0), >($5, 0)), AND(=($8, 1), >($6, 0)), =($8, 3))])
    LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], C_g0=[COUNT($2) FILTER $3], C_g1=[COUNT($2) FILTER $5], C_g2=[COUNT($2) FILTER $7], $g_present_0=[COUNT() FILTER $4], $g_present_1=[COUNT() FILTER $6], $g_present_2=[COUNT() FILTER $8], $g_final=[GROUPING($0, $1)])
      LogicalProject(DEPTNO=[$0], JOB=[$1], ENAME=[$2], $g_0=[=($3, 0)], $g_1=[=($3, 1)], $g_2=[=($3, 2)], $g_3=[=($3, 3)], $g_6=[=($3, 6)], $g_7=[=($3, 7)])
        LogicalAggregate(group=[{0, 1, 2}], groups=[[{0, 1, 2}, {0, 1}, {0, 2}, {0}, {2}, {}]], $g=[GROUPING($0, $1, $2)])
          LogicalProject(DEPTNO=[$7], JOB=[$2], ENAME=[$1])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, PROJECT_MERGE"

# testDistinctCountGroupingSets2 -----------------------------------------------
# Tests expansion of COUNT(DISTINCT) and SUM with ROLLUP grouping sets.

select deptno, job, count(distinct ename) as c, sum(sal) as s
from emp group by rollup(deptno, job);
+--------+-----------+----+----------+
| DEPTNO | JOB       | C  | S        |
+--------+-----------+----+----------+
|     10 | CLERK     |  1 |  1300.00 |
|     10 | MANAGER   |  1 |  2450.00 |
|     10 | PRESIDENT |  1 |  5000.00 |
|     10 |           |  3 |  8750.00 |
|     20 | ANALYST   |  2 |  6000.00 |
|     20 | CLERK     |  2 |  1900.00 |
|     20 | MANAGER   |  1 |  2975.00 |
|     20 |           |  5 | 10875.00 |
|     30 | CLERK     |  1 |   950.00 |
|     30 | MANAGER   |  1 |  2850.00 |
|     30 | SALESMAN  |  4 |  5600.00 |
|     30 |           |  6 |  9400.00 |
|        |           | 14 | 29025.00 |
+--------+-----------+----+----------+
(13 rows)

!ok
LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], C=[COUNT(DISTINCT $2)], S=[SUM($3)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], ENAME=[$1], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], JOB=[$1], C=[CAST(CASE(=($11, 0), $2, =($11, 1), $3, =($11, 3), $4, null:BIGINT)):BIGINT NOT NULL], S=[CASE(=($11, 0), $5, =($11, 1), $6, =($11, 3), $7, null:INTEGER)])
  LogicalFilter(condition=[OR(AND(=($11, 0), >($8, 0)), AND(=($11, 1), >($9, 0)), =($11, 3))])
    LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}, {}]], C_g0=[COUNT($2) FILTER $4], C_g1=[COUNT($2) FILTER $6], C_g2=[COUNT($2) FILTER $8], S_g0=[MIN($3) FILTER $5], S_g1=[MIN($3) FILTER $7], S_g2=[MIN($3) FILTER $9], $g_present_0=[COUNT() FILTER $5], $g_present_1=[COUNT() FILTER $7], $g_present_2=[COUNT() FILTER $9], $g_final=[GROUPING($0, $1)])
      LogicalProject(DEPTNO=[$0], JOB=[$1], ENAME=[$2], S=[$3], $g_0=[=($4, 0)], $g_1=[=($4, 1)], $g_2=[=($4, 2)], $g_3=[=($4, 3)], $g_6=[=($4, 6)], $g_7=[=($4, 7)])
        LogicalAggregate(group=[{0, 1, 2}], groups=[[{0, 1, 2}, {0, 1}, {0, 2}, {0}, {2}, {}]], S=[SUM($3)], $g=[GROUPING($0, $1, $2)])
          LogicalProject(DEPTNO=[$7], JOB=[$2], ENAME=[$1], SAL=[$5])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, PROJECT_MERGE"

# testDistinctCountMixed -------------------------------------------------------
# Tests expansion of COUNT(DISTINCT) with multiple group-key args alongside
# a non-distinct SUM.

select deptno, count(distinct deptno, job) as cddj,
  sum(sal) as s
from emp group by deptno;
+--------+------+----------+
| DEPTNO | CDDJ | S        |
+--------+------+----------+
|     10 |    3 |  8750.00 |
|     20 |    3 | 10875.00 |
|     30 |    3 |  9400.00 |
+--------+------+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], CDDJ=[COUNT(DISTINCT $0, $1)], S=[SUM($2)])
  LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], CDDJ=[$1], S=[CAST($2):INTEGER NOT NULL])
  LogicalAggregate(group=[{0}], CDDJ_g0=[COUNT($0, $1) FILTER $3], S_g0=[MIN($2) FILTER $4])
    LogicalProject(DEPTNO=[$0], JOB=[$1], S=[$2], $g_0=[=($3, 0)], $g_1=[=($3, 1)])
      LogicalAggregate(group=[{0, 1}], groups=[[{0, 1}, {0}]], S=[SUM($2)], $g=[GROUPING($0, $1)])
        LogicalProject(DEPTNO=[$7], JOB=[$2], SAL=[$5])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, PROJECT_MERGE"

# testDistinctCountMixed2 ------------------------------------------------------
# Tests expansion of multiple COUNT(DISTINCT) calls with different arg sets
# alongside a non-distinct SUM.

select deptno, count(distinct ename) as cde,
count(distinct job, ename) as cdje,
count(distinct deptno, job) as cddj,
sum(sal) as s
from emp group by deptno;
+--------+-----+------+------+----------+
| DEPTNO | CDE | CDJE | CDDJ | S        |
+--------+-----+------+------+----------+
|     10 |   3 |    3 |    3 |  8750.00 |
|     20 |   5 |    5 |    3 | 10875.00 |
|     30 |   6 |    6 |    3 |  9400.00 |
+--------+-----+------+------+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], CDE=[COUNT(DISTINCT $1)], CDJE=[COUNT(DISTINCT $2, $1)], CDDJ=[COUNT(DISTINCT $0, $2)], S=[SUM($3)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], JOB=[$2], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], CDE=[$1], CDJE=[$2], CDDJ=[$3], S=[CAST($4):INTEGER NOT NULL])
  LogicalAggregate(group=[{0}], CDE_g0=[COUNT($1) FILTER $5], CDJE_g0=[COUNT($2, $1) FILTER $4], CDDJ_g0=[COUNT($0, $2) FILTER $6], S_g0=[MIN($3) FILTER $7])
    LogicalProject(DEPTNO=[$2], ENAME=[$0], JOB=[$1], S=[$3], $g_0=[=($4, 0)], $g_1=[=($4, 1)], $g_2=[=($4, 2)], $g_3=[=($4, 3)])
      LogicalAggregate(group=[{1, 2, 7}], groups=[[{1, 2, 7}, {1, 7}, {2, 7}, {7}]], S=[SUM($5)], $g=[GROUPING($7, $1, $2)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE, PROJECT_MERGE"

# testDistinctCountMixedJoin ---------------------------------------------------
# Tests expansion of multiple COUNT(DISTINCT) calls using the join strategy.

select deptno, count(distinct ename) as c1, count(distinct job, ename) as c2,
count(distinct deptno, job) as c3, sum(sal) as s
from emp group by deptno;
+--------+----+----+----+----------+
| DEPTNO | C1 | C2 | C3 | S        |
+--------+----+----+----+----------+
|     10 |  3 |  3 |  3 |  8750.00 |
|     20 |  5 |  5 |  3 | 10875.00 |
|     30 |  6 |  6 |  3 |  9400.00 |
+--------+----+----+----+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C1=[COUNT(DISTINCT $1)], C2=[COUNT(DISTINCT $2, $1)], C3=[COUNT(DISTINCT $0, $2)], S=[SUM($3)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], JOB=[$2], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C1=[$3], C2=[$5], C3=[$7], S=[$1])
  LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $6)], joinType=[inner])
    LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $4)], joinType=[inner])
      LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $2)], joinType=[inner])
        LogicalAggregate(group=[{7}], S=[SUM($5)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalAggregate(group=[{1}], C1=[COUNT($0)])
          LogicalAggregate(group=[{1, 7}])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalAggregate(group=[{2}], C2=[COUNT($1, $0)])
        LogicalAggregate(group=[{1, 2, 7}])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{1}], C3=[COUNT($1, $0)])
      LogicalAggregate(group=[{2, 7}])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN, AGGREGATE_PROJECT_MERGE"

# testDistinctCountMultiple ----------------------------------------------------
# Tests expansion of two COUNT(DISTINCT) calls on different columns using
# GROUPING SETS.

select deptno, count(distinct ename) as c1,
  count(distinct job) as c2
from emp group by deptno;
+--------+----+----+
| DEPTNO | C1 | C2 |
+--------+----+----+
|     10 |  3 |  3 |
|     20 |  5 |  3 |
|     30 |  6 |  3 |
+--------+----+----+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C1=[COUNT(DISTINCT $1)], C2=[COUNT(DISTINCT $2)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], JOB=[$2])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C1=[$1], C2=[$2])
  LogicalAggregate(group=[{0}], C1_g0=[COUNT($1) FILTER $3], C2_g0=[COUNT($2) FILTER $4])
    LogicalProject(DEPTNO=[$0], ENAME=[$1], JOB=[$2], $g_1=[=($3, 1)], $g_2=[=($3, 2)])
      LogicalProject(DEPTNO=[$2], ENAME=[$0], JOB=[$1], $g=[$3])
        LogicalAggregate(group=[{1, 2, 7}], groups=[[{1, 7}, {2, 7}, {7}]], $g=[GROUPING($7, $1, $2)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE"

# testDistinctCountMultipleNoGroup ---------------------------------------------
# Tests expansion of two COUNT(DISTINCT) calls on different columns with no
# GROUP BY.

select count(distinct ename) as c1, count(distinct job) as c2
from emp;
+----+----+
| C1 | C2 |
+----+----+
| 14 |  5 |
+----+----+
(1 row)

!ok
LogicalAggregate(group=[{}], C1=[COUNT(DISTINCT $0)], C2=[COUNT(DISTINCT $1)])
  LogicalProject(ENAME=[$1], JOB=[$2])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(C1=[$0], C2=[$1])
  LogicalAggregate(group=[{}], C1_g0=[COUNT($0) FILTER $2], C2_g0=[COUNT($1) FILTER $3])
    LogicalProject(ENAME=[$0], JOB=[$1], $g_1=[=($2, 1)], $g_2=[=($2, 2)])
      LogicalAggregate(group=[{1, 2}], groups=[[{1}, {2}, {}]], $g=[GROUPING($1, $2)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE"

# testDistinctCountMultipleViaJoin ---------------------------------------------
# Tests expansion of multiple COUNT(DISTINCT) calls using the join strategy.

select deptno, count(distinct ename) as c1,
  count(distinct job, ename) as c2,
  count(distinct deptno, job) as c3, sum(sal) as s
from emp group by deptno;
+--------+----+----+----+----------+
| DEPTNO | C1 | C2 | C3 | S        |
+--------+----+----+----+----------+
|     10 |  3 |  3 |  3 |  8750.00 |
|     20 |  5 |  5 |  3 | 10875.00 |
|     30 |  6 |  6 |  3 |  9400.00 |
+--------+----+----+----+----------+
(3 rows)

!ok
LogicalAggregate(group=[{0}], C1=[COUNT(DISTINCT $1)], C2=[COUNT(DISTINCT $2, $1)], C3=[COUNT(DISTINCT $0, $2)], S=[SUM($3)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1], JOB=[$2], SAL=[$5])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(DEPTNO=[$0], C1=[$3], C2=[$5], C3=[$7], S=[$1])
  LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $6)], joinType=[inner])
    LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $4)], joinType=[inner])
      LogicalJoin(condition=[IS NOT DISTINCT FROM($0, $2)], joinType=[inner])
        LogicalAggregate(group=[{7}], S=[SUM($5)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalAggregate(group=[{1}], C1=[COUNT($0)])
          LogicalAggregate(group=[{1, 7}])
            LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalAggregate(group=[{2}], C2=[COUNT($1, $0)])
        LogicalAggregate(group=[{1, 2, 7}])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
    LogicalAggregate(group=[{1}], C3=[COUNT($1, $0)])
      LogicalAggregate(group=[{2, 7}])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN, AGGREGATE_PROJECT_MERGE"

# testDistinctCountWithoutGroupBy ----------------------------------------------
# Tests expansion of COUNT(DISTINCT) alongside a non-distinct MAX with no
# GROUP BY.

select max(deptno) as m, count(distinct ename) as c
from emp;
+----+----+
| M  | C  |
+----+----+
| 30 | 14 |
+----+----+
(1 row)

!ok
LogicalAggregate(group=[{}], M=[MAX($0)], C=[COUNT(DISTINCT $1)])
  LogicalProject(DEPTNO=[$7], ENAME=[$1])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(M=[$0], C=[$1])
  LogicalAggregate(group=[{}], M_g0=[MIN($1) FILTER $3], C_g0=[COUNT($0) FILTER $2])
    LogicalProject(ENAME=[$0], M=[$1], $g_0=[=($2, 0)], $g_1=[=($2, 1)])
      LogicalAggregate(group=[{1}], groups=[[{1}, {}]], M=[MAX($7)], $g=[GROUPING($1)])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES, AGGREGATE_PROJECT_MERGE"

# testDistinctNonDistinctAggregates --------------------------------------------
# Tests expansion of a DISTINCT AVG alongside a non-distinct COUNT(*).

select emp.empno, count(*) as c, avg(distinct dept.deptno) as a
from emp emp inner join dept dept
on emp.deptno = dept.deptno
group by emp.empno;
+-------+---+----+
| EMPNO | C | A  |
+-------+---+----+
|  7369 | 1 | 20 |
|  7499 | 1 | 30 |
|  7521 | 1 | 30 |
|  7566 | 1 | 20 |
|  7654 | 1 | 30 |
|  7698 | 1 | 30 |
|  7782 | 1 | 10 |
|  7788 | 1 | 20 |
|  7839 | 1 | 10 |
|  7844 | 1 | 30 |
|  7876 | 1 | 20 |
|  7900 | 1 | 30 |
|  7902 | 1 | 20 |
|  7934 | 1 | 10 |
+-------+---+----+
(14 rows)

!ok
LogicalAggregate(group=[{0}], C=[COUNT()], A=[AVG(DISTINCT $1)])
  LogicalProject(EMPNO=[$0], DEPTNO0=[$9])
    LogicalJoin(condition=[=($7, $9)], joinType=[inner])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
      LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform ""
LogicalAggregate(group=[{0}], C=[$SUM0($2)], A=[AVG($1)])
  LogicalAggregate(group=[{0, 1}], C=[COUNT()])
    LogicalProject(EMPNO=[$0], DEPTNO0=[$9])
      LogicalJoin(condition=[=($7, $9)], joinType=[inner])
        LogicalTableScan(table=[[CATALOG, SALES, EMP]])
        LogicalTableScan(table=[[CATALOG, SALES, DEPT]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

# testDistinctNonDistinctAggregatesWithGrouping1 -------------------------------
# [CALCITE-1558] AggregateExpandDistinctAggregatesRule gets field mapping wrong
# if groupKey is used in aggregate function.

SELECT deptno,
  SUM(deptno) as s1, SUM(DISTINCT sal) as s2, MAX(deptno) as m1, MAX(comm) as m2
FROM emp
GROUP BY deptno;
Value 150 out of range
!error
LogicalAggregate(group=[{0}], S1=[SUM($0)], S2=[SUM(DISTINCT $1)], M1=[MAX($0)], M2=[MAX($2)])
  LogicalProject(DEPTNO=[$7], SAL=[$5], COMM=[$6])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], S1=[SUM($2)], S2=[SUM($1)], M1=[MAX($3)], M2=[MAX($4)])
  LogicalAggregate(group=[{0, 1}], S1=[SUM($0)], M1=[MAX($0)], M2=[MAX($2)])
    LogicalProject(DEPTNO=[$7], SAL=[$5], COMM=[$6])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

# testDistinctNonDistinctAggregatesWithGrouping2 -------------------------------
# Tests expansion of SUM(DISTINCT) alongside COUNT of non-distinct column.

SELECT deptno, COUNT(deptno) as c, SUM(DISTINCT sal) as s
FROM emp
GROUP BY deptno;
+--------+---+---------+
| DEPTNO | C | S       |
+--------+---+---------+
