    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalProject(S=[$0], C=[$1])
  LogicalAggregate(group=[{}], S_g0=[MIN($1) FILTER $3], C_g0=[COUNT($0) FILTER $2])
    LogicalProject(SAL=[$0], S=[$2], $g_0_f_1=[AND(=($3, 0), IS TRUE($1))], $g_3=[=($3, 3)])
      LogicalAggregate(group=[{1, 2}], groups=[[{1, 2}, {}]], S=[SUM($0)], $g=[GROUPING($1, $2)])
        LogicalProject(COMM=[$6], SAL=[$5], $f2=[>($5, 1000)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES"

# testDistinctWithFilterWithoutGroupByUsingJoin --------------------------------
# Tests expansion of COUNT(DISTINCT) with a FILTER clause and no GROUP BY,
# using the join-based strategy.

SELECT SUM(comm) as s, COUNT(DISTINCT sal) FILTER (WHERE sal > 1000) as c
FROM emp;
+---------+----+
| S       | C  |
+---------+----+
| 2200.00 | 10 |
+---------+----+
(1 row)

!ok
LogicalAggregate(group=[{}], S=[SUM($0)], C=[COUNT(DISTINCT $1) FILTER $2])
  LogicalProject(COMM=[$6], SAL=[$5], $f2=[>($5, 1000)])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalJoin(condition=[true], joinType=[inner])
  LogicalAggregate(group=[{}], S=[SUM($0)])
    LogicalProject(COMM=[$6], SAL=[$5], $f2=[>($5, 1000)])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
  LogicalAggregate(group=[{}], C=[COUNT($0)])
    LogicalAggregate(group=[{0}])
      LogicalProject(i$SAL=[CASE($2, $1, null:INTEGER)])
        LogicalProject(COMM=[$6], SAL=[$5], $f2=[>($5, 1000)])
          LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

# testDistinctWithGrouping -----------------------------------------------------
