| 1250.00 | 1900.00 | 500.00 | 1250.00 |
| 1300.00 |         |        | 1300.00 |
| 1500.00 |    0.00 |   0.00 | 1500.00 |
| 1600.00 |  300.00 | 300.00 | 1600.00 |
| 2450.00 |         |        | 2450.00 |
| 2850.00 |         |        | 2850.00 |
| 2975.00 |         |        | 2975.00 |
| 3000.00 |         |        | 3000.00 |
| 5000.00 |         |        | 5000.00 |
|  800.00 |         |        |  800.00 |
|  950.00 |         |        |  950.00 |
+---------+---------+--------+---------+
(12 rows)

!ok
LogicalAggregate(group=[{0}], S1=[SUM($1)], N=[MIN($1)], S2=[SUM(DISTINCT $0)])
  LogicalProject(SAL=[$5], COMM=[$6])
    LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform ""
LogicalAggregate(group=[{0}], S1=[SUM($1)], N=[MIN($2)], S2=[SUM($0)])
  LogicalAggregate(group=[{0}], S1=[SUM($1)], N=[MIN($1)])
    LogicalProject(SAL=[$5], COMM=[$6])
      LogicalTableScan(table=[[CATALOG, SALES, EMP]])
!transform "AGGREGATE_EXPAND_DISTINCT_AGGREGATES_TO_JOIN"

